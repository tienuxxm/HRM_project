@model List<Domain.Positions.Position>

@{
    ViewBag.Title = "Position List";
    Layout = "_Layout";
}

<div class="w-full flex flex-col font-geist">
    <!-- Header Section -->
    <div class="mb-6">
        <h2 class="text-[32px] font-bold text-black uppercase tracking-tight">Positions</h2>
        <p class="text-[14px] text-[#4c4546]">Configure organizational job positions, titles, and approval hierarchy levels.</p>
    </div>

    <!-- Search & Action Bar -->
    <!-- Desktop Search & Action Bar -->
    <div class="hidden lg:flex flex-row items-center justify-between gap-4 mb-4">
        <div class="w-[400px] relative">
            <input id="posSearchInput" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5]" placeholder="SEARCH POSITIONS..." type="text"/>
            <span class="material-symbols-outlined absolute right-3 top-2.5 text-[20px] text-[#cfc4c5]">search</span>
        </div>
        <div>
            <button type="button" data-modal-target="createPositionModal" data-modal-toggle="createPositionModal" class="h-10 px-8 bg-black text-white text-[11px] font-bold uppercase tracking-widest hover:opacity-90 transition-all cursor-pointer">
                + Create Position
            </button>
        </div>
    </div>

    <!-- Mobile Search & Action Bar -->
    <div class="lg:hidden mb-4">
        <div class="flex items-stretch gap-0 border border-[#D1D1D1]">
            <div class="flex-grow flex items-center bg-white px-3 border-r border-[#D1D1D1] h-10">
                <span class="material-symbols-outlined text-[#4c4546] mr-2" style="font-size: 16px;">search</span>
                <input id="mobileSearchInput" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" class="w-full bg-transparent border-none focus:ring-0 text-[11px] placeholder:text-[#4c4546] p-0 font-medium" placeholder="SEARCH POSITIONS" type="text"/>
            </div>
            <button type="button" data-modal-target="createPositionModal" data-modal-toggle="createPositionModal" class="bg-black text-white px-4 h-10 text-[11px] font-bold uppercase flex items-center gap-1 active:invert transition-all cursor-pointer">
                <span class="material-symbols-outlined" style="font-size: 14px;">add</span>CREATE
            </button>
        </div>
    </div>

    <!-- Data Layout -->
    <!-- Desktop Data Grid -->
    <div class="hidden lg:flex flex-col border border-[#D1D1D1] bg-white">
        <table class="w-full text-left border-collapse">
            <thead class="bg-[#F5F5F5]">
                <tr class="border-b border-[#D1D1D1]">
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-16 text-center">No</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-32">Code</th>
                    <th class="px-4 py-3 font-bold text-[11px] text-black uppercase border-r border-[#D1D1D1]">Position Name</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-32 text-center">Level</th>
                    <th class="px-4 py-3 font-bold text-[10px] text-[#4c4546] uppercase w-48">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#D1D1D1]">
                @foreach (var pos in Model.Select((val, index) => new { val, index = index + 1 }))
                {
                    <tr class="hover:bg-[#f4f3f3] transition-colors pos-row" data-code="@pos.val.Code" data-name="@pos.val.Name" style="transition: transform 0.15s ease;">
                         <td class="px-4 py-3 font-mono text-[11px] font-bold border-r border-[#D1D1D1] text-center">@pos.index</td>
                         <td class="px-4 py-3 font-mono text-[11px] font-bold border-r border-[#D1D1D1]">@pos.val.Code</td>
                         <td class="px-4 py-3 font-bold text-[12px] text-black border-r border-[#D1D1D1]">@pos.val.Name</td>
                         <td class="px-4 py-3 font-mono text-[11px] font-bold border-r border-[#D1D1D1] text-center">@pos.val.Level</td>
                         <td class="px-4 py-3 whitespace-nowrap">
                             <div class="flex space-x-3">
                                 <a data-modal-target="updatePositionModal-@pos.val.Id.Value" data-modal-toggle="updatePositionModal-@pos.val.Id.Value" class="text-[9px] font-bold text-black hover:text-swiss-red uppercase underline decoration-[#cfc4c5] underline-offset-4 cursor-pointer" href="javascript:void(0)">Edit</a>
                                 <a data-modal-target="confirmDelete-@pos.val.Id.Value" data-modal-toggle="confirmDelete-@pos.val.Id.Value" class="text-[9px] font-bold text-swiss-red hover:opacity-70 uppercase underline decoration-[#cfc4c5] underline-offset-4 cursor-pointer" href="javascript:void(0)">Remove</a>
                             </div>
                         </td>
                    </tr>
                }
            </tbody>
        </table>
        
        <!-- Desktop Table Pagination Footer -->
        <div class="flex items-center justify-between px-4 py-3 border-t border-[#D1D1D1] bg-[#F5F5F5] font-mono text-[10px] font-bold text-[#4c4546] uppercase">
            <div id="desktopShowingText">
                SHOWING 1-4 OF 4 POSITIONS
            </div>
            <div class="flex items-center space-x-6">
                <button type="button" id="desktopPrevBtn" class="bg-transparent border-0 p-0 font-bold hover:text-black transition-colors uppercase font-mono cursor-pointer">PREV</button>
                <span class="text-black font-mono" id="desktopPageText">PAGE 1 OF 1</span>
                <button type="button" id="desktopNextBtn" class="bg-transparent border-0 p-0 font-bold hover:text-black transition-colors uppercase font-mono cursor-pointer">NEXT</button>
            </div>
        </div>
    </div>

    <!-- Mobile Stacked List -->
    <div class="lg:hidden flex flex-col gap-4">
        <div class="flex flex-col gap-4">
            @foreach (var pos in Model)
            {
                <div class="bg-white border border-[#D1D1D1] p-4 flex flex-col gap-3 pos-card" data-code="@pos.Code" data-name="@pos.Name">
                    <div class="flex justify-between items-start">
                        <div class="flex flex-col">
                            <span class="mono text-[10px] text-[#4c4546] font-bold">@pos.Code</span>
                            <h2 class="text-[16px] font-bold uppercase tracking-tight">@pos.Name</h2>
                        </div>
                        <span class="bg-black text-white px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider">LEVEL @pos.Level</span>
                    </div>
                    
                    <div class="flex gap-4 border-t border-[#F1F1F1] pt-3">
                        <button type="button" data-modal-target="updatePositionModal-@pos.Id.Value" data-modal-toggle="updatePositionModal-@pos.Id.Value" class="text-[10px] font-bold uppercase hover:text-primary transition-colors cursor-pointer">[EDIT]</button>
                        <button type="button" data-modal-target="confirmDelete-@pos.Id.Value" data-modal-toggle="confirmDelete-@pos.Id.Value" class="ml-auto text-[#E62429] text-[10px] font-bold uppercase hover:opacity-70 transition-opacity cursor-pointer">[REMOVE]</button>
                    </div>
                </div>
            }
        </div>
        
        <!-- Mobile Pagination Footer -->
        <div class="mt-6 border border-[#D1D1D1] bg-white p-4 flex flex-col gap-3 font-mono text-[11px]">
            <div class="text-center font-bold text-black uppercase" id="mobileShowingText">
                SHOWING 1-4 OF 4 POSITIONS
            </div>
            <div class="grid grid-cols-3 border-t border-[#D1D1D1] pt-3 text-center font-bold">
                <button type="button" id="mobilePrevBtn" class="py-2 hover:bg-black hover:text-white transition-colors bg-transparent border-0 cursor-pointer">PREV</button>
                <span class="py-2 text-black" id="mobilePageText">PAGE 1 OF 1</span>
                <button type="button" id="mobileNextBtn" class="py-2 hover:bg-black hover:text-white transition-colors bg-transparent border-0 cursor-pointer">NEXT</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Container -->
@Html.Partial("_CreatePositionPartial")

@foreach (var pos in Model)
{
    @Html.Partial("_UpdatePositionPartial", pos)
    @Html.Partial("_ConfirmDeletePartial", new ConfirmDeleteViewModel()
    {
        Id = pos.Id.Value,
        Type = "Position",
        Name = pos.Name,
        ActionName = "Delete",
        ActionController = "Position"
    })
}

@section Scripts {
<script>
    let currentPage = 1;
    const pageSize = 10;

    const successUrl = '@Url.Action("SuccessToastPartial", "Main", new { message = "__MSG__" }, null)';
    const failUrl = '@Url.Action("FailToastPartial", "Main", new { message = "__MSG__" }, null)';

    function showSuccessToast(message) {
        const url = successUrl.replace('__MSG__', encodeURIComponent(message));
        $('#toast-container').load(url);
    }
    function showFailToast(message) {
        const url = failUrl.replace('__MSG__', encodeURIComponent(message));
        $('#toast-container').load(url);
    }

    function applyFilterAndPagination() {
        const searchInput = $('#posSearchInput');
        const searchTerm = searchInput.length ? (searchInput.val() || '').toLowerCase().trim() : '';
        
        const matchedDesktopRows = [];
        const matchedMobileCards = [];
        
        $('.pos-row').each(function() {
            const code = ($(this).attr('data-code') || '').toLowerCase();
            const name = ($(this).attr('data-name') || '').toLowerCase();
            const matches = code.includes(searchTerm) || name.includes(searchTerm);
            if (matches) {
                matchedDesktopRows.push(this);
            } else {
                $(this).hide();
            }
        });
        
        $('.pos-card').each(function() {
            const code = ($(this).attr('data-code') || '').toLowerCase();
            const name = ($(this).attr('data-name') || '').toLowerCase();
            const matches = code.includes(searchTerm) || name.includes(searchTerm);
            if (matches) {
                matchedMobileCards.push(this);
            } else {
                $(this).hide();
            }
        });
        
        const totalMatches = matchedDesktopRows.length;
        const totalPages = Math.ceil(totalMatches / pageSize) || 1;
        
        if (currentPage > totalPages) {
            currentPage = totalPages;
        }
        if (currentPage < 1) {
            currentPage = 1;
        }
        
        const startIdx = (currentPage - 1) * pageSize;
        const endIdx = Math.min(startIdx + pageSize, totalMatches);
        
        // Hide all rows/cards first
        $('.pos-row').hide();
        $('.pos-card').hide();
        
        // Show current page items
        for (let i = startIdx; i < endIdx; i++) {
            $(matchedDesktopRows[i]).show();
            $(matchedMobileCards[i]).show();
        }
        
        // Update labels
        const showingFrom = totalMatches === 0 ? 0 : startIdx + 1;
        const showingTo = endIdx;
        const showingLabel = `SHOWING ${showingFrom}-${showingTo} OF ${totalMatches} POSITIONS`;
        
        $('#desktopShowingText').text(showingLabel);
        $('#mobileShowingText').text(showingLabel);
        
        const pageLabel = `PAGE ${currentPage} OF ${totalPages}`;
        $('#desktopPageText').text(pageLabel);
        $('#mobilePageText').text(pageLabel);
        
        // Enable/Disable buttons styling
        if (currentPage <= 1) {
            $('#desktopPrevBtn, #mobilePrevBtn')
                .addClass('opacity-50 pointer-events-none')
                .removeClass('hover:text-black hover:bg-black hover:text-white');
        } else {
            $('#desktopPrevBtn, #mobilePrevBtn')
                .removeClass('opacity-50 pointer-events-none');
        }
        
        if (currentPage >= totalPages) {
            $('#desktopNextBtn, #mobileNextBtn')
                .addClass('opacity-50 pointer-events-none')
                .removeClass('hover:text-black hover:bg-black hover:text-white');
        } else {
            $('#desktopNextBtn, #mobileNextBtn')
                .removeClass('opacity-50 pointer-events-none');
        }
    }

    $(document).ready(function() {
        // Sync search input values
        $('#posSearchInput').on('input', function() {
            $('#mobileSearchInput').val($(this).val());
            currentPage = 1;
            applyFilterAndPagination();
        });
        
        $('#mobileSearchInput').on('input', function() {
            $('#posSearchInput').val($(this).val());
            currentPage = 1;
            applyFilterAndPagination();
        });
        
        // Hook prev buttons
        $(document).on('click', '#desktopPrevBtn, #mobilePrevBtn', function(e) {
            e.preventDefault();
            if (currentPage > 1) {
                currentPage--;
                applyFilterAndPagination();
            }
        });
        
        // Hook next buttons
        $(document).on('click', '#desktopNextBtn, #mobileNextBtn', function(e) {
            e.preventDefault();
            const searchInput = $('#posSearchInput');
            const searchTerm = searchInput.length ? (searchInput.val() || '').toLowerCase().trim() : '';
            let totalMatches = 0;
            $('.pos-row').each(function() {
                const code = ($(this).attr('data-code') || '').toLowerCase();
                const name = ($(this).attr('data-name') || '').toLowerCase();
                if (code.includes(searchTerm) || name.includes(searchTerm)) {
                    totalMatches++;
                }
            });
            const totalPages = Math.ceil(totalMatches / pageSize) || 1;
            if (currentPage < totalPages) {
                currentPage++;
                applyFilterAndPagination();
            }
        });
        
        // Row slide-in hover micro-interactions
        $(document).on('mouseenter', '.pos-row', function() {
            $(this).css({
                'transform': 'translateX(4px)',
                'transition': 'transform 0.15s ease'
            });
        }).on('mouseleave', '.pos-row', function() {
            $(this).css({
                'transform': 'translateX(0px)'
            });
        });

        // Event Delegation for Create Position Form Submit
        $(document).on('click', '#savePosButton', function(e) {
            e.preventDefault();
            const button = $(this);
            if (button.prop('disabled')) return;
            
            const posCodeError = $('#posCodeError');
            const posNameError = $('#posNameError');
            const posLevelError = $('#posLevelError');
            
            posCodeError.hide().text('');
            posNameError.hide().text('');
            posLevelError.hide().text('');
            
            const posCode = ($('#posCode').val() || '').trim().toUpperCase();
            const posName = ($('#posName').val() || '').trim();
            const posLevel = $('#posLevel').val();
            
            if (!posCode) {
                posCodeError.text("Please enter position code").show();
                return;
            }
            if (!posName) {
                posNameError.text("Please enter position name").show();
                return;
            }
            if (!posLevel || isNaN(posLevel) || parseInt(posLevel) < 1) {
                posLevelError.text("Please enter a valid level (>= 1)").show();
                return;
            }
            
            button.prop('disabled', true);
            
            const formData = new FormData();
            formData.append('Code', posCode);
            formData.append('Name', posName);
            formData.append('Level', parseInt(posLevel));
            
            $.ajax({
                type: "POST",
                url: "/position/create",
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    showSuccessToast("Position created successfully");
                    setTimeout(() => {
                        location.href = "/position";
                    }, 1500);
                },
                error: function (xhr) {
                    showFailToast("Position creation failed");
                    button.prop('disabled', false);
                }
            });
        });

        // Event Delegation for Update Position Form Submit
        $(document).on('click', '[id^="savePosButton-"]', function(e) {
            e.preventDefault();
            const button = $(this);
            if (button.prop('disabled')) return;
            
            const buttonId = button.attr('id') || '';
            const id = buttonId.substring("savePosButton-".length);
            if (!id) return;
            
            const posCodeError = $('#posCodeError-' + id);
            const posNameError = $('#posNameError-' + id);
            const posLevelError = $('#posLevelError-' + id);
            
            posCodeError.hide().text('');
            posNameError.hide().text('');
            posLevelError.hide().text('');
            
            const posCode = ($('#posCode-' + id).val() || '').trim().toUpperCase();
            const posName = ($('#posName-' + id).val() || '').trim();
            const posLevel = $('#posLevel-' + id).val();
            
            if (!posCode) {
                posCodeError.text("Please enter position code").show();
                return;
            }
            if (!posName) {
                posNameError.text("Please enter position name").show();
                return;
            }
            if (!posLevel || isNaN(posLevel) || parseInt(posLevel) < 1) {
                posLevelError.text("Please enter a valid level (>= 1)").show();
                return;
            }
            
            button.prop('disabled', true);
            
            const formData = new FormData();
            formData.append('Id', id);
            formData.append('Code', posCode);
            formData.append('Name', posName);
            formData.append('Level', parseInt(posLevel));
            
            $.ajax({
                type: "POST",
                url: "/position/update",
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    showSuccessToast("Position updated successfully");
                    setTimeout(() => {
                        location.href = "/position";
                    }, 1500);
                },
                error: function (xhr) {
                    showFailToast("Position update failed");
                    button.prop('disabled', false);
                }
            });
        });
        
        // Initial pagination setup
        applyFilterAndPagination();
    });
</script>
}

