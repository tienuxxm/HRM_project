<div id="createPositionModal" tabindex="-1" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Static Backdrop (Enterprise Calm Dim style) -->
    <div class="fixed inset-0 hrm-modal-backdrop bg-black bg-opacity-40" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal content panel -->
        <div class="w-full max-w-[480px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Modal Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">ADD POSITION</span>
                <button type="button" class="bg-[#E62429] w-8 h-8 flex items-center justify-center hover:bg-[#c51f24] transition-colors" data-modal-hide="createPositionModal">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Modal Body -->
            <div class="p-6 flex flex-col gap-4 text-left font-geist">
                <div>
                    <label for="posCode" class="block mb-1.5 font-mono text-[10px] font-bold text-[#4c4546] uppercase">Position Code</label>
                    <input type="text" autocomplete="off" placeholder="E.G. CEO, DEPT_MANAGER" id="posCode" class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5] rounded-none" required>
                    <p id="posCodeError" class="mt-1.5 text-[10px] font-bold uppercase tracking-wide text-[#E62429] hidden"></p>
                </div>
                <div>
                    <label for="posName" class="block mb-1.5 font-bold text-[11px] text-black uppercase">Position Name</label>
                    <input type="text" autocomplete="off" placeholder="ENTER POSITION NAME" id="posName" class="w-full h-10 bg-white border border-[#D1D1D1] px-4 text-[11px] focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5] rounded-none" required>
                    <p id="posNameError" class="mt-1.5 text-[10px] font-bold uppercase tracking-wide text-[#E62429] hidden"></p>
                </div>
                <div>
                    <label for="posLevel" class="block mb-1.5 font-bold text-[11px] text-black uppercase">Level (Hierarchy / Approval)</label>
                    <input type="number" min="1" max="100" placeholder="E.G. 1" id="posLevel" class="w-full h-10 bg-white border border-[#D1D1D1] px-4 text-[11px] focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5] rounded-none" required>
                    <p id="posLevelError" class="mt-1.5 text-[10px] font-bold uppercase tracking-wide text-[#E62429] hidden"></p>
                </div>
            </div>
            <!-- Modal Footer -->
            <div class="h-16 flex items-center justify-end gap-3 px-6 bg-[#FBFBFB] border-t border-[#D1D1D1]">
                <button data-modal-hide="createPositionModal" type="button" class="bg-white border border-[#D1D1D1] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#F4F3F3] transition-colors rounded-none cursor-pointer">
                    CANCEL
                </button>
                <button type="button" id="savePosButton" class="bg-black text-white border border-black px-6 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:opacity-95 transition-all rounded-none cursor-pointer">
                    CREATE
                </button>
            </div>
        </div>
    </div>
</div>

