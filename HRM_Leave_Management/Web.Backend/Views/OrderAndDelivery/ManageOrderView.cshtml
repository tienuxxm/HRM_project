@model ManageOrderViewModel
@{
    ViewBag.Title = Model.Title;
    Layout = "_Layout";
}

<nav class="flex mb-4" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
            <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">
                <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                    <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
                </svg>
            </a>
        </li>
        <li>
            <div class="flex items-center">
                <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                </svg>
                <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">General Management</span>
            </div>
        </li>
        <li>
            <div class="flex items-center">
                <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                </svg>
                <a href="/delivery" class="ml-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ml-2 dark:text-gray-400 dark:hover:text-white">Delivery list</a>
            </div>
        </li>
        <li aria-current="page">
            <div class="flex items-center">
                <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                </svg>
                <a href="#" class="ml-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ml-2 dark:text-gray-400 dark:hover:text-white">Add giao@**@ hàng</a>
            </div>
        </li>
    </ol>
</nav>

<div id="createOrderDeliveryForm" style="min-height: 500px" class="w-full bg-white p-4 rounded-md flex flex-col justify-between" enctype="multipart/form-data">
    <div class="w-full flex flex-col">
        <h1 class="text-black font-semibold text-xl">@Model.Title</h1>
        <div class="grid grid-cols-12 gap-2 mt-3">
            <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12">
                <label for="memberList" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Customer</label>
                <div class="relative mt-1.5 group">
                    <input
                        asp-for="Model.MemberId"
                        autocomplete="off"
                        type="text"
                        value="@Model.Model.Fullname"
                        name="MemberId"
                        id="memberList"
                        class="transition p-[10px] ease-in-out delay-150 w-full rounded-lg border-gray-300 pe-10 text-gray-700 sm:text-sm [&::-webkit-calendar-picker-indicator]:opacity-0"
                        placeholder="Select Customer"/>
                    <div id="selectMemberDropdown" class="w-full mt-2 absolute p-2 bg-white rounded-lg shadow-sm transition ease-in-out delay-150">
                        <div id="selectMemberDropdownItemContainer" class="mt-1 p-1 w-full flex-col max-h-[250px]  h-[128px] overflow-y-auto relative">
                            <span id="searchPlaceholder" class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-sm">Enter to search</span>
                            <span id="searchResult" class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-sm">Not found</span>
                            <div role="status" id="loadingSpinner" class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                                <svg aria-hidden="true" class="w-8 h-8 mr-2 text-gray-200 animate-spin dark:text-gray-600 fill-blue-600" viewBox="0 0 100 101" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor"/>
                                    <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentFill"/>
                                </svg>
                                <span class="sr-only">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
                <p id="memberNameError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                <style>
                    #selectMemberDropdown{
                        transition: all .8s ease-in-out;
                        display: none;
                    }
                    #selectMemberDropdown:hover{
                        display: block;
                    }
                    #memberList:focus + #selectMemberDropdown{
                        transition: all .8s ease-in-out;
                       display: block;
                    }
                    #memberList:active + #selectMemberDropdown{
                        transition: all .8s ease-in-out;
                       display: block;
                    }
                </style>
            </div>
            <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12">
                <label for="deliveryAddress" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Delivery Address</label>
                <input onchange="clearFormError('delivery')" value="@Model.Model.DeliveryAddress" type="text" name="DeliveryAddress" id="deliveryAddress" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Enter Delivery Address" required>
                <p id="deliveryAddressError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
            </div>
            <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12">
                <label for="note" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Notes</label>
                <input value="@Model.Model.Note" type="text" name="Note" id="note" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Enter Notes">
            </div>
            <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12 flex flex-col justify-content-between">
                <label class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Request to add a spoon</label>
                <div class="w-full flex">
                    <div class="flex items-center">
                        <input checked="@(Model.Model.HasRequestCutlery)" id="hasRequestCutleryYes" type="radio" value="true" name="hasRequestCutlery" class="text-wnz-yellow w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 focus:ring-wnz-yellow focus:ring-2">
                        <label for="hasRequestCutleryNo" class="ml-2 text-sm font-medium text-gray-900 dark:text-gray-300">Yes</label>
                    </div>
                    <div class="flex items-center">
                        <input checked="@(!Model.Model.HasRequestCutlery)" id="hasRequestCutleryNo" type="radio" value="false" name="hasRequestCutlery" class="text-wnz-yellow ml-2 w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 focus:ring-wnz-yellow focus:ring-2">
                        <label for="hasRequestCutleryNo" class="ml-2 text-sm font-medium text-gray-900 dark:text-gray-300">No</label>
                    </div>
                </div>
            </div>
            <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12">
                <label for="paymentType" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Payment Method</label>
                <select name="PaymentType" id="paymentType" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500">
                    @foreach (var res in Model.PatymentTypes)
                    {
                        @if (res.Key == (int)Model.Model.PaymentType)
                        {
                            <option selected value="@res.Key">@res.Value</option>
                        }
                        else
                        {
                            <option value="@res.Key">@res.Value</option>
                        }
                    }
                </select>
            </div>
            <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12 flex flex-col justify-content-between">
                <label class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Generate invoice</label>
                <div class="w-full flex">
                    <div class="flex items-center">
                        <input onchange="toggleIssueAnInvoice(true)" asp-for="Model.HasIssueAnInvoice" checked="@(Model.Model.HasIssueAnInvoice)" id="HasIssueAnInvoiceYes" type="radio" value="true" name="HasIssueAnInvoice" class="text-wnz-yellow w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 focus:ring-wnz-yellow focus:ring-2">
                        <label for="HasIssueAnInvoiceYes" class="ml-2 text-sm font-medium text-gray-900 dark:text-gray-300">Yes</label>
                    </div>
                    <div class="flex items-center">
                        <input checked="@(!Model.Model.HasIssueAnInvoice)" onchange="toggleIssueAnInvoice(false)" asp-for="Model.HasIssueAnInvoice" id="HasIssueAnInvoiceNo" type="radio" value="false" name="HasIssueAnInvoice" class="text-wnz-yellow ml-2 w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 focus:ring-wnz-yellow focus:ring-2">
                        <label for="HasIssueAnInvoiceNo" class="ml-2 text-sm font-medium text-gray-900 dark:text-gray-300">No</label>
                    </div>
                </div>
            </div>
            <div class="col-span-12" id="companyField">
                <div class="grid grid-cols-12 gap-2">
                    <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12">
                        <label id="lblCompanyTaxCode" for="companyTaxCode" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Tax code</label>
                        <input onchange="clearFormError('taxCode')" value="@Model.Model.CompanyTaxCode" asp-for="Model.CompanyTaxCode" type="text" name="CompanyTaxCode" id="companyTaxCode" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Enter Tax code" required>
                        <p id="companyTaxCodeError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                    </div>
                    <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12">
                        <label id="lblCompanyName" for="companyName" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Company Name</label>
                        <input onchange="clearFormError('companyName')" value="@Model.Model.CompanyName" asp-for="Model.CompanyName" required type="text" name="CompanyName" id="companyName" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Enter Company Name">
                        <p id="companyNameError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                    </div>
                    <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12">
                        <label id="lblCompanyMail" for="companyMail" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Company Email</label>
                        <input onchange="clearFormError('companyEmail')" value="@Model.Model.CompanyEmail" asp-for="Model.CompanyEmail" type="email" name="CompanyMail" id="companyMail" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Enter Company Email" required>
                        <p id="companyEmailError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                    </div>
                    <div class="2xl:col-span-6 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-12">
                        <label id="lblCompanyAddress" for="companyAddress" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Company Address</label>
                        <input onchange="clearFormError('companyAddress')" value="@Model.Model.CompanyAddress" required asp-for="Model.CompanyAddress" type="text" name="CompanyAddress" id="companyAddress" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Enter Company Address">
                        <p id="companyAddressError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                    </div>
                </div>
            </div>
            <div class="col-span-12 border rounded-lg border-gray-900 p-2">
                <div class="flex justify-content-between items-center border-b pb-2 border-gray-900">
                    <span class="text-lg font-medium text-dark required-label">SELECT DISH</span>
                    <a onclick="addNewLineItem()" type="button"
                       class="inline-block rounded bg-indigo-600 px-4 py-1 px-2 text-sm font-medium text-white transition hover:scale-110 hover:shadow-xl focus:outline-none focus:ring active:bg-indigo-500">
                        Add Dish
                    </a>
                </div>
                <div class="w-full" id="lineItemsList">
                    <p id="lineItemError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                </div>
                <div class="col-span-12 border-t pt-2 mt-3 border-gray-900">
                    <div class="flex gap-2">
                        <span class="text-lg font-medium text-red-500">Total: </span>
                        <span class="text-lg font-medium text-red-500" id="totalPrice"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="w-full flex justify-content-end">
        <button type="button" class="mx-1 border border-wnz-yellow block rounded bg-white px-3 py-2 text-sm font-medium text-black transition hover:scale-110 hover:shadow-xl focus:outline-none focus:ring active:bg-indigo-500">
            <div class="flex justify-center items-center">
                <svg width="15" height="13" viewBox="0 0 15 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14.8887 8.41675C14.8887 9.28133 14.5579 10.4558 13.8965 11.9402C13.8809 11.9766 13.8522 12.0391 13.8105 12.1277C13.7741 12.2162 13.7402 12.2944 13.709 12.3621C13.6777 12.4298 13.6439 12.4871 13.6074 12.5339C13.5449 12.6225 13.472 12.6667 13.3887 12.6667C13.3105 12.6667 13.248 12.6407 13.2012 12.5886C13.1595 12.5365 13.1387 12.4714 13.1387 12.3933C13.1387 12.3464 13.1439 12.2761 13.1543 12.1824C13.1699 12.0938 13.1777 12.0339 13.1777 12.0027C13.2038 11.6485 13.2168 11.3282 13.2168 11.0417C13.2168 10.5157 13.1699 10.0444 13.0762 9.62769C12.9876 9.21102 12.8626 8.85164 12.7012 8.54956C12.5397 8.24227 12.3314 7.97925 12.0762 7.7605C11.821 7.53654 11.5449 7.35425 11.248 7.21362C10.9564 7.073 10.61 6.96362 10.209 6.8855C9.81315 6.80216 9.41211 6.74487 9.00586 6.71362C8.60482 6.68237 8.14909 6.66675 7.63867 6.66675H5.88867V8.66675C5.88867 8.80216 5.83919 8.91935 5.74023 9.01831C5.64128 9.11727 5.52409 9.16675 5.38867 9.16675C5.25326 9.16675 5.13607 9.11727 5.03711 9.01831L1.03711 5.01831C0.938151 4.91935 0.888672 4.80216 0.888672 4.66675C0.888672 4.53133 0.938151 4.41414 1.03711 4.31519L5.03711 0.315185C5.13607 0.216227 5.25326 0.166748 5.38867 0.166748C5.52409 0.166748 5.64128 0.216227 5.74023 0.315185C5.83919 0.414143 5.88867 0.531331 5.88867 0.666747V2.66675H7.63867C11.3522 2.66675 13.6309 3.71623 14.4746 5.81519C14.7507 6.5131 14.8887 7.38029 14.8887 8.41675Z" fill="black"/>
                </svg>
                <span class="mx-1">Cancel</span>
            </div>
        </button>
        <button id="saveButton" class="mx-1 block rounded bg-wnz-yellow px-3 py-2 text-sm font-medium text-white transition hover:scale-110 hover:shadow-xl focus:outline-none focus:ring active:bg-indigo-500">
            <div class="flex justify-center items-center">
                <svg width="12" height="13" viewBox="0 0 12 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 11.6667H9V8.66675H3V11.6667ZM10 11.6667H11V4.66675C11 4.59383 10.974 4.49487 10.9219 4.36987C10.8698 4.23966 10.8177 4.14852 10.7656 4.09644L8.57031 1.90112C8.51823 1.84904 8.42969 1.79696 8.30469 1.74487C8.17969 1.69279 8.07813 1.66675 8 1.66675V4.91675C8 5.12508 7.92708 5.30216 7.78125 5.448C7.63542 5.59383 7.45833 5.66675 7.25 5.66675H2.75C2.54167 5.66675 2.36458 5.59383 2.21875 5.448C2.07292 5.30216 2 5.12508 2 4.91675V1.66675H1V11.6667H2V8.41675C2 8.20841 2.07292 8.03133 2.21875 7.8855C2.36458 7.73966 2.54167 7.66675 2.75 7.66675H9.25C9.45833 7.66675 9.63542 7.73966 9.78125 7.8855C9.92708 8.03133 10 8.20841 10 8.41675V11.6667ZM7 4.41675V1.91675C7 1.84904 6.97396 1.79175 6.92188 1.74487C6.875 1.69279 6.81771 1.66675 6.75 1.66675H5.25C5.18229 1.66675 5.1224 1.69279 5.07031 1.74487C5.02344 1.79175 5 1.84904 5 1.91675V4.41675C5 4.48446 5.02344 4.54435 5.07031 4.59644C5.1224 4.64331 5.18229 4.66675 5.25 4.66675H6.75C6.81771 4.66675 6.875 4.64331 6.92188 4.59644C6.97396 4.54435 7 4.48446 7 4.41675ZM12 4.66675V11.9167C12 12.1251 11.9271 12.3022 11.7813 12.448C11.6354 12.5938 11.4583 12.6667 11.25 12.6667H0.75C0.541667 12.6667 0.364583 12.5938 0.21875 12.448C0.0729167 12.3022 0 12.1251 0 11.9167V1.41675C0 1.20841 0.0729167 1.03133 0.21875 0.885497C0.364583 0.739664 0.541667 0.666747 0.75 0.666747H8C8.20833 0.666747 8.4375 0.718831 8.6875 0.822998C8.9375 0.927165 9.13542 1.05216 9.28125 1.198L11.4688 3.3855C11.6146 3.53133 11.7396 3.72925 11.8438 3.97925C11.9479 4.22925 12 4.45841 12 4.66675Z" fill="white"/>
                </svg>
                <span class="mx-1">Save</span>
            </div>
        </button>
    </div>

</div>

@section Scripts
{
    <script>
        const loading = $("#loadingSpinner");
        const searchPlaceholder = $("#searchPlaceholder");
        const selectMemberDropdownItemContainer = $("#selectMemberDropdownItemContainer")
        const searchResult = $('#searchResult')
        const isUpdate = @(Model.Model.Id.HasValue ? "true" : "false")
        let isFormValid = false;
        let selectedMemberId;
        let extendLineItemIds = [];
        loading.hide();
        searchResult.hide();
        function setMemberSelected(member){
            $("#memberList").val(member)
        }


        const memberList = $('#memberList')
        $('#memberList').on('keyup', debounce(() => searchMember()))
        $('#memberList').on('keypress', function (){
            selectMemberDropdownItemContainer.find('.member-item').remove()
            searchPlaceholder.hide();
            searchResult.hide();
            loading.show()
        })
        
        const memberError = $('#memberNameError');
        const deliveryAddressError= $('#deliveryAddressError');
        const companyTaxCodeError = $('#companyTaxCodeError');
        const companyNameError = $('#companyNameError');
        const companyEmailError = $('#companyEmailError');
        const companyAddressError = $('#companyAddressError');
        const lineItemError = $('#lineItemError')
        
        function clearFormError(form){
            switch (form){
                case 'member':
                    memberError.hide();
                    break;
                case 'delivery':
                    deliveryAddressError.hide();
                    break;
                case 'taxCode':
                    companyTaxCodeError.hide();
                    break;
                case 'companyName':
                    companyNameError.hide();
                    break;
                case 'companyEmail':
                    companyEmailError.hide();
                    break;
                case 'companyAddress':
                    companyAddressError.hide();
                    break;
                case 'lineItem':
                    lineItemError.hide();
                    break;
            }
        }
        
        function resetFormError(){
            isFormValid = false;
            memberError.hide();
            deliveryAddressError.hide();
            companyTaxCodeError.hide();
            companyNameError.hide();
            companyEmailError.hide();
            companyAddressError.hide();
            memberError.hide();
            lineItemError.hide();
        }
        
        resetFormError(); 
        
        function formValidate(){
            
           resetFormError(); 
           const deliveryAddress = $('#deliveryAddress').val()
           const hasIssueAnInvoice = $(document).find("[name='HasIssueAnInvoice']:checked").val()
           let errors = []
           if (!selectedMemberId){
               const error = 'Please select a Customer'
               errors.push(error)
               memberError.text(error)
               memberError.show();
           }
           
           if (deliveryAddress.trim() === '' ||  !deliveryAddress){
               const error = 'Please Enter Delivery Address'
               errors.push(error)
               deliveryAddressError.text(error)
               deliveryAddressError.show();
           }
           
           if (extendLineItemIds.length === 0){
               const error = 'Please select a dish'
               errors.push(error)
               lineItemError.text(error)
               lineItemError.show();
           }
           
           if (hasIssueAnInvoice === 'true'){
               const companyTaxCode = $('#companyTaxCode').val();
               const companyEmail = $('#companyMail').val();
               const companyName = $('#companyName').val();
               const companyAddress = $('#companyAddress').val();
               
               if (companyTaxCode === '' || !companyTaxCode){
                   const error = 'Please enter the company tax code'
                   errors.push(error)
                   companyTaxCodeError.text(error)
                   companyTaxCodeError.show();
               }
               
               if(companyEmail === '' || !companyEmail){
                   const error = 'Please enter the company email'
                   errors.push(error)
                   companyEmailError.text(error)
                   companyEmailError.show();
               }
               
               if (companyAddress === '' || !companyAddress){
                   const error = 'Please enter company address'
                   errors.push(error)
                   companyAddressError.text(error)
                   companyAddressError.show();
               }
               
               if (companyName === '' || !companyName){
                   const error = 'Please company name'
                   errors.push(error)
                   companyNameError.text(error)
                   companyNameError.show();
               }
               
           }
           
               isFormValid = errors.length === 0;
        }
        
        const saveButton = $('#saveButton')
        saveButton.on('click', event => {
            event.preventDefault(); 
            formValidate()
            console.log(isFormValid)
            if (!isFormValid){
                return;
            }
            const loadingOverlay = $('#loadingOverlay');
            loadingOverlay.show();
            const toastContainer = $('#toast-container')
            
            const deliveryAddress = $('#deliveryAddress').val()
            const note = $('#note').val()
            const hasRequestCutlery = $(document).find("[name='hasRequestCutlery']:checked").val()
            const hasIssueAnInvoice = $(document).find("[name='HasIssueAnInvoice']:checked").val()
            const paymentType = $('#paymentType').val()
            const companyTaxCode  = $('#companyTaxCode').val()
            const companyAddress  = $('#companyAddress').val()
            const companyEmail  = $('#companyMail').val()
            const companyName  = $('#companyName').val()
            
            
            const lineItems = []
            
            extendLineItemIds.forEach(id => {
                const productId = $(`#productList${id}`).val();
                const quantity = parseInt($(`#productQuantity${id}`).val());
                const note = $(`#productNote${id}`).val();
                lineItems.push({
                    productId,
                    quantity,
                    note
                })
            })
            
            let request = {
                memberId: selectedMemberId,
                deliveryAddress,
                note,
                hasRequestCutlery,
                hasIssueAnInvoice,
                paymentType,
                lineItems
            }
            if (hasIssueAnInvoice){
                request = {
                    ...request,
                    companyTaxCode,
                    companyAddress,
                    companyEmail,
                    companyName
                } 
            }
            if (isUpdate){
               request = {
                   ...request,
                   id: '@Model.Model.Id'
               }
            }
            
            
            $.ajax({
                type: "POST",
                url: `/delivery/Create`,
                data: {
                    ...request
                },
                dataType: 'multipart/form-data',
                success: function () {
                    loadingOverlay.hide();
                    showToast('Save Success')
                    setTimeout(() => {
                        loadingOverlay.show();
                        location.href = "/delivery"
                    }, 1500)
                },error: function (error){
                    if (error.status === 200){
                        loadingOverlay.hide();
                        showToast('Save Success')
                        setTimeout(() => {
                            loadingOverlay.show();
                            location.href = "/delivery"
                        }, 1500)
                    }else{
                        loadingOverlay.hide();
                        showToast('Save Failed', false)
                        console.log("error",error)    
                    }
                }
            })
        })
        
        const lineItemsContainer = $("#lineItemsList")
        function uuidv4() {
          return "10000000-1000-4000-8000-100000000000".replace(/[018]/g, c =>
            (c ^ crypto.getRandomValues(new Uint8Array(1))[0] & 15 >> c / 4).toString(16)
          );
        }
        let productList = []
        productList = @(Json.Serialize(Model.Products))
        
        function calculateTotalPrice() {
          
            const lineItems = []
            const defaultLineItemProductId = $("#productList").val();
            const defaultLineItemProductQuantity = $("#productQuantity").val();
            const defaultLineItemProductNote = $("#productNote").val();
            lineItems.push({
                 productId: defaultLineItemProductId,
                 quantity: defaultLineItemProductQuantity,
                 note: defaultLineItemProductNote
            })
            
            extendLineItemIds.forEach(id => {
                const productId = $(`#productList${id}`).val();
                const quantity = parseInt($(`#productQuantity${id}`).val());
                const note = $(`#productNote${id}`).val();
                lineItems.push({
                    productId,
                    quantity,
                    note
                })
            })
            let total = 0;
            
            lineItems.forEach(item => {
               const product = productList.find(x => x.id === item.productId)
               if (product){
                   total += (product.price * item.quantity)
               }
            });
            
            $('#totalPrice').text(new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total))
        }
        let lineItems = []
        $(document).ready(function() {
            const hasIssueAnInvoiceAfterInit = ($(document).find("[name='HasIssueAnInvoice']:checked").val()) === 'true'
            toggleIssueAnInvoice(hasIssueAnInvoiceAfterInit)
            if (isUpdate){
                
            selectedMemberId = '@Model.Model.MemberId'
            lineItems = @(Json.Serialize(Model.Model.LineItems))
            lineItems?.forEach(item => {
                addNewLineItem(item.productId, item.quantity, item.note ?? '' )
            })
        }else{
                addNewLineItem();
        }
        });
        
        calculateTotalPrice();
        
        function addNewLineItem(productId = null, quantity = 1, note = ''){
            clearFormError('lineItem')
            const id = uuidv4();
            extendLineItemIds.push(id);
            lineItemsContainer.append(`<div class="grid grid-cols-12 gap-2 mt-3 relative" id="lineItem${id}">
                        <div id="lineItemRemoveIcon${id}" class="absolute right-0 top-0 cursor-pointer hover:scale-110">
                            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M10.1406 8.32812C10.1406 8.52344 10.0625 8.71875 9.92188 8.85937L8.85938 9.92187C8.71875 10.0625 8.52344 10.1406 8.32813 10.1406C8.13281 10.1406 7.9375 10.0625 7.79688 9.92187L5.5 7.625L3.20313 9.92187C3.0625 10.0625 2.86719 10.1406 2.67188 10.1406C2.47656 10.1406 2.28125 10.0625 2.14063 9.92187L1.07813 8.85937C0.9375 8.71875 0.859375 8.52344 0.859375 8.32812C0.859375 8.13281 0.9375 7.9375 1.07813 7.79687L3.375 5.5L1.07813 3.20312C0.9375 3.0625 0.859375 2.86719 0.859375 2.67188C0.859375 2.47656 0.9375 2.28125 1.07813 2.14062L2.14063 1.07812C2.28125 0.9375 2.47656 0.859374 2.67188 0.859374C2.86719 0.859374 3.0625 0.9375 3.20313 1.07812L5.5 3.375L7.79688 1.07812C7.9375 0.9375 8.13281 0.859374 8.32813 0.859374C8.52344 0.859374 8.71875 0.9375 8.85938 1.07812L9.92188 2.14062C10.0625 2.28125 10.1406 2.47656 10.1406 2.67188C10.1406 2.86719 10.0625 3.0625 9.92188 3.20312L7.625 5.5L9.92188 7.79687C10.0625 7.9375 10.1406 8.13281 10.1406 8.32812Z" fill="#FF0202"/>
                            </svg>
                        </div>
                        <div class="2xl:col-span-5 xl:col-span-4 lg:col-span-4 md:col-span-4 col-span-12">
                            <label for="productList${id}" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Dishes</label>
                            <select placeholder="Select Dishes" name="productId${id}" id="productList${id}" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500">
                                ${productList.map(p => {
                                    if (productId === p.id){
                                        return `<option selected value="${p.id}">${p.productName}</option>`
                                    }else{
                                        return `<option value="${p.id}">${p.productName}</option>`
                                    }
                                })}
                            </select>
                        </div>
                        <div class="2xl:col-span-1 xl:col-span-2 lg:col-span-2 md:col-span-2 col-span-4">
                            <label for="productQuantity${id}" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Quantity</label>
                            <input value="${quantity}" required type="number" min="1" name="productQuantity${id}" id="productQuantity${id}" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Số lượng">
                        </div>
                        <div class="2xl:col-span-5 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-8">
                            <label for="productNote${id}" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Notes</label>
                            <input value="${note}" type="text" name="productNote${id}" id="productNote${id}" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Enter Notes">
                        </div>
                    </div>`)
                    $(`#lineItemRemoveIcon${id}`).one('click', () => removeLineItem(id))
                    $(`#productQuantity${id}`).on('change', () => calculateTotalPrice())
                    $(`#productList${id}`).on('change', () => calculateTotalPrice())
                    calculateTotalPrice()
        }
        
        function removeLineItem(lineItemId){
            extendLineItemIds = extendLineItemIds.filter(x => x !== lineItemId)
            $(`#lineItem${lineItemId}`).remove()
            calculateTotalPrice();
        }
        
        const lblCompanyTaxCode = $("#lblCompanyTaxCode")
        const lblCompanyEmail = $("#lblCompanyMail")
        const lblCompanyAddress = $("#lblCompanyAddress")
        const lblCompanyName = $("#lblCompanyName")
        const companyTaxCode = $("#companyTaxCode")
        const companyEmail = $("#companyMail")
        const companyAddress = $("#companyAddress")
        const companyName = $("#companyName")
        const companyField = $("#companyField")
        function toggleIssueAnInvoice(toggle){
            if (toggle){
                lblCompanyName.addClass("required-label")
                lblCompanyAddress.addClass("required-label")
                lblCompanyTaxCode.addClass("required-label")
                lblCompanyEmail.addClass("required-label")
                companyAddress.attr("required",true);
                companyName.attr("required",true);
                companyEmail.attr("required",true);
                companyTaxCode.attr("required",true);
                companyField.show();
            }else{
                lblCompanyName.removeClass("required-label")
                lblCompanyAddress.removeClass("required-label")
                lblCompanyTaxCode.removeClass("required-label")
                lblCompanyEmail.removeClass("required-label")
                companyAddress.removeAttr("required");
                companyName.removeAttr("required");
                companyEmail.removeAttr("required");
                companyTaxCode.removeAttr("required");   
                companyField.hide();
            }
        }
       
        
        function debounce(func, timeout = 500){
          let timer;
          return (...args) => {
            clearTimeout(timer);
            timer = setTimeout(() => { func.apply(this, args); }, timeout);
          };
        }
        
        function searchMember(){
            const searchValue = memberList.val()
            if(!searchValue){
                searchPlaceholder.show()
                searchResult.hide();
                loading.hide();
                selectMemberDropdownItemContainer.find('.member-item').remove()
                return;
            }
            
            $.ajax({
                type: "GET",
                url: `/Member/SearchMember?searchValue=${searchValue}`,
                success: function (customers) {
                    selectMemberDropdownItemContainer.find('.member-item').remove()
                    if(!customers || customers.length === 0){
                        searchResult.show();
                    }
                    $.each(customers, function (i, member) {
                        const memberElement = $(`<p class="member-item text-wrap text-sm rounded-lg px-2 text-gray-900 p-1 font-semibold hover:bg-wnz-yellow hover:text-white transition ease-in-out cursor-pointer">${member.firstName + ' ' + member.lastName + ' - '+ member.phoneNumber}</p>`)
                        memberElement.on('click', function (){
                            selectedMemberId = member.id;
                            clearFormError('member')
                            memberList.val(member.firstName + ' ' + member.lastName + ' - '+ member.phoneNumber)
                        })
                        selectMemberDropdownItemContainer.append(memberElement)
                    });
                },error: function (){
                    searchResult.show();
                }
            }).done(function (){
                setTimeout(() => {
                    loading.hide();
                }, 300)
            })
        }
        
        $(document).ready(function (){
            $('#selectMemberDropdown').append('')
        })
        
        $(document).ready(function (){
            $('#productSelect').SumoSelect({
                placeholder: 'Lựa chọn món ăn',
            });
        })
    </script>
}