@model Application.Roles.GetAllPaged.GetAllRolePagedResponse

@{
    ViewBag.Title = "Permission group";
    Layout = "_Layout";
}

<div class="w-full flex flex-col font-geist">
    <!-- Header Section -->
    <div class="mb-6">
        <h2 class="text-[32px] font-bold text-black uppercase tracking-tight">Permission Groups</h2>
        <p class="text-[14px] text-[#4c4546]">Manage user roles, permission mappings, and access control policies for the HRM system.</p>
    </div>

    <!-- Desktop Search & Action Bar -->
    <div class="hidden lg:flex flex-row items-center justify-between gap-4 mb-4">
        <div></div> <!-- Spacer -->
        <div>
            <a href="@Url.Action("CreateRoleview", "Role")" class="h-10 px-8 bg-black text-white text-[11px] font-bold uppercase tracking-widest hover:opacity-90 transition-all flex items-center justify-center cursor-pointer rounded-none">
                + Add Group
            </a>
        </div>
    </div>

    <!-- Mobile Search & Action Bar -->
    <div class="lg:hidden mb-4">
        <div class="flex items-stretch justify-end">
            <a href="@Url.Action("CreateRoleview", "Role")" class="bg-black text-white px-4 h-10 text-[11px] font-bold uppercase flex items-center gap-1 active:invert transition-all cursor-pointer rounded-none">
                <span class="material-symbols-outlined" style="font-size: 14px;">add</span>ADD
            </a>
        </div>
    </div>

    <!-- Desktop Data Grid -->
    <div class="hidden lg:flex flex-col border border-[#D1D1D1] bg-white rounded-none">
        <div class="overflow-x-auto w-full">
            <table class="w-full text-left border-collapse min-w-[800px]">
                <thead class="bg-[#F5F5F5]">
                    <tr class="border-b border-[#D1D1D1]">
                        <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-16 text-center">No</th>
                        <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-48">ID</th>
                        <th class="px-4 py-3 font-bold text-[11px] text-black uppercase border-r border-[#D1D1D1]">Group Name</th>
                        <th class="px-4 py-3 font-bold text-[10px] text-[#4c4546] uppercase border-r border-[#D1D1D1]">Permissions</th>
                        <th class="px-4 py-3 font-bold text-[10px] text-[#4c4546] uppercase w-40">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#D1D1D1]">
                    @foreach (var user in Model.Data.Select((val, index) => new { val, index = index + 1 }))
                    {
                        <tr class="hover:bg-[#F8F8F8] transition-colors border-b border-[#D1D1D1]">
                            <td class="px-4 py-3 font-mono text-[10px] text-[#4c4546] border-r border-[#D1D1D1] text-center font-bold">@user.index</td>
                            <td class="px-4 py-3 font-mono text-[10px] text-[#4c4546] border-r border-[#D1D1D1] font-bold">@user.val.Id</td>
                            <td class="px-4 py-3 text-[11px] text-black border-r border-[#D1D1D1] font-bold">@user.val.DisplayName</td>
                            <td class="px-4 py-3 text-[11px] text-[#4c4546] border-r border-[#D1D1D1]" style="max-width: 350px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @user.val.PermissionsResponse
                            </td>
                            <td class="px-4 py-3 text-[11px] text-black">
                                <div class="flex items-center gap-4">
                                    <a href="@Url.Action("Detail", "Role", new { id = user.val.Id })" class="text-black font-bold uppercase tracking-wider hover:underline">Edit</a>
                                    <button type="button" data-modal-target="confirmDelete-@user.val.Id" data-modal-toggle="confirmDelete-@user.val.Id" class="text-[#E62429] font-bold uppercase tracking-wider hover:underline bg-transparent border-none p-0 cursor-pointer">
                                        Remove
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Mobile Stacked List -->
    <div class="lg:hidden flex flex-col gap-4">
        @foreach (var user in Model.Data.Select((val, index) => new { val, index = index + 1 }))
        {
            <div class="border border-[#D1D1D1] bg-white p-4 flex flex-col gap-3 rounded-none shadow-none font-geist">
                <div class="flex justify-between items-start border-b border-[#F1F1F1] pb-2">
                    <div class="flex flex-col">
                        <span class="font-mono text-[9px] text-[#7e7576] uppercase font-bold">NO. @user.index</span>
                        <h3 class="font-bold text-[13px] text-black uppercase tracking-tight">@user.val.DisplayName</h3>
                    </div>
                    <span class="font-mono text-[9px] bg-[#F5F5F5] border border-[#D1D1D1] px-2 py-0.5 text-[#4c4546] font-bold">ID: @user.val.Id</span>
                </div>

                <div class="flex flex-col gap-1">
                    <span class="font-mono text-[9px] text-[#7e7576] uppercase font-bold">Permissions</span>
                    <p class="text-[11px] text-[#4c4546] break-words line-clamp-3 leading-relaxed">
                        @user.val.PermissionsResponse
                    </p>
                </div>

                <div class="flex items-center justify-between border-t border-[#F1F1F1] pt-2 mt-1">
                    <div class="flex gap-4">
                        <a href="@Url.Action("Detail", "Role", new { id = user.val.Id })" class="text-[11px] font-bold text-black uppercase tracking-wider hover:underline">Edit</a>
                        <button type="button" data-modal-target="confirmDelete-@user.val.Id" data-modal-toggle="confirmDelete-@user.val.Id" class="text-[11px] font-bold text-[#E62429] uppercase tracking-wider hover:underline bg-transparent border-none p-0 cursor-pointer">
                            Remove
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination Footer -->
    <div class="mt-4 flex justify-center py-3 border border-[#D1D1D1] bg-[#F5F5F5] rounded-none shadow-none">
        @Html.Partial("_Pagination", new PaginationViewModel() { CurrentPage = Model.CurrentPage, TotalPage = Model.TotalPages, PageSize = Model.PageSize, HasNext = Model.HasNext, HasPrevious = Model.HasPrevious, TotalItem = Model.TotalCount })
    </div>

    <!-- Modal Containers (Rendered once per Role to avoid duplicate IDs) -->
    @foreach (var role in Model.Data)
    {
        @Html.Partial("_ConfirmDeletePartial", new ConfirmDeleteViewModel()
        {
            Id = role.Id,
            Type = "Decentralization",
            Name = role.DisplayName,
            ActionName = "Delete",
            ActionController = "Role"
        })
    }
</div>

<style>
    /* Swiss Style CSS Overrides for dynamically generated confirm modal */
    div[id^="confirmDelete-"] {
        z-index: 100 !important;
        border-radius: 0px !important;
    }
    div[id^="confirmDelete-"] .relative.w-full {
        border-radius: 0px !important;
        box-shadow: none !important;
    }
    div[id^="confirmDelete-"] button {
        border-radius: 0px !important;
    }
    .hrm-modal-backdrop {
        background-color: rgba(0, 0, 0, 0.6) !important;
    }
</style>
