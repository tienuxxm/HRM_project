@model ManageRoleViewModel

@{
    ViewBag.Title = "Add Group Permission";
    Layout = "_Layout";
}

<div class="w-full flex flex-col font-geist gap-6">
    <!-- Header Section with Back to List Button -->
    <div class="flex flex-row items-center justify-between border-b border-[#D1D1D1] pb-4">
        <div>
            <h2 class="text-[32px] font-bold text-black uppercase tracking-tight">Create Group Permission</h2>
            <p class="text-[14px] text-[#4c4546]">Configure group details and assign capabilities for the new permission group.</p>
        </div>
        <a href="/role" class="text-[11px] font-bold uppercase tracking-wider text-[#4c4546] hover:text-black transition-colors flex items-center gap-1 select-none whitespace-nowrap min-w-[120px] justify-end">
            [← BACK TO LIST]
        </a>
    </div>

    <!-- Form Container -->
    <div class="w-full bg-white border border-[#D1D1D1] p-6 lg:p-8 rounded-none flex flex-col gap-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
            <!-- Group Name -->
            <div class="flex flex-col">
                <label for="DisplayName" class="block mb-2 font-mono text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">
                    Group Name <span class="text-red-500">*</span>
                </label>
                <input name="DisplayName" asp-for="ManageRoleModel.DisplayName" type="text" id="DisplayName"
                       class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] rounded-none focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5] text-black"
                       placeholder="ENTER GROUP NAME" required>
            </div>
        </div>

        <!-- Permission List Section -->
        <div class="flex flex-col gap-2">
            <label class="block font-mono text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">
                List Permission <span class="text-red-500">*</span>
            </label>

            <div class="bg-white border border-[#D1D1D1] rounded-none overflow-hidden">
                <div class="overflow-x-auto w-full max-h-[400px] overflow-y-auto">
                    <table class="min-w-full border-collapse text-left font-mono text-[11px]">
                        <thead class="sticky top-0 z-10 bg-[#F8F8F8] border-b border-[#D1D1D1]">
                            <tr>
                                <th class="w-16 text-center py-3 px-4 font-bold text-black border-r border-[#D1D1D1]">
                                    NO
                                </th>
                                <th class="py-3 px-4 font-bold text-black border-r border-[#D1D1D1]">
                                    PERMISSION
                                </th>
                                <th class="w-36 text-center py-3 px-4 font-bold text-black">
                                    <div class="flex items-center justify-center gap-2 select-none">
                                        SELECT ALL
                                        <input id="all" type="checkbox" name="all" class="w-3.5 h-3.5 border-[#D1D1D1] rounded-none text-black focus:ring-0 focus:ring-offset-0 cursor-pointer" />
                                    </div>
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#EAEAEA]">
                            @foreach (var item in Model.Permissions.Select((val, index) => new { val, index = index + 1 }))
                            {
                                <tr class="hover:bg-[#F9F9F9] transition-colors">
                                    <td class="text-center py-2.5 px-4 text-black font-bold border-r border-[#D1D1D1]">
                                        @item.index.ToString("D2")
                                    </td>
                                    <td class="py-2.5 px-4 text-[#4c4546] font-bold border-r border-[#D1D1D1]">
                                        @item.val.DisplayName
                                    </td>
                                    <td class="text-center py-2.5 px-4">
                                        <input data-id="@item.val.Id" type="checkbox" class="permissionId w-3.5 h-3.5 border-[#D1D1D1] rounded-none text-black focus:ring-0 focus:ring-offset-0 cursor-pointer" name="all" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="flex items-center justify-end gap-3 border-t border-[#D1D1D1] pt-6">
            <a href="/role" class="h-10 px-6 border border-[#D1D1D1] text-black text-[11px] font-bold uppercase tracking-widest hover:bg-neutral-50 transition-all flex items-center justify-center cursor-pointer rounded-none whitespace-nowrap select-none">
                Cancel
            </a>
            <button id="submit" type="submit" class="h-10 px-8 bg-black text-white text-[11px] font-bold uppercase tracking-widest hover:opacity-90 transition-all flex items-center justify-center cursor-pointer rounded-none border border-black select-none">
                Save
            </button>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    let permissionSelected = [];
    const modelData = @Html.Raw(Json.Serialize(Model));
    const permissions = modelData.permissions;
    const permissionIds = permissions.map(item => item.id);

    $('#all').on('change', function (event){
        const value = event.currentTarget.checked;
        if (value){
            permissionSelected = permissionIds;
            $('.permissionId').each(function (index, item){
                item.checked = true;
            });
        } else {
            $('.permissionId').each(function (index, item){
                 item.checked = false;
            });
            permissionSelected = [];
        }
    });

    $('.permissionId').on('change', function (event){
        const value = event.currentTarget.checked;
        const id = event.currentTarget.dataset.id;
        if (value){
            if (!permissionSelected.includes(id)){
                permissionSelected.push(id);
            }
            if (permissionSelected.length === permissions.length){
                $('#all').prop('checked', true);
            }
        } else {
            $('#all').prop('checked', false);
            permissionSelected = permissionSelected.filter(item => item !== id);
        }
    });

    $('#submit').on('click', function (event){
        event.preventDefault();
        const displayName = $('#DisplayName').val();

        if (!displayName || displayName.trim() === '') {
            showToast("Please enter a group name.", false);
            return;
        }

        $.ajax({
            type: "POST",
            url: `/Role/create`,
            data: { displayName, permissionIds: permissionSelected },
            success: function (res){
                showToast("Permission created successfully", true);
                setTimeout(function () {
                    location.href = '/Role';
                }, 1000);
            },
            error: function (err) {
                showToast("An error occurred while saving", false);
            }
        });
    });
</script>
