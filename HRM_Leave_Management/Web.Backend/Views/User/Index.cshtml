@model Application.Users.GetAllPaged.GetAllUserPagedResponse

@{
    ViewBag.Title = "User List";
    Layout = "_Layout";
}

<div class="w-full flex flex-col font-geist">
    <!-- Header Section -->
    <div class="mb-6">
        <h2 class="text-[32px] font-bold text-black uppercase tracking-tight">The Users</h2>
        <p class="text-[14px] text-[#4c4546]">Manage application user accounts, authentication profiles, and system-level security roles.</p>
    </div>

    <!-- Search & Action Bar -->
    <!-- Desktop Search & Action Bar -->
    <div class="hidden lg:flex flex-row items-center justify-between gap-4 mb-4">
        <div class="w-[400px] relative">
            <input id="search" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5]" placeholder="SEARCH USERS..." type="text"/>
            <span class="material-symbols-outlined absolute right-3 top-2.5 text-[20px] text-[#cfc4c5]">search</span>
        </div>
        <div>
            <a href="@Url.Action("CreateUserView", "User")" class="h-10 px-8 bg-black text-white text-[11px] font-bold uppercase tracking-widest hover:opacity-90 transition-all flex items-center justify-center cursor-pointer rounded-none">
                + Add User
            </a>
        </div>
    </div>

    <!-- Mobile Search & Action Bar -->
    <div class="lg:hidden mb-4">
        <div class="flex items-stretch gap-0 border border-[#D1D1D1]">
            <div class="flex-grow flex items-center bg-white px-3 border-r border-[#D1D1D1] h-10">
                <span class="material-symbols-outlined text-[#4c4546] mr-2" style="font-size: 16px;">search</span>
                <input id="mobileSearch" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" class="w-full bg-transparent border-none focus:ring-0 text-[11px] placeholder:text-[#4c4546] p-0 font-medium" placeholder="SEARCH USERS" type="text"/>
            </div>
            <a href="@Url.Action("CreateUserView", "User")" class="bg-black text-white px-4 h-10 text-[11px] font-bold uppercase flex items-center gap-1 active:invert transition-all cursor-pointer rounded-none">
                <span class="material-symbols-outlined" style="font-size: 14px;">add</span>ADD
            </a>
        </div>
    </div>

    <!-- Desktop Data Grid -->
    <div class="hidden lg:flex flex-col border border-[#D1D1D1] bg-white rounded-none">
        <div class="overflow-x-auto w-full">
            <table id="table" class="w-full text-left border-collapse min-w-[1000px]">
                <thead class="bg-[#F5F5F5]">
                    <tr class="border-b border-[#D1D1D1]">
                        <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-16 text-center">No</th>
                        <th class="px-4 py-3 font-bold text-[11px] text-black uppercase border-r border-[#D1D1D1]">Full Name</th>
                        <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-48">Username</th>
                        <th class="px-4 py-3 font-bold text-[11px] text-black uppercase border-r border-[#D1D1D1]">Email</th>
                        <th class="px-4 py-3 font-bold text-[10px] text-[#4c4546] uppercase border-r border-[#D1D1D1]">Permission</th>
                        <th class="px-4 py-3 font-bold text-[10px] text-[#4c4546] uppercase w-40">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#D1D1D1]">
                    <!-- Rendered dynamically by DataTables AJAX -->
                </tbody>
            </table>
        </div>

        <!-- Desktop Table Pagination Footer -->
        <div class="flex items-center justify-between px-4 py-3 border-t border-[#D1D1D1] bg-[#F5F5F5] font-mono text-[10px] font-bold text-[#4c4546] uppercase">
            <div id="desktopShowingText">
                SHOWING 0-0 OF 0 USERS
            </div>
            <div class="flex items-center space-x-6">
                <button type="button" id="prevPage" class="bg-transparent border-0 p-0 font-bold hover:text-black transition-colors uppercase font-mono cursor-pointer">PREV</button>
                <span class="text-black font-mono" id="currentPage">PAGE 1 OF 1</span>
                <button type="button" id="nextPage" class="bg-transparent border-0 p-0 font-bold hover:text-black transition-colors uppercase font-mono cursor-pointer">NEXT</button>
            </div>
        </div>
    </div>

    <!-- Mobile Stacked List -->
    <div class="lg:hidden flex flex-col gap-4">
        <div class="flex flex-col gap-4" id="mobileCardsContainer">
            <!-- Rendered dynamically by JS -->
        </div>

        <!-- Mobile Pagination Footer -->
        <div class="mt-6 border border-[#D1D1D1] bg-white p-4 flex flex-col gap-3 font-mono text-[11px]">
            <div class="text-center font-bold text-black uppercase" id="mobileShowingText">
                SHOWING 0-0 OF 0 USERS
            </div>
            <div class="grid grid-cols-3 border-t border-[#D1D1D1] pt-3 text-center font-bold">
                <button type="button" id="mobilePrevBtn" class="py-2 hover:bg-black hover:text-white transition-colors bg-transparent border-0 cursor-pointer font-mono">PREV</button>
                <span class="py-2 text-black" id="mobilePageText">PAGE 1 OF 1</span>
                <button type="button" id="mobileNextBtn" class="py-2 hover:bg-black hover:text-white transition-colors bg-transparent border-0 cursor-pointer font-mono">NEXT</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Swiss Style CSS Overrides for dynamically generated confirm modal */
    [modal-backdrop] {
        background-color: rgba(0, 0, 0, 0.6) !important;
        z-index: 90 !important;
    }
    div[id^="confirmDelete-"] {
        z-index: 100 !important;
        border-radius: 0px !important;
    }
    div[id^="confirmDelete-"] .relative.w-full {
        border-radius: 0px !important;
        box-shadow: none !important;
    }
    div[id^="confirmDelete-"] button {
        border-radius: 0px !important;
    }

    /* Fixed border vertical and horizontal for DataTables dynamic rows */
    #table {
        border-collapse: collapse !important;
    }
    #table tbody tr {
        border-bottom: 1px solid #D1D1D1 !important;
        transition: background-color 150ms ease-in-out;
    }
    #table tbody tr:hover {
        background-color: #F8F8F8 !important;
    }
</style>

@section Scripts
{
    <script>
        function getUserDeleteModal(id, type, name, actionLink, callBack) {
            return `
                <div id="confirmDelete-${id}" tabindex="-1" class="fixed top-0 left-0 right-0 z-50 hidden p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full flex items-center justify-center">
                    <div class="relative w-full max-w-md max-h-full">
                        <div class="relative bg-white border border-[#D1D1D1] rounded-none shadow-none">
                            <div class="bg-[#E62429] text-white px-4 py-3 font-mono text-[11px] font-bold uppercase tracking-wider flex justify-between items-center border-b border-[#D1D1D1]">
                                <span>Warning: Remove User</span>
                                <button onclick="toggleDeleteModal('${id}', false)" type="button" class="text-white hover:opacity-80 bg-transparent flex items-center">
                                    <span class="material-symbols-outlined text-[16px]">close</span>
                                </button>
                            </div>
                            <div class="p-6 flex flex-col gap-4">
                                <div class="flex items-start gap-3">
                                    <span class="material-symbols-outlined text-[#E62429] text-[32px] shrink-0">warning</span>
                                    <div class="flex flex-col gap-1">
                                        <p class="text-[12px] text-black font-bold uppercase tracking-tight font-mono">Confirm Removal</p>
                                        <p class="text-[11px] text-[#4c4546] font-normal leading-relaxed font-geist text-wrap">
                                            Are you sure you want to remove user <strong class="font-mono text-black font-bold select-all">${name}</strong>? This action cannot be undone.
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-center justify-end gap-3 mt-2 border-t border-[#F1F1F1] pt-4">
                                    <button onclick="toggleDeleteModal('${id}', false)" type="button" class="h-9 px-4 border border-black bg-white text-black hover:bg-black hover:text-white text-[11px] font-bold uppercase tracking-wider transition-colors rounded-none cursor-pointer font-mono">
                                        Cancel
                                    </button>
                                    <button onclick="deleteAction('${actionLink}', '${id}', ${callBack})" type="button" class="h-9 px-4 bg-[#E62429] hover:bg-[#b81d21] text-white text-[11px] font-bold uppercase tracking-wider transition-colors rounded-none cursor-pointer font-mono">
                                        Remove
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        $(document).ready(function () {
            const table = $('#table').DataTable({
                lengthChange: false,
                paging: false,
                pageResize: true,
                processing: true,
                serverSide: true,
                info: false,
                dom: '<"top"l>rt<"bottom"ip><"clear">',
                pageLength: 10,
                ajax: {
                    url: "@Url.Action("LoadData", "User")",
                    type: "POST",
                    dataFilter: function(data){
                        const dataJson = JSON.parse(data);
                        return JSON.stringify({
                            draw: dataJson.draw,
                            data: dataJson.data,
                            recordsFiltered: dataJson.recordsFiltered,
                            recordsTotal: dataJson.recordsTotal
                        });
                    },
                    dataSrc: function (json) {
                        const data = json.data.map((item, index) => ({
                            ...item,
                            index: index + 1
                        }));
                        return data;
                    }
                },
                columnDefs: [
                    {
                        "className": "px-4 py-3 font-mono text-[11px] font-bold border-r border-[#D1D1D1] text-center text-[#4c4546]",
                        "targets": [0]
                    },
                    {
                        "className": "px-4 py-3 font-bold text-[12px] text-black border-r border-[#D1D1D1]",
                        "targets": [1]
                    },
                    {
                        "className": "px-4 py-3 font-mono text-[11px] font-bold text-[#4c4546] border-r border-[#D1D1D1]",
                        "targets": [2]
                    },
                    {
                        "className": "px-4 py-3 text-[11px] text-black border-r border-[#D1D1D1] select-all",
                        "targets": [3]
                    },
                    {
                        "className": "px-4 py-3 border-r border-[#D1D1D1]",
                        "targets": [4],
                        "render": function(data, type, row, meta) {
                            if (!data) return '<span class="text-gray-400 font-mono text-[9px]">NO ROLES</span>';
                            const roles = Array.isArray(data) ? data : [data];
                            return roles.map(r => `<span class="bg-[#F5F5F5] border border-[#D1D1D1] text-black px-2 py-0.5 text-[9px] font-mono font-bold uppercase rounded-none">${r}</span>`).join(' ');
                        }
                    },
                    {
                        "className": "px-4 py-3 whitespace-nowrap",
                        "targets": [5],
                        "render": function(data, type, row, meta) {
                            return `
                                <div class="flex space-x-3">
                                    <a class="text-[9px] font-bold text-black hover:text-neutral-600 uppercase underline decoration-[#cfc4c5] underline-offset-4 cursor-pointer" href="/user/${row.id}">Edit</a>
                                    <a onclick="toggleDeleteModal('${row.id}')" data-modal-target="confirmDelete-${row.id}" data-modal-toggle="confirmDelete-${row.id}" class="text-[9px] font-bold text-[#E62429] hover:opacity-70 uppercase underline decoration-[#cfc4c5] underline-offset-4 cursor-pointer" href="javascript:void(0)">Remove</a>
                                </div>
                                ${getUserDeleteModal(row.id, 'User', row.username, `/User/Delete`, function (result){
                                    if (result){
                                        showToast('Deleted Success');
                                        location.reload();
                                    }else{
                                        showToast('An error occurred', false);
                                    }
                                })}
                            `;
                        }
                    },
                    { "orderable": false, "targets": [0, 4, 5] },
                    { "defaultContent": "-", "targets": [1, 2, 3] }
                ],
                columns: [
                    { "data": "index" },
                    { "data": "fullname" },
                    { "data": "username" },
                    { "data": "email" },
                    { "data": "rolesResponse" },
                    { "data": null }
                ]
            });

            // Handle prev/next page click events
            $('#prevPage, #mobilePrevBtn').on('click', function(e) {
                e.preventDefault();
                table.page('previous').draw('page');
            });

            $('#nextPage, #mobileNextBtn').on('click', function(e) {
                e.preventDefault();
                table.page('next').draw('page');
            });

            // Sync Search input values
            $('#search').on('input', function() {
                $('#mobileSearch').val($(this).val());
                table.search(this.value).draw();
            });

            $('#mobileSearch').on('input', function() {
                $('#search').val($(this).val());
                table.search(this.value).draw();
            });

            // Table Draw event callback
            table.on('draw', function () {
                loadPage();
                renderMobileCards();
            });

            function loadPage() {
                const pageInfo = table.page.info();

                // Construct showing label text
                const showingFrom = pageInfo.recordsDisplay === 0 ? 0 : pageInfo.start + 1;
                const showingTo = pageInfo.end;
                const showingLabel = `SHOWING ${showingFrom}-${showingTo} OF ${pageInfo.recordsDisplay} USERS`;

                $('#desktopShowingText').text(showingLabel);
                $('#mobileShowingText').text(showingLabel);

                // Construct page text
                const currentPageVal = Math.ceil(pageInfo.end / 10) || 1;
                const totalPagesVal = Math.ceil(pageInfo.recordsDisplay / 10) || 1;
                const pageLabel = `PAGE ${currentPageVal} OF ${totalPagesVal}`;

                $('#currentPage').text(pageLabel);
                $('#mobilePageText').text(pageLabel);

                // Handle active/disabled states for pagination buttons
                if (currentPageVal <= 1) {
                    $('#prevPage, #mobilePrevBtn')
                        .addClass('opacity-50 pointer-events-none')
                        .removeClass('hover:text-black hover:bg-black hover:text-white');
                } else {
                    $('#prevPage, #mobilePrevBtn')
                        .removeClass('opacity-50 pointer-events-none');
                }

                if (currentPageVal >= totalPagesVal) {
                    $('#nextPage, #mobileNextBtn')
                        .addClass('opacity-50 pointer-events-none')
                        .removeClass('hover:text-black hover:bg-black hover:text-white');
                } else {
                    $('#nextPage, #mobileNextBtn')
                        .removeClass('opacity-50 pointer-events-none');
                }
            }

            function renderMobileCards() {
                const container = $('#mobileCardsContainer');
                container.empty();

                const data = table.rows({ page: 'current' }).data();
                if (data.length === 0) {
                    container.append(`
                        <div class="bg-white border border-[#D1D1D1] p-8 text-center font-mono text-[11px] text-[#4c4546] uppercase">
                            No users found.
                        </div>
                    `);
                    return;
                }

                data.each(function(row) {
                    const fullname = row.fullname || '—';
                    const username = row.username || '—';
                    const email = row.email || '—';

                    let rolesHtml = '';
                    if (row.rolesResponse && row.rolesResponse.length > 0) {
                        const roles = Array.isArray(row.rolesResponse) ? row.rolesResponse : [row.rolesResponse];
                        rolesHtml = roles.map(r => `<span class="bg-[#F5F5F5] border border-[#D1D1D1] text-black px-2 py-0.5 text-[9px] font-mono font-bold uppercase rounded-none">${r}</span>`).join(' ');
                    } else {
                        rolesHtml = `<span class="text-gray-400 font-mono text-[9px]">NO ROLES</span>`;
                    }

                    const cardHtml = `
                        <div class="bg-white border border-[#D1D1D1] p-4 flex flex-col gap-3">
                            <div class="flex justify-between items-start">
                                <div class="flex flex-col">
                                    <span class="font-mono text-[10px] text-[#4c4546] font-bold">${username}</span>
                                    <h3 class="text-[16px] font-bold uppercase tracking-tight text-black">${fullname}</h3>
                                </div>
                            </div>

                            <div class="flex flex-col gap-1 text-[11px] border-t border-[#F1F1F1] pt-3">
                                <div class="flex justify-between">
                                    <span class="text-[#4c4546] font-mono text-[10px] uppercase">Email:</span>
                                    <span class="font-bold text-black select-all">${email}</span>
                                </div>
                                <div class="flex justify-between items-center mt-1">
                                    <span class="text-[#4c4546] font-mono text-[10px] uppercase">Roles:</span>
                                    <div class="flex flex-wrap gap-1">${rolesHtml}</div>
                                </div>
                            </div>

                            <div class="flex gap-4 border-t border-[#F1F1F1] pt-3">
                                <a href="/user/${row.id}" class="text-[10px] font-bold uppercase text-black hover:text-neutral-600 underline underline-offset-4 decoration-[#cfc4c5]">[EDIT]</a>
                                <button type="button" onclick="toggleDeleteModal('${row.id}')" class="ml-auto text-[#E62429] text-[10px] font-bold uppercase hover:opacity-70 underline underline-offset-4 decoration-[#cfc4c5] cursor-pointer bg-transparent border-none p-0">[REMOVE]</button>
                            </div>
                        </div>
                    `;
                    container.append(cardHtml);
                });
            }
        });
    </script>
}
