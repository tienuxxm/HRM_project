@model ManageUserViewModel

@{
    ViewBag.Title = "Add User";
    Layout = "_Layout";
}

<div class="w-full flex flex-col font-geist gap-6">
    <!-- Header Section with Back to List Button -->
    <div class="flex flex-row items-center justify-between border-b border-[#D1D1D1] pb-4">
        <div>
            <h2 class="text-[32px] font-bold text-black uppercase tracking-tight">Create User</h2>
            <p class="text-[14px] text-[#4c4546]">Configure account details and assign permissions for the new user profile.</p>
        </div>
        <a href="/user" class="text-[11px] font-bold uppercase tracking-wider text-[#4c4546] hover:text-black transition-colors flex items-center gap-1 select-none whitespace-nowrap min-w-[120px] justify-end">
            [← BACK TO LIST]
        </a>
    </div>

    <!-- Form Container -->
    <div class="w-full bg-white border border-[#D1D1D1] p-6 lg:p-8 rounded-none">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
            <!-- Full Name -->
            <div class="flex flex-col">
                <label for="fullname" class="block mb-2 font-mono text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">
                    Full name <span class="text-red-500">*</span>
                </label>
                <input onchange="inputChange('fullname')" asp-for="ManageUserModel.Name" type="text" id="fullname"
                       class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] rounded-none focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5] text-black"
                       placeholder="ENTER FULL NAME" required>
                <p id="fullnameError" class="mt-1 font-mono text-[10px] font-bold text-red-600 uppercase"></p>
            </div>

            <!-- Username -->
            <div class="flex flex-col">
                <label for="usernameInput" class="block mb-2 font-mono text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">
                    Username <span class="text-red-500">*</span>
                </label>
                <input onchange="inputChange('username')" asp-for="ManageUserModel.Username" type="text" id="usernameInput"
                       class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] rounded-none focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5] text-black"
                       placeholder="ENTER USERNAME" required>
                <p id="usernameError" class="mt-1 font-mono text-[10px] font-bold text-red-600 uppercase"></p>
            </div>

            <!-- Email -->
            <div class="flex flex-col">
                <label for="email" class="block mb-2 font-mono text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">
                    Email <span class="text-red-500">*</span>
                </label>
                <input onchange="inputChange('email')" required asp-for="ManageUserModel.Email" type="text" id="email"
                       class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] rounded-none focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5] text-black"
                       placeholder="ENTER EMAIL">
                <p id="emailError" class="mt-1 font-mono text-[10px] font-bold text-red-600 uppercase"></p>
            </div>

            <!-- Group Permission -->
            <div class="flex flex-col">
                <label for="RoleIds" class="block mb-2 font-mono text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">
                    Group Permission <span class="text-red-500">*</span>
                </label>
                <select onchange="inputChange('role')" multiple asp-for="ManageUserModel.RoleIds" id="RoleIds">
                    @foreach (var op in Model.Roles)
                    {
                        <option value="@op.Id">@op.DisplayName</option>
                    }
                </select>
                <p id="roleError" class="mt-1 font-mono text-[10px] font-bold text-red-600 uppercase"></p>
            </div>

            <!-- Password -->
            <div class="flex flex-col">
                <label for="password" class="block mb-2 font-mono text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">
                    Password <span class="text-red-500">*</span>
                </label>
                <input onchange="inputChange('password')" asp-for="ManageUserModel.Password" type="password" id="password"
                       class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] rounded-none focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5] text-black"
                       placeholder="ENTER PASSWORD" required>
                <p id="passwordError" class="mt-1 font-mono text-[10px] font-bold text-red-600 uppercase"></p>
            </div>

            <!-- Confirm Password -->
            <div class="flex flex-col">
                <label for="rePassword" class="block mb-2 font-mono text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">
                    Confirm Password <span class="text-red-500">*</span>
                </label>
                <input onchange="inputChange('rePassword')" asp-for="ManageUserModel.Password" type="password" id="rePassword"
                       class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] rounded-none focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5] text-black"
                       placeholder="CONFIRM PASSWORD" required>
                <p id="rePasswordError" class="mt-1 font-mono text-[10px] font-bold text-red-600 uppercase"></p>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="flex items-center justify-end gap-3 mt-6 border-t border-[#D1D1D1] pt-6">
            <a href="/user" class="h-10 px-6 border border-[#D1D1D1] text-black text-[11px] font-bold uppercase tracking-widest hover:bg-neutral-50 transition-all flex items-center justify-center cursor-pointer rounded-none whitespace-nowrap select-none">
                Cancel
            </a>
            <button id="saveButton" type="submit" class="h-10 px-8 bg-black text-white text-[11px] font-bold uppercase tracking-widest hover:opacity-90 transition-all flex items-center justify-center cursor-pointer rounded-none border border-black select-none">
                Save
            </button>
        </div>
    </div>
</div>

<style>
    /* SumoSelect Overrides for Swiss Design Parity */
    .SumoSelect {
        width: 100% !important;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 11px;
    }
    .SumoSelect > .CaptionCont {
        border-radius: 0px !important;
        border: 1px solid #D1D1D1 !important;
        min-height: 40px !important;
        display: flex !important;
        align-items: center !important;
        padding: 0 16px !important;
        background-color: #fff !important;
        box-shadow: none !important;
    }
    .SumoSelect > .CaptionCont > span {
        color: #000 !important;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 11px;
    }
    .SumoSelect > .CaptionCont > span.placeholder {
        color: #cfc4c5 !important;
        font-style: normal !important;
        font-weight: normal;
        text-transform: uppercase;
    }
    .SumoSelect > .CaptionCont > label {
        border-left: none !important;
        background-color: transparent !important;
    }
    .SumoSelect > .CaptionCont > label > i {
        background-image: none !important;
        border-left: 4px solid transparent;
        border-right: 4px solid transparent;
        border-top: 4px solid #000;
        width: 0;
        height: 0;
        display: inline-block;
    }
    .SumoSelect.open > .CaptionCont > label > i {
        border-top: none;
        border-bottom: 4px solid #000;
    }
    .SumoSelect > .optWrapper {
        border-radius: 0px !important;
        border: 1px solid #D1D1D1 !important;
        box-shadow: none !important;
        top: 40px !important;
    }
    .SumoSelect > .optWrapper > .options li.opt {
        border-bottom: 1px solid #F5F5F5 !important;
        padding: 10px 16px !important;
        border-radius: 0px !important;
    }
    .SumoSelect > .optWrapper > .options li.opt label {
        font-weight: bold;
        text-transform: uppercase;
        color: #000;
    }
    .SumoSelect > .optWrapper > .options li.opt.selected {
        background-color: #F5F5F5 !important;
    }
    .SumoSelect > .optWrapper > .options li.opt:hover {
        background-color: #F8F8F8 !important;
    }
    .SumoSelect > .optWrapper.multiple > .options li.opt span i {
        border-radius: 0px !important;
        border: 1px solid #D1D1D1 !important;
    }
    .SumoSelect > .optWrapper.multiple > .options li.opt.selected span i {
        background-color: #000 !important;
        border-color: #000 !important;
    }
</style>

@section Scripts
{
    <script>
        $(document).ready(function (){
            $('#RoleIds').SumoSelect({
                placeholder: 'select permission',
                floatWidth: 0
            });
        })
        const loading = $("#loadingSpinner");
        loading.hide();

        const saveButton = $('#saveButton')
        let isFormValid = false;
        const fullnameError =  $('#fullnameError')
        const usernameError =  $('#usernameError')
        const emailError =  $('#emailError')
        const roleError  =  $('#roleError')
        const passwordError =  $('#passwordError')
        const rePasswordError =  $('#rePasswordError')

        function resetFormError(){
            fullnameError.hide();
            usernameError.hide();
            emailError.hide();
            roleError.hide();
            passwordError.hide();
            rePasswordError.hide();
        }

        function inputChange(inputName){
            switch (inputName){
                case 'fullname':
                    fullnameError.hide();
                    break;
                case 'username':
                    usernameError.hide();
                    break;
                case 'email':
                    emailError.hide();
                    break;
                case 'role':
                    roleError.hide();
                    break;
                case 'password':
                    passwordError.hide();
                    break;
                case 'rePassword':
                    rePasswordError.hide();
                    break;
            }
        }

        resetFormError()

        function formValidate(){

            resetFormError();

            const fullname = $('#fullname').val();
            const username = $('#usernameInput').val()
            const email = $('#email').val()
            const password = $('#password').val()
            const rePassword = $('#rePassword').val()
            const role = $('#RoleIds').val()

            const errors = [];

            if (fullname === '' || !fullname){
                const error = 'Please Enter Full Name'
                fullnameError.show();
                fullnameError.text(error);
                errors.push(error);
            }

            if (username === '' || !username){
                const error = 'Please Enter Username'
                usernameError.show();
                usernameError.text(error);
                errors.push(error);
            }


            if (email === null || !email){
                const error = 'Please Enter email'
                emailError.show();
                emailError.text(error);
                errors.push(error);
            }

            if (password === null || !password){
                const error = 'Please Enter Password'
                passwordError.show();
                passwordError.text(error);
                errors.push(error);
            }

            if (rePassword === null || !rePassword){
                const error = 'Please Enter Re-Password'
                rePasswordError.show();
                rePasswordError.text(error);
                errors.push(error);
            }

            if (password && rePassword){
                if (password !== rePassword){
                    const error = 'Password does not match'
                    rePasswordError.show();
                    rePasswordError.text(error);
                    errors.push(error);
                }
            }
            if(role.length <= 0){
                const error = 'Please select role'
                roleError.show();
                roleError.text(error);
                errors.push(error);
            }

            isFormValid = errors.length === 0;
        }

        const submitButton = $('#submitButton')

        saveButton.on('click', (event) => {
            event.preventDefault();
            formValidate();
            if(!isFormValid){
                return;
            }

            const loadingOverlay = $('#loadingOverlay');
            loadingOverlay.show();

            const fullname = $("#fullname").val();
            const username = $("#usernameInput").val();
            const email = $("#email").val();
            const roleIds = $("#RoleIds").val();
            const password = $("#password").val();

            let request = {
                 name: fullname,
                 username,
                 email,
                 password,
                 roleIds
            }

            const toastContainer = $('#toast-container')

            $.ajax({
                type: "POST",
                url:  '/User/Create',
                data: {
                    ...request
                },
                dataType: 'multipart/form-data',
                success: function () {
                    loadingOverlay.hide();
                    toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Save Success" }, null)')
                    setTimeout(() => {
                        loadingOverlay.show();
                    }, 1500)
                    location.href = "/user"
                },error: function (error){
                    if (error.status === 200){
                        loadingOverlay.hide();
                        showToast('Add Success')
                        setTimeout(() => {
                            loadingOverlay.show();
                        }, 1500)
                        location.href = "/user"
                    }else{
                        const responseError = JSON.parse(error.responseText)
                        loadingOverlay.hide();
                        showToast(responseError.name, false)
                    }
                }
            })
        })

        function debounce(func, timeout = 500){
          let timer;
          return (...args) => {
            clearTimeout(timer);
            timer = setTimeout(() => { func.apply(this, args); }, timeout);
          };
        }

    </script>
}
