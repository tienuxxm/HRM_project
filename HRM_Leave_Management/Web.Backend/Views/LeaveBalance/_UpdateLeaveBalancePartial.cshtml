@model Application.LeaveBalances.LeaveBalanceResponse

<div id="updateLeaveBalanceModal-@Model.Id" tabindex="-1" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal Panel -->
        <div class="w-full max-w-[480px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">UPDATE LEAVE BALANCE</span>
                <button type="button" class="bg-[#E62429] w-8 h-8 flex items-center justify-center hover:bg-[#c51f24] transition-colors" data-modal-hide="updateLeaveBalanceModal-@Model.Id">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Body -->
            <div class="p-6 flex flex-col gap-4 text-left font-geist">
                <!-- Read-only Employee -->
                <div>
                    <label class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Employee</label>
                    <input type="text" value="@Model.EmployeeName (@Model.EmployeeCode)" class="w-full bg-[#F5F5F5] border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] text-[#4c4546] cursor-not-allowed" readonly>
                </div>

                <!-- Read-only Leave Type -->
                <div>
                    <label class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Leave Type</label>
                    <input type="text" value="@Model.LeaveTypeName (@Model.LeaveTypeCode)" class="w-full bg-[#F5F5F5] border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] text-[#4c4546] cursor-not-allowed" readonly>
                </div>

                <!-- Read-only Year -->
                <div>
                    <label class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Year</label>
                    <input type="text" value="@Model.Year" class="w-full bg-[#F5F5F5] border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] text-[#4c4546] cursor-not-allowed" readonly>
                </div>

                <!-- Editable Allocated Days -->
                <div>
                    <label for="upAllocated-@Model.Id" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Allocated Days</label>
                    <input type="number" id="upAllocated-@Model.Id" value="@Model.AllocatedDays.ToString("G29")" step="0.5" min="0" max="365" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                    <p id="upAllocatedError-@Model.Id" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>

                <!-- Editable Used Days -->
                <div>
                    <label for="upUsed-@Model.Id" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Used Days</label>
                    <input type="number" id="upUsed-@Model.Id" value="@Model.UsedDays.ToString("G29")" step="0.5" min="0" max="365" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                    <p id="upUsedError-@Model.Id" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>

                <!-- Read-only Remaining Days -->
                <div>
                    <label class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Remaining Days (Calculated)</label>
                    <input type="text" value="@Model.RemainingDays.ToString("G29")" class="w-full bg-[#F5F5F5] border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] text-[#4c4546] cursor-not-allowed" readonly>
                </div>

                <!-- Info Box -->
                <div class="bg-[#F5F5F5] border border-[#D1D1D1] px-3 py-2 font-mono text-[10px] text-[#4c4546]">
                    Remaining days are calculated automatically from allocated minus used days.
                </div>
            </div>
            <!-- Footer -->
            <div class="h-16 flex items-center justify-between px-6 bg-[#FBFBFB] border-t border-[#D1D1D1]">
                <span class="font-mono text-[9px] text-[#4c4546] uppercase tracking-wider">SYSTEM: LIVE</span>
                <div class="flex items-center gap-3">
                    <button data-modal-hide="updateLeaveBalanceModal-@Model.Id" type="button" class="bg-white border border-[#D1D1D1] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#F4F3F3] transition-colors rounded-none cursor-pointer">
                        CANCEL
                    </button>
                    <button type="button" onclick="updateLeaveBalance('@Model.Id')" class="bg-[#E62429] text-white border border-[#E62429] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#c51f24] transition-all rounded-none cursor-pointer">
                        UPDATE
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function updateLeaveBalance(id) {
        const allocatedError = $('#upAllocatedError-' + id);
        const usedError = $('#upUsedError-' + id);
        
        allocatedError.addClass('hidden').text('');
        usedError.addClass('hidden').text('');
        
        const allocatedStr = $('#upAllocated-' + id).val();
        const usedStr = $('#upUsed-' + id).val();
        
        let hasError = false;
        
        const allocated = parseFloat(allocatedStr);
        if (isNaN(allocated) || allocated < 0 || allocated > 365) {
            allocatedError.removeClass('hidden').text('Allocated days must be between 0 and 365.');
            hasError = true;
        }
        
        const used = parseFloat(usedStr);
        if (isNaN(used) || used < 0 || used > 365) {
            usedError.removeClass('hidden').text('Used days must be between 0 and 365.');
            hasError = true;
        }
        
        if (hasError) return;
        
        const fd = new FormData();
        fd.append('Id', id);
        fd.append('AllocatedDays', allocated);
        fd.append('UsedDays', used);
        
        $.ajax({
            type: 'POST',
            url: '/leave-balance/update',
            data: fd,
            processData: false,
            contentType: false,
            success: function() {
                $('#toast-container').load('@Url.Action("SuccessToastPartial", "Main", new { message = "Leave balance updated successfully" })');
                setTimeout(function() {
                    location.href = '/leave-balance';
                }, 1500);
            },
            error: function(xhr) {
                let errMsg = "Update failed.";
                if (xhr.responseText) {
                    try {
                        const errObj = JSON.parse(xhr.responseText);
                        if (errObj && errObj.description) {
                            errMsg = errObj.description;
                        }
                    } catch (e) {}
                }
                $('#toast-container').load('@Url.Action("FailToastPartial", "Main", new { message = "FAIL_PLACEHOLDER" })'.replace("FAIL_PLACEHOLDER", errMsg));
            }
        });
    }
</script>
