@{
    var employees = ViewBag.Employees as List<Domain.Employees.Employee> ?? new();
    var leaveTypes = ViewBag.LeaveTypes as List<Domain.LeaveTypes.LeaveType> ?? new();
    int currentYear = DateTime.Now.Year;
}

<div id="createLeaveBalanceModal" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative w-full max-w-md max-h-full">
        <div class="relative bg-white rounded-lg shadow dark:bg-gray-700">
            <button type="button" class="absolute top-3 right-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ml-auto inline-flex justify-center items-center" data-modal-hide="createLeaveBalanceModal">
                <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
            </button>
            <div class="px-6 py-6 lg:px-8">
                <h3 class="mb-4 text-xl font-medium text-gray-900">Allocate Leave Balance</h3>
                <div class="space-y-4">
                    <!-- Employee Dropdown -->
                    <div>
                        <label for="createEmpId" class="block mb-2 text-sm font-medium text-gray-900">Employee</label>
                        <select id="createEmpId" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5" required>
                            <option value="">-- Select Employee --</option>
                            @foreach (var emp in employees)
                            {
                                <option value="@emp.Id.Value">@emp.FullName (@emp.EmployeeCode)</option>
                            }
                        </select>
                        <p id="createEmpIdError" class="mt-1 text-xs text-red-600 hidden"></p>
                    </div>

                    <!-- Leave Type Dropdown -->
                    <div>
                        <label for="createLeaveTypeId" class="block mb-2 text-sm font-medium text-gray-900">Leave Type</label>
                        <select id="createLeaveTypeId" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5" required>
                            <option value="">-- Select Leave Type --</option>
                            @foreach (var lt in leaveTypes)
                            {
                                <option value="@lt.Id.Value">@lt.Name (@lt.Code)</option>
                            }
                        </select>
                        <p id="createLeaveTypeIdError" class="mt-1 text-xs text-red-600 hidden"></p>
                    </div>

                    <!-- Year -->
                    <div>
                        <label for="createYear" class="block mb-2 text-sm font-medium text-gray-900">Year</label>
                        <input type="number" id="createYear" value="@currentYear" min="@(currentYear - 1)" max="@(currentYear + 1)" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5" required>
                        <p id="createYearError" class="mt-1 text-xs text-red-600 hidden"></p>
                    </div>

                    <!-- Allocated Days -->
                    <div>
                        <label for="createAllocated" class="block mb-2 text-sm font-medium text-gray-900">Allocated Days</label>
                        <input type="number" id="createAllocated" placeholder="e.g. 12" step="0.5" min="0" max="365" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5" required>
                        <p id="createAllocatedError" class="mt-1 text-xs text-red-600 hidden"></p>
                    </div>

                    <!-- Used Days -->
                    <div>
                        <label for="createUsed" class="block mb-2 text-sm font-medium text-gray-900">Used Days</label>
                        <input type="number" id="createUsed" value="0" step="0.5" min="0" max="365" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5" required>
                        <p id="createUsedError" class="mt-1 text-xs text-red-600 hidden"></p>
                    </div>

                    <button type="button" id="saveLbBtn" class="w-full text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center">Allocate</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    $(document).ready(function() {
        const toastContainer = $('#toast-container');
        
        $('#saveLbBtn').on('click', function() {
            // Hide all errors
            $('#createEmpIdError, #createLeaveTypeIdError, #createYearError, #createAllocatedError, #createUsedError').addClass('hidden').text('');
            
            const employeeId = $('#createEmpId').val();
            const leaveTypeId = $('#createLeaveTypeId').val();
            const yearStr = $('#createYear').val();
            const allocatedStr = $('#createAllocated').val();
            const usedStr = $('#createUsed').val();
            
            let hasError = false;
            
            if (!employeeId) {
                $('#createEmpIdError').removeClass('hidden').text('Please select an employee.');
                hasError = true;
            }
            if (!leaveTypeId) {
                $('#createLeaveTypeIdError').removeClass('hidden').text('Please select a leave type.');
                hasError = true;
            }
            
            const year = parseInt(yearStr);
            const currentYear = new Date().getFullYear();
            if (isNaN(year) || year < (currentYear - 1) || year > (currentYear + 1)) {
                $('#createYearError').removeClass('hidden').text(`Year must be between ${currentYear - 1} and ${currentYear + 1}.`);
                hasError = true;
            }
            
            const allocated = parseFloat(allocatedStr);
            if (isNaN(allocated) || allocated < 0 || allocated > 365) {
                $('#createAllocatedError').removeClass('hidden').text('Allocated days must be between 0 and 365.');
                hasError = true;
            }
            
            const used = parseFloat(usedStr);
            if (isNaN(used) || used < 0 || used > 365) {
                $('#createUsedError').removeClass('hidden').text('Used days must be between 0 and 365.');
                hasError = true;
            }
            
            if (hasError) return;
            
            const fd = new FormData();
            fd.append('EmployeeId', employeeId);
            fd.append('LeaveTypeId', leaveTypeId);
            fd.append('Year', year);
            fd.append('AllocatedDays', allocated);
            fd.append('UsedDays', used);
            
            $.ajax({
                type: 'POST',
                url: '/leave-balance/create',
                data: fd,
                processData: false,
                contentType: false,
                success: function() {
                    toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Leave balance allocated successfully" })');
                    setTimeout(function() {
                        location.href = '/leave-balance';
                    }, 1500);
                },
                error: function(xhr) {
                    let errMsg = "Allocation failed.";
                    if (xhr.responseText) {
                        try {
                            const errObj = JSON.parse(xhr.responseText);
                            if (errObj && errObj.description) {
                                errMsg = errObj.description;
                            }
                        } catch (e) {}
                    }
                    toastContainer.load('@Url.Action("FailToastPartial", "Main", new { message = "FAIL_PLACEHOLDER" })'.replace("FAIL_PLACEHOLDER", errMsg));
                }
            });
        });
    });
</script>
