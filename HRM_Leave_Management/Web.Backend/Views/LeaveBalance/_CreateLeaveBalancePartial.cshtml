@{
    var employees = ViewBag.Employees as List<Domain.Employees.Employee> ?? new();
    var leaveTypes = ViewBag.LeaveTypes as List<Domain.LeaveTypes.LeaveType> ?? new();
    int currentYear = DateTime.Now.Year;
}

<div id="createLeaveBalanceModal" tabindex="-1" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal Panel -->
        <div class="w-full max-w-[480px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">ALLOCATE LEAVE BALANCE</span>
                <button type="button" class="bg-[#E62429] w-8 h-8 flex items-center justify-center hover:bg-[#c51f24] transition-colors" data-modal-hide="createLeaveBalanceModal">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Body -->
            <div class="p-6 flex flex-col gap-4 text-left font-geist">
                <!-- Employee -->
                <div>
                    <label for="createEmpId" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Employee</label>
                    <select id="createEmpId" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                        <option value="">-- SELECT EMPLOYEE --</option>
                        @foreach (var emp in employees)
                        {
                            <option value="@emp.Id.Value">@emp.FullName (@emp.EmployeeCode)</option>
                        }
                    </select>
                    <p id="createEmpIdError" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>

                <!-- Leave Type -->
                <div>
                    <label for="createLeaveTypeId" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Leave Type</label>
                    <select id="createLeaveTypeId" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                        <option value="">-- SELECT LEAVE TYPE --</option>
                        @foreach (var lt in leaveTypes)
                        {
                            <option value="@lt.Id.Value">@lt.Name (@lt.Code)</option>
                        }
                    </select>
                    <p id="createLeaveTypeIdError" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>

                <!-- Year -->
                <div>
                    <label for="createYear" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Year</label>
                    <input type="number" id="createYear" value="@currentYear" min="@(currentYear - 1)" max="@(currentYear + 1)" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                    <p id="createYearError" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>

                <!-- Allocated Days -->
                <div>
                    <label for="createAllocated" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Allocated Days</label>
                    <input type="number" id="createAllocated" placeholder="e.g. 12" step="0.5" min="0" max="365" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                    <p id="createAllocatedError" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>

                <!-- Used Days -->
                <div>
                    <label for="createUsed" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Used Days</label>
                    <input type="number" id="createUsed" value="0" step="0.5" min="0" max="365" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                    <p id="createUsedError" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>

                <!-- Info Box -->
                <div class="bg-[#F5F5F5] border border-[#D1D1D1] px-3 py-2 font-mono text-[10px] text-[#4c4546]">
                    Remaining days are calculated automatically from allocated minus used days.
                </div>
            </div>
            <!-- Footer -->
            <div class="h-16 flex items-center justify-between px-6 bg-[#FBFBFB] border-t border-[#D1D1D1]">
                <span class="font-mono text-[9px] text-[#4c4546] uppercase tracking-wider">SYSTEM: LIVE</span>
                <div class="flex items-center gap-3">
                    <button data-modal-hide="createLeaveBalanceModal" type="button" class="bg-white border border-[#D1D1D1] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#F4F3F3] transition-colors rounded-none cursor-pointer">
                        CANCEL
                    </button>
                    <button type="button" id="saveLbBtn" class="bg-[#E62429] text-white border border-[#E62429] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#c51f24] transition-all rounded-none cursor-pointer">
                        ALLOCATE
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    $(document).ready(function() {
        const toastContainer = $('#toast-container');
        
        $('#saveLbBtn').on('click', function() {
            // Hide all errors
            $('#createEmpIdError, #createLeaveTypeIdError, #createYearError, #createAllocatedError, #createUsedError').addClass('hidden').text('');
            
            const employeeId = $('#createEmpId').val();
            const leaveTypeId = $('#createLeaveTypeId').val();
            const yearStr = $('#createYear').val();
            const allocatedStr = $('#createAllocated').val();
            const usedStr = $('#createUsed').val();
            
            let hasError = false;
            
            if (!employeeId) {
                $('#createEmpIdError').removeClass('hidden').text('Please select an employee.');
                hasError = true;
            }
            if (!leaveTypeId) {
                $('#createLeaveTypeIdError').removeClass('hidden').text('Please select a leave type.');
                hasError = true;
            }
            
            const year = parseInt(yearStr);
            const currentYear = new Date().getFullYear();
            if (isNaN(year) || year < (currentYear - 1) || year > (currentYear + 1)) {
                $('#createYearError').removeClass('hidden').text(`Year must be between ${currentYear - 1} and ${currentYear + 1}.`);
                hasError = true;
            }
            
            const allocated = parseFloat(allocatedStr);
            if (isNaN(allocated) || allocated < 0 || allocated > 365) {
                $('#createAllocatedError').removeClass('hidden').text('Allocated days must be between 0 and 365.');
                hasError = true;
            }
            
            const used = parseFloat(usedStr);
            if (isNaN(used) || used < 0 || used > 365) {
                $('#createUsedError').removeClass('hidden').text('Used days must be between 0 and 365.');
                hasError = true;
            }
            
            if (hasError) return;
            
            const fd = new FormData();
            fd.append('EmployeeId', employeeId);
            fd.append('LeaveTypeId', leaveTypeId);
            fd.append('Year', year);
            fd.append('AllocatedDays', allocated);
            fd.append('UsedDays', used);
            
            $.ajax({
                type: 'POST',
                url: '/leave-balance/create',
                data: fd,
                processData: false,
                contentType: false,
                success: function() {
                    toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Leave balance allocated successfully" })');
                    setTimeout(function() {
                        location.href = '/leave-balance';
                    }, 1500);
                },
                error: function(xhr) {
                    let errMsg = "Allocation failed.";
                    if (xhr.responseText) {
                        try {
                            const errObj = JSON.parse(xhr.responseText);
                            if (errObj && errObj.description) {
                                errMsg = errObj.description;
                            }
                        } catch (e) {}
                    }
                    toastContainer.load('@Url.Action("FailToastPartial", "Main", new { message = "FAIL_PLACEHOLDER" })'.replace("FAIL_PLACEHOLDER", errMsg));
                }
            });
        });
    });
</script>
