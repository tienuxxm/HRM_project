@model ConfirmDeleteViewModel
<div id="confirmDelete-@Model.Id" tabindex="-1" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Static Backdrop (Enterprise Calm Dim style) -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal content panel -->
        <div class="w-full max-w-[480px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Modal Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">CONFIRM DELETION</span>
                <button type="button" class="bg-[#E62429] w-8 h-8 flex items-center justify-center hover:bg-[#c51f24] transition-colors" data-modal-hide="confirmDelete-@Model.Id">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Modal Body -->
            <div class="p-6 flex flex-col gap-4 text-left">
                <p class="text-[11px] uppercase tracking-wider text-black leading-relaxed font-geist">
                    ARE YOU SURE YOU WANT TO DELETE @Model.Type.ToUpper() <strong class="font-bold text-black font-mono text-[12px]">@Model.Name.ToUpper()</strong>?
                </p>
                
                <!-- Warning Box -->
                <div class="p-4 bg-[#FFF0F0] border border-[#E62429]">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-[#E62429] text-[18px]">warning</span>
                        <p class="mono-text text-[9px] text-[#E62429] leading-relaxed uppercase">
                            WARNING: DELETION MAY BE BLOCKED WHEN ACTIVE SUBORDINATES OR HRM HISTORY EXIST. EXISTING RECORDS MAY BE DEACTIVATED INSTEAD OF HARD-DELETED.
                        </p>
                    </div>
                </div>
            </div>
            <!-- Modal Footer -->
            <div class="h-16 flex items-center justify-end gap-4 px-6 bg-[#FBFBFB] border-t border-[#D1D1D1]">
                <form class="w-full flex justify-between items-center" method="post" action="@Url.Action(Model.ActionName, Model.ActionController, new { id = Model.Id, url = string.IsNullOrEmpty(Model.Url) ? null : Model.Url })">
                    <div class="mono-text text-[9px] text-[#7e7576] font-bold uppercase tracking-tighter">
                        RECORD ID: <span class="text-black font-mono">@Model.Id</span>
                    </div>
                    <div class="flex gap-3">
                        <button data-modal-hide="confirmDelete-@Model.Id" type="button" class="bg-white border border-[#D1D1D1] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#F4F3F3] transition-colors rounded-none cursor-pointer">
                            CANCEL
                        </button>
                        <button type="submit" class="bg-[#E62429] text-white border border-[#E62429] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-white hover:text-[#E62429] transition-all rounded-none cursor-pointer">
                            DELETE
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>