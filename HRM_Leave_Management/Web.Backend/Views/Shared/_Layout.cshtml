@using Application.Abstractions.Authentication
@using Application.Abstractions.Role
@inject IUserContext UserContext
@inject IRoleService RoleService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HRM Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/sumoselect.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css" />
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.tailwindcss.css" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <!-- Google Fonts & Material Symbols for Swiss International -->
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=JetBrains+Mono:wght@400;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Geist', sans-serif; background-color: #FAF9F9; margin: 0; padding: 0; height: 100vh; }
        .font-mono, .mono-text { font-family: 'JetBrains Mono', monospace !important; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; font-size: 18px; }
        .active-indicator { border-left: 3px solid black !important; }
        .swiss-underline { border-bottom: 2px solid #E62429; }
        .no-corners { border-radius: 0px !important; }
        input, select, textarea, button { border-radius: 0px !important; }
        div[modal-backdrop] { display: none !important; }
        .hrm-modal-backdrop { background-color: rgba(0, 0, 0, 0.4) !important; }
        #sidebarMenu {
            width: 260px;
            min-width: 260px;
            max-width: 260px;
            height: 100vh;
            overflow: hidden;
        }
        #sidebarMenu nav {
            min-height: 0;
            overflow-y: auto;
            overflow-x: hidden;
            scrollbar-width: none;
        }
        #sidebarMenu nav::-webkit-scrollbar {
            display: none;
        }
        .hrm-app-shell {
            min-width: 0;
            flex: 1 1 0%;
            height: 100vh;
        }
        .hrm-app-shell > main {
            flex: 1 1 0%;
            min-height: 0;
            overflow-y: auto;
        }
        @@media (min-width: 1024px) {
            #sidebarMenu {
                position: static !important;
                inset: auto !important;
                transform: none !important;
                display: flex !important;
                height: 100vh !important;
                overflow: hidden !important;
            }
            #sidebarBackdrop {
                display: none !important;
            }
            .hrm-app-shell {
                flex: 1 1 auto;
                width: auto !important;
            }
        }
        @@media (max-width: 1023.98px) {
            #sidebarMenu {
                position: fixed !important;
                width: 260px;
                min-width: 260px;
                max-width: 85vw;
                height: 100vh !important;
                overflow: hidden !important;
            }
            .hrm-app-shell {
                width: 100%;
            }
        }
        /* Hide scrollbar for Chrome, Safari and Opera */
        .scrollbar-none::-webkit-scrollbar {
            display: none;
        }
        /* Hide scrollbar for IE, Edge and Firefox */
        .scrollbar-none {
            -ms-overflow-style: none;  /* IE and Edge */
            scrollbar-width: none;  /* Firefox */
        }
        #mobileBottomNav {
            -webkit-overflow-scrolling: touch;
            overscroll-behavior-x: contain;
            touch-action: pan-x;
        }
    </style>
</head>
<body class="font-body-md overflow-hidden h-screen flex flex-row">
    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" integrity="sha512-CNgIRecGo7nphbeZ04Sc13ka07paqdeTu0WR1IM4kNcpmBAUSHSQX0FslNhTDadL4O5SAGapGt4FodqL8My0mA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://unpkg.com/chart.js@4.2.0/dist/chart.umd.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/@("@editorjs")/editorjs@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@("@editorjs")/image@2.3.0"></script>
    <script src="https://cdn.jsdelivr.net/npm/@("@editorjs")/header@latest"></script>
    <script src="https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js"></script>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <div id="toast-container"></div>
    <div id="loadingOverlay" style="z-index: 1000 !important;" class="transition delay-150 ease-in-out fixed top-0 left-0 bg-gray-800 bg-opacity-60 h-full w-full flex items-center justify-center">
        <div class="flex items-center">
            <svg aria-hidden="true" class="inline w-10 h-10 mr-2 text-gray-200 animate-spin dark:text-gray-600 fill-black" viewBox="0 0 100 101" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor" />
                <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentFill" />
            </svg>
        </div>
    </div>

    <!-- Persistent Sidebar -->
    <aside id="sidebarMenu" class="hidden lg:flex fixed lg:static inset-y-0 left-0 z-50 w-[260px] h-screen bg-swiss-light border-r border-swiss-border flex-col flex-shrink-0 transform -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-in-out">
        <div class="px-6 pt-8 pb-4 flex-shrink-0">
            <div class="inline-block pb-1 swiss-underline">
                <h1 class="font-bold text-black border-l-4 border-swiss-red pl-4 text-2xl tracking-tighter" style="font-family: 'Geist', sans-serif;">HRM PORTAL</h1>
            </div>
            <p class="mt-2 text-[10px] tracking-widest uppercase text-[#4c4546] opacity-60 font-semibold font-mono">Institutional Authority</p>
        </div>
        <nav class="flex-1 min-h-0 mt-6 overflow-y-auto overflow-x-hidden">
            <div class="flex flex-col" id="menuList">
            </div>
        </nav>
        <div class="p-6 border-t border-swiss-border flex-shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-[#e2e2e2] border border-swiss-border flex items-center justify-center">
                    <span class="material-symbols-outlined text-black">account_circle</span>
                </div>
                <div>
                    <p class="text-xs font-bold text-black uppercase font-mono headerUsername">...</p>
                    <p class="mono-text text-[9px] text-[#4c4546] uppercase">LEVEL: 00 (ROOT)</p>
                </div>
            </div>
        </div>
    </aside>

    <!-- Sidebar backdrop for mobile -->
    <div id="sidebarBackdrop" class="fixed inset-0 z-40 bg-black bg-opacity-40 hidden lg:hidden"></div>

    <!-- Main Application Container -->
    <div class="hrm-app-shell flex-1 flex flex-col overflow-hidden w-full">
        <!-- Desktop Header -->
        <header class="hidden lg:flex h-16 items-center justify-between px-6 bg-swiss-light border-b border-swiss-border sticky top-0 z-40">
            <div class="mono-text text-[10px] text-[#4c4546] flex items-center gap-2">
                <span class="opacity-50">SYS / DIRECTORY /</span> <span class="font-bold text-black">@(ViewData["Title"]?.ToString().ToUpper() ?? "PORTAL")</span>
            </div>
            <div class="flex items-center gap-6">
                <div class="mono-text text-[10px] text-[#4c4546] border-r border-swiss-border pr-6">
                    REALM: <span class="text-black font-bold">HRM</span> | USER: <span class="text-black font-bold headerUsername">...</span>
                </div>
                <a href="/Auth/Logout" class="bg-swiss-red text-white px-4 py-1.5 font-mono text-[10px] tracking-wider uppercase hover:bg-black transition-colors flex items-center gap-2 no-underline" style="border-radius: 0px;">
                    <span class="material-symbols-outlined text-[14px]">logout</span>
                    LOGOUT
                </a>
            </div>
        </header>

        <!-- Mobile Header -->
        <header class="lg:hidden bg-swiss-light sticky top-0 z-50 w-full border-b-2 border-swiss-red flex items-center justify-between px-6 h-16">
            <div class="flex items-center gap-4">
                <button id="mobileMenuBtn" class="hidden lg:hidden hover:bg-black hover:text-white transition-colors duration-100 p-1 cursor-pointer">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <h1 class="font-bold tracking-tighter text-black text-lg font-mono">HRM PORTAL</h1>
            </div>
            <div class="flex flex-col items-end">
                <span class="font-mono text-[9px] uppercase font-bold text-black headerUsername">...</span>
                <a href="/Auth/Logout" class="font-mono text-[9px] uppercase font-bold text-swiss-red cursor-pointer hover:underline no-underline">LOGOUT</a>
            </div>
        </header>

        <!-- Main Workspace -->
        <main class="flex-1 overflow-y-auto bg-swiss-light p-6 pb-24 lg:pb-6 flex flex-col gap-6">
            @RenderBody()
        </main>

        <!-- System Status Footer -->
        <footer class="hidden lg:flex h-8 bg-[#eeeeee] border-t border-swiss-border px-6 items-center justify-between">
            <div class="mono-text text-[9px] text-[#4c4546] tracking-wider uppercase">
                REALM CONNECTIVITY SECURED BY KEYCLOAK IDENTITY PROVIDER. SESSION STATUS: <span class="text-black font-bold">VERIFIED.</span>
            </div>
            <div class="flex items-center gap-4 mono-text text-[9px] text-[#4c4546] uppercase">
                <span>LATENCY: 14MS</span>
                <span>ENC: AES-256</span>
                <span>© 2024 HRM PORTAL SECURE</span>
            </div>
        </footer>

        <!-- Mobile Bottom Navigation Bar -->
        <nav id="mobileBottomNav" class="lg:hidden fixed bottom-0 left-0 right-0 h-16 bg-white border-t border-black flex items-center overflow-x-auto whitespace-nowrap scrollbar-none z-50 select-none shadow-[0_-2px_10px_rgba(0,0,0,0.05)] w-full">
        </nav>
        <div class="pointer-events-none absolute right-0 bottom-0 w-12 h-16 bg-gradient-to-l from-white to-transparent z-50 lg:hidden" id="mobileNavFade"></div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/jquery.sumoselect.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/1.8.1/flowbite.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/1.8.1/datepicker.min.js"></script>

    <script>
        $.get('/Auth/GetUserLogin')
            .done(function(data) {
                const username = data.username ? data.username.toUpperCase() : '';
                $('.headerUsername').text(username);
            })
            .fail(function(error) {
                console.log('Error occurred', error);
            });

        @{
            bool viewWorkCalendar = false;
            try
            {
                var checkPermResult = await RoleService.checkRoleExist(UserContext.IdentityId, "VIEW_WORK_CALENDAR", default);
                viewWorkCalendar = checkPermResult.IsSuccess && checkPermResult.Value;
            }
            catch {}
        }

        const menuItems = [
            {
                name: 'GENERAL',
                isTab: true
            },
            {
                name: 'Dashboard',
                icon: 'dashboard',
                url: 'dashboard',
                mobileLabel: 'Home'
            },
            {
                name: 'HRM MANAGEMENT',
                isTab: true
            },
            {
                name: 'Departments',
                icon: 'domain',
                url: 'department',
                mobileLabel: 'Depts'
            },
            {
                name: 'Employees',
                icon: 'group',
                url: 'employee',
                mobileLabel: 'Staff'
            },
            {
                name: 'Positions',
                icon: 'badge',
                url: 'position',
                mobileLabel: 'Pos'
            },
            {
                name: 'LEAVE MANAGEMENT',
                isTab: true
            },
            {
                name: 'Leave Types',
                icon: 'event_busy',
                url: 'leave-type',
                mobileLabel: 'Types'
            },
            {
                name: 'Leave Requests',
                icon: 'date_range',
                url: 'leave-request',
                mobileLabel: 'Requests'
            },
            {
                name: 'Leave Balances',
                icon: 'account_balance_wallet',
                url: 'leave-balance',
                mobileLabel: 'Balances'
            },
            @if (viewWorkCalendar)
            {
                <text>
                {
                    name: 'Work Calendar',
                    icon: 'calendar_today',
                    url: 'work-calendar',
                    mobileLabel: 'Calendar'
                },
                </text>
            }
            {
                name: 'Approver Assignments',
                icon: 'how_to_reg',
                url: 'leave-approver-assignment',
                mobileLabel: 'Approvers'
            },
            {
                name: 'SYSTEM',
                isTab: true
            },
            {
                name: 'Users',
                icon: 'manage_accounts',
                url: 'user',
                mobileLabel: 'Users'
            },
            {
                name: 'Roles & Permissions',
                icon: 'security',
                url: 'role',
                mobileLabel: 'Security'
            }
        ];
        const loadingOverlay = $('#loadingOverlay');
        loadingOverlay.hide();
        const menuContainer = $('#menuList').html('');

        // Render Desktop Sidebar Menu
        menuItems.forEach(i => {
            if (i.isTab){
                menuContainer.append(`<div class="flex flex-col justify-start items-start w-full mt-6 mb-2">
                        <div class="flex items-center w-full px-6 py-1">
                            <span class="text-[9px] font-bold tracking-widest text-[#7F7F7F] uppercase font-mono">${i.name}</span>
                        </div>
                    </div>`)
            }else{
                const path = location.pathname.split('/')[1]?.toLowerCase()
                const isActive = path === i.url?.toLowerCase();

                menuContainer.append(
                    `<div class="flex flex-col justify-start items-start w-full">
                        <a href="/${i.url}" class="flex items-center w-full px-6 py-3 cursor-pointer group no-underline transition-colors duration-150 ${isActive ? 'bg-black text-white font-bold active-indicator' : 'text-[#4c4546] hover:bg-[#eeeeee] hover:text-black'}">
                            <span class="material-symbols-outlined mr-3 transition-colors duration-150 ${isActive ? 'text-white' : 'text-[#7F7F7F] group-hover:text-black'}">${i.icon}</span>
                            <span class="font-mono text-[11px] uppercase tracking-wider transition-colors duration-150">${i.name}</span>
                        </a>
                    </div>`)
            }
        });

        // Render Mobile Bottom Navigation
        const mobileNavContainer = $('<div class="flex items-center h-full w-full"></div>');
        menuItems.forEach(i => {
            if (!i.isTab) {
                const path = location.pathname.split('/')[1]?.toLowerCase();
                const isActive = path === i.url?.toLowerCase();

                mobileNavContainer.append(
                    `<a href="/${i.url}" class="mobile-nav-item flex-shrink-0 w-20 h-full flex flex-col items-center justify-center gap-1 transition-colors duration-150 ${isActive ? 'bg-black text-white font-bold' : 'text-[#4c4546] hover:bg-[#eeeeee] hover:text-black'}" style="border-radius: 0px !important; text-decoration: none !important;">
                        <span class="material-symbols-outlined ${isActive ? 'text-white' : 'text-[#7F7F7F]'}">${i.icon}</span>
                        <span class="font-mono text-[9px] uppercase tracking-wider">${i.mobileLabel || i.name}</span>
                    </a>`
                );
            }
        });
        $('#mobileBottomNav').html(mobileNavContainer);

        // Auto scroll active mobile item into view
        setTimeout(() => {
            const activeMobileItem = $('#mobileBottomNav .bg-black')[0];
            if (activeMobileItem) {
                activeMobileItem.scrollIntoView({ behavior: 'auto', block: 'nearest', inline: 'center' });
            }
        }, 100);

        // Mobile sidebar toggle
        $('#mobileMenuBtn').on('click', function(e) {
            e.stopPropagation();
            $('#sidebarMenu').removeClass('-translate-x-full');
            $('#sidebarBackdrop').removeClass('hidden');
        });
        $('#sidebarBackdrop').on('click', function() {
            $('#sidebarMenu').addClass('-translate-x-full');
            $('#sidebarBackdrop').addClass('hidden');
        });

        // Desktop mouse drag scroll helper for mobile bottom nav
        (function() {
            const nav = document.getElementById('mobileBottomNav');
            if (!nav) return;
            let isPointerDown = false;
            let hasDragged = false;
            let startX = 0;
            let startScrollLeft = 0;
            const dragThreshold = 5;

            nav.addEventListener('pointerdown', (event) => {
                if (event.pointerType === 'touch' || event.button !== 0) return;
                isPointerDown = true;
                hasDragged = false;
                startX = event.clientX;
                startScrollLeft = nav.scrollLeft;
                nav.style.cursor = 'grabbing';
                nav.style.userSelect = 'none';
            });

            nav.addEventListener('pointermove', (event) => {
                if (!isPointerDown) return;
                const deltaX = event.clientX - startX;
                if (Math.abs(deltaX) <= dragThreshold) return;
                hasDragged = true;
                event.preventDefault();
                nav.scrollLeft = startScrollLeft - deltaX;
            });

            const stopDrag = () => {
                isPointerDown = false;
                nav.style.cursor = 'grab';
                nav.style.userSelect = '';
            };

            nav.addEventListener('pointerup', stopDrag);
            nav.addEventListener('pointercancel', stopDrag);
            nav.addEventListener('mouseleave', stopDrag);
            nav.addEventListener('click', (event) => {
                if (!hasDragged) return;
                event.preventDefault();
                event.stopPropagation();
                hasDragged = false;
            }, true);

            // Initial styling hint
            nav.style.cursor = 'grab';
        })();
    </script>
    @await RenderSectionAsync("Scripts", false)
</body>
</html>
