<div id="createLeaveTypeModal" tabindex="-1" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal Panel -->
        <div class="w-full max-w-[480px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">CREATE LEAVE TYPE</span>
                <button type="button" class="bg-[#E62429] w-8 h-8 flex items-center justify-center hover:bg-[#c51f24] transition-colors" data-modal-hide="createLeaveTypeModal">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Body -->
            <div class="p-6 flex flex-col gap-4 text-left font-geist">
                <!-- Code -->
                <div>
                    <label for="ltCode" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Code</label>
                    <input type="text" placeholder="e.g. ANNUAL_LEAVE" id="ltCode" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                    <p id="ltCodeError" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>
                <!-- Name -->
                <div>
                    <label for="ltName" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Name</label>
                    <input type="text" placeholder="e.g. Annual Leave" id="ltName" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                    <p id="ltNameError" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>
                <!-- Default Days -->
                <div>
                    <label for="ltDefaultDays" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Default Days</label>
                    <input type="number" placeholder="e.g. 12" id="ltDefaultDays" min="0" max="365" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors" required>
                    <p id="ltDaysError" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>
                <!-- Description -->
                <div>
                    <label for="ltDesc" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Description (Optional)</label>
                    <textarea placeholder="Enter description" id="ltDesc" rows="3" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors resize-none"></textarea>
                </div>
            </div>
            <!-- Footer -->
            <div class="h-16 flex items-center justify-end gap-3 px-6 bg-[#FBFBFB] border-t border-[#D1D1D1]">
                <button data-modal-hide="createLeaveTypeModal" type="button" class="bg-white border border-[#D1D1D1] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#F4F3F3] transition-colors rounded-none cursor-pointer">
                    CANCEL
                </button>
                <button type="button" id="saveLtBtn" class="bg-[#E62429] text-white border border-[#E62429] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#c51f24] transition-all rounded-none cursor-pointer">
                    CREATE
                </button>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    const toastContainer = $('#toast-container');
    $('#ltCodeError, #ltNameError, #ltDaysError').addClass('hidden');
    $('#saveLtBtn').on('click', function(){
        $('#ltCodeError, #ltNameError, #ltDaysError').addClass('hidden').text('');
        var code=$('#ltCode').val(), name=$('#ltName').val(), days=$('#ltDefaultDays').val(), desc=$('#ltDesc').val();
        if(!code||!code.trim()){$('#ltCodeError').removeClass('hidden').text("Please enter code");return;}
        if(!name||!name.trim()){$('#ltNameError').removeClass('hidden').text("Please enter name");return;}
        if(!days||parseInt(days)<0){$('#ltDaysError').removeClass('hidden').text("Please enter valid days");return;}
        var fd=new FormData();
        fd.append('Code',code);fd.append('Name',name);fd.append('DefaultDays',days);fd.append('Description',desc);
        $.ajax({type:"POST",url:'/leave-type/create',data:fd,processData:false,contentType:false,
            success:function(){
                toastContainer.load('@Url.Action("SuccessToastPartial","Main",new{message="Leave type created"},null)');
                setTimeout(function(){location.href="/leave-type"},1500);
            },
            error:function(){
                toastContainer.load('@Url.Action("FailToastPartial","Main",new{message="Creation failed"},null)');
            }
        });
    });
</script>
