@model Domain.LeaveTypes.LeaveType
<div id="updateLeaveTypeModal-@Model.Id.Value" tabindex="-1" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal Panel -->
        <div class="w-full max-w-[480px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">UPDATE LEAVE TYPE</span>
                <button type="button" class="bg-[#E62429] w-8 h-8 flex items-center justify-center hover:bg-[#c51f24] transition-colors" data-modal-hide="updateLeaveTypeModal-@Model.Id.Value">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Body -->
            <div class="p-6 flex flex-col gap-4 text-left font-geist">
                <!-- Code -->
                <div>
                    <label class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Code</label>
                    <input type="text" id="upLtCode-@Model.Id.Value" value="@Model.Code" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors">
                    <p id="upLtCodeErr-@Model.Id.Value" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>
                <!-- Name -->
                <div>
                    <label class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Name</label>
                    <input type="text" id="upLtName-@Model.Id.Value" value="@Model.Name" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors">
                    <p id="upLtNameErr-@Model.Id.Value" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide hidden"></p>
                </div>
                <!-- Default Days -->
                <div>
                    <label class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Default Days</label>
                    <input type="number" id="upLtDays-@Model.Id.Value" value="@Model.DefaultDays" min="0" max="365" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors">
                </div>
                <!-- Description -->
                <div>
                    <label class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Description</label>
                    <textarea id="upLtDesc-@Model.Id.Value" rows="3" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors resize-none">@Model.Description</textarea>
                </div>
            </div>
            <!-- Footer -->
            <div class="h-16 flex items-center justify-end gap-3 px-6 bg-[#FBFBFB] border-t border-[#D1D1D1]">
                <button data-modal-hide="updateLeaveTypeModal-@Model.Id.Value" type="button" class="bg-white border border-[#D1D1D1] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#F4F3F3] transition-colors rounded-none cursor-pointer">
                    CANCEL
                </button>
                <button type="button" onclick="updateLeaveType('@Model.Id.Value')" class="bg-[#E62429] text-white border border-[#E62429] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#c51f24] transition-all rounded-none cursor-pointer">
                    UPDATE
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function updateLeaveType(id){
        $('#upLtCodeErr-'+id+', #upLtNameErr-'+id).addClass('hidden').text('');
        var code=$('#upLtCode-'+id).val(),name=$('#upLtName-'+id).val(),days=$('#upLtDays-'+id).val(),desc=$('#upLtDesc-'+id).val();
        if(!code||!code.trim()){$('#upLtCodeErr-'+id).removeClass('hidden').text("Required");return;}
        if(!name||!name.trim()){$('#upLtNameErr-'+id).removeClass('hidden').text("Required");return;}
        var fd=new FormData();
        fd.append('Id',id);fd.append('Code',code);fd.append('Name',name);fd.append('DefaultDays',days);fd.append('Description',desc);
        $.ajax({type:"POST",url:'/leave-type/update',data:fd,processData:false,contentType:false,
            success:function(){
                $('#toast-container').load('@Url.Action("SuccessToastPartial","Main",new{message="Updated"},null)');
                setTimeout(function(){location.href="/leave-type"},1500);
            },
            error:function(){
                $('#toast-container').load('@Url.Action("FailToastPartial","Main",new{message="Update failed"},null)');
            }
        });
    }
</script>
