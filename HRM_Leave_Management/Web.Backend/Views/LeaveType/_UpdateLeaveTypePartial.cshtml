@model Domain.LeaveTypes.LeaveType
<div id="updateLeaveTypeModal-@Model.Id.Value" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative w-full max-w-md max-h-full">
        <div class="relative bg-white rounded-lg shadow dark:bg-gray-700">
            <button type="button" class="absolute top-3 right-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ml-auto inline-flex justify-center items-center" data-modal-hide="updateLeaveTypeModal-@Model.Id.Value">
                <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
            </button>
            <div class="px-6 py-6 lg:px-8">
                <h3 class="mb-4 text-xl font-medium text-gray-900">Update Leave Type</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block mb-2 text-sm font-medium text-gray-900">Code</label>
                        <input type="text" id="upLtCode-@Model.Id.Value" value="@Model.Code" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                        <p id="upLtCodeErr-@Model.Id.Value" class="mt-2 text-sm text-red-600 hidden"></p>
                    </div>
                    <div>
                        <label class="block mb-2 text-sm font-medium text-gray-900">Name</label>
                        <input type="text" id="upLtName-@Model.Id.Value" value="@Model.Name" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                        <p id="upLtNameErr-@Model.Id.Value" class="mt-2 text-sm text-red-600 hidden"></p>
                    </div>
                    <div>
                        <label class="block mb-2 text-sm font-medium text-gray-900">Default Days</label>
                        <input type="number" id="upLtDays-@Model.Id.Value" value="@Model.DefaultDays" min="0" max="365" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                    </div>
                    <div>
                        <label class="block mb-2 text-sm font-medium text-gray-900">Description</label>
                        <textarea id="upLtDesc-@Model.Id.Value" rows="3" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">@Model.Description</textarea>
                    </div>
                    <button type="button" onclick="updateLeaveType('@Model.Id.Value')" class="w-full text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center">Update</button>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    function updateLeaveType(id){
        var code=$('#upLtCode-'+id).val(),name=$('#upLtName-'+id).val(),days=$('#upLtDays-'+id).val(),desc=$('#upLtDesc-'+id).val();
        if(!code||!code.trim()){$('#upLtCodeErr-'+id).removeClass('hidden').text("Required");return;}
        if(!name||!name.trim()){$('#upLtNameErr-'+id).removeClass('hidden').text("Required");return;}
        var fd=new FormData();
        fd.append('Id',id);fd.append('Code',code);fd.append('Name',name);fd.append('DefaultDays',days);fd.append('Description',desc);
        $.ajax({type:"POST",url:'/leave-type/update',data:fd,processData:false,contentType:false,
            success:function(){
                $('#toast-container').load('@Url.Action("SuccessToastPartial","Main",new{message="Updated"},null)');
                setTimeout(function(){location.href="/leave-type"},1500);
            },
            error:function(){
                $('#toast-container').load('@Url.Action("FailToastPartial","Main",new{message="Update failed"},null)');
            }
        });
    }
</script>
