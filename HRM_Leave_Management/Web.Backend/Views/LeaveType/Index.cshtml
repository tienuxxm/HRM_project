@model List<Domain.LeaveTypes.LeaveType>

@{
    ViewBag.Title = "Leave Types";
    Layout = "_Layout";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 5;
    int totalCount = ViewBag.TotalCount ?? 0;
    int startIndex = (currentPage - 1) * pageSize;
}

<style>
    /* LeaveType pagination — synced with LeaveBalance pattern */
    .lt-page-btn {
        display:inline-block !important;
        padding:2px 12px !important;
        font-family:monospace !important;
        font-size:10px !important;
        font-weight:700 !important;
        text-transform:uppercase !important;
        text-decoration:none !important;
        border:1px solid #D1D1D1 !important;
        background:#fff !important;
        color:#000 !important;
        cursor:pointer !important;
    }
    .lt-page-btn:link, .lt-page-btn:visited, .lt-page-btn:active { color:#000 !important; text-decoration:none !important; }
    .lt-page-btn:hover, .lt-page-btn:hover:link, .lt-page-btn:hover:visited { background:#E0E0E0 !important; color:#000 !important; border-color:#999 !important; }
    .lt-page-btn-disabled {
        display:inline-block !important;
        padding:2px 12px !important;
        font-family:monospace !important;
        font-size:10px !important;
        font-weight:700 !important;
        text-transform:uppercase !important;
        border:1px solid #E0E0E0 !important;
        background:#F0F0F0 !important;
        color:#999 !important;
        cursor:not-allowed !important;
    }
    .lt-page-btn-mobile {
        display:inline-block !important;
        padding:6px 16px !important;
        font-family:monospace !important;
        font-size:10px !important;
        font-weight:700 !important;
        text-transform:uppercase !important;
        text-decoration:none !important;
        border:1px solid #D1D1D1 !important;
        background:#fff !important;
        color:#000 !important;
        cursor:pointer !important;
    }
    .lt-page-btn-mobile:link, .lt-page-btn-mobile:visited, .lt-page-btn-mobile:active { color:#000 !important; text-decoration:none !important; }
    .lt-page-btn-mobile:hover, .lt-page-btn-mobile:hover:link, .lt-page-btn-mobile:hover:visited { background:#E0E0E0 !important; color:#000 !important; border-color:#999 !important; }
    .lt-page-btn-mobile-disabled {
        display:inline-block !important;
        padding:6px 16px !important;
        font-family:monospace !important;
        font-size:10px !important;
        font-weight:700 !important;
        text-transform:uppercase !important;
        border:1px solid #E0E0E0 !important;
        background:#F0F0F0 !important;
        color:#999 !important;
        cursor:not-allowed !important;
    }
</style>

<div class="w-full flex flex-col font-geist">
    <!-- Header Section -->
    <div class="mb-6">
        <h2 class="text-[32px] font-bold text-black uppercase tracking-tight">Leave Types</h2>
        <p class="text-[14px] text-[#4c4546]">Configure leave categories and default allocation days.</p>
    </div>

    <!-- Desktop Search & Action Bar -->
    <div class="hidden lg:flex flex-row items-center justify-between gap-4 mb-4">
        <div class="w-[400px] relative">
            <input id="ltSearchInput" autocomplete="off" class="w-full h-10 bg-white border border-[#D1D1D1] px-4 font-mono text-[11px] focus:outline-none focus:border-black transition-colors placeholder:text-[#cfc4c5]" placeholder="SEARCH LEAVE TYPES..." type="text"/>
            <span class="material-symbols-outlined absolute right-3 top-2.5 text-[20px] text-[#cfc4c5]">search</span>
        </div>
        <div>
            <button type="button" data-modal-target="createLeaveTypeModal" data-modal-toggle="createLeaveTypeModal" class="h-10 px-8 bg-black text-white text-[11px] font-bold uppercase tracking-widest hover:opacity-90 transition-all cursor-pointer">
                + Create Leave Type
            </button>
        </div>
    </div>

    <!-- Mobile Search & Action Bar -->
    <div class="lg:hidden mb-4">
        <div class="flex items-stretch gap-0 border border-[#D1D1D1]">
            <div class="flex-grow flex items-center bg-white px-3 border-r border-[#D1D1D1] h-10">
                <span class="material-symbols-outlined text-[#4c4546] mr-2" style="font-size: 16px;">search</span>
                <input id="mobileSearchInput" autocomplete="off" class="w-full bg-transparent border-none focus:ring-0 text-[11px] placeholder:text-[#4c4546] p-0 font-medium" placeholder="SEARCH LEAVE TYPES" type="text"/>
            </div>
            <button type="button" data-modal-target="createLeaveTypeModal" data-modal-toggle="createLeaveTypeModal" class="bg-black text-white px-4 h-10 text-[11px] font-bold uppercase flex items-center gap-1 active:invert transition-all cursor-pointer">
                <span class="material-symbols-outlined" style="font-size: 14px;">add</span>CREATE
            </button>
        </div>
    </div>

    <!-- Desktop Data Grid -->
    <div class="hidden lg:flex flex-col border border-[#D1D1D1] bg-white">
        <table class="w-full text-left border-collapse">
            <thead class="bg-[#F5F5F5]">
                <tr class="border-b border-[#D1D1D1]">
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-16 text-center">No</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-36">Code</th>
                    <th class="px-4 py-3 font-bold text-[11px] text-black uppercase border-r border-[#D1D1D1]">Leave Type Name</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-28 text-center">Default Days</th>
                    <th class="px-4 py-3 font-bold text-[11px] text-[#4c4546] uppercase border-r border-[#D1D1D1]">Description</th>
                    <th class="px-4 py-3 font-bold text-[10px] text-[#4c4546] uppercase border-r border-[#D1D1D1] w-24">Status</th>
                    <th class="px-4 py-3 font-bold text-[10px] text-[#4c4546] uppercase w-40">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#D1D1D1]">
                @foreach (var lt in Model.Select((val, index) => new { val, index = startIndex + index + 1 }))
                {
                    <tr class="hover:bg-[#f4f3f3] transition-colors lt-row" data-code="@lt.val.Code" data-name="@lt.val.Name" style="transition: transform 0.15s ease;">
                         <td class="px-4 py-3 font-mono text-[11px] font-bold border-r border-[#D1D1D1] text-center">@lt.index</td>
                         <td class="px-4 py-3 font-mono text-[11px] font-bold border-r border-[#D1D1D1]">@lt.val.Code</td>
                         <td class="px-4 py-3 font-bold text-[12px] text-black border-r border-[#D1D1D1]">@lt.val.Name</td>
                         <td class="px-4 py-3 font-mono text-[11px] font-bold text-black border-r border-[#D1D1D1] text-center">@lt.val.DefaultDays</td>
                         <td class="px-4 py-3 text-[11px] text-[#4c4546] border-r border-[#D1D1D1]">
                             @(string.IsNullOrEmpty(lt.val.Description) ? "—" : lt.val.Description)
                         </td>
                         <td class="px-4 py-3 border-r border-[#D1D1D1]">
                             @if (lt.val.IsActive)
                             {
                                 <span class="px-2 py-0.5 border border-emerald-500 text-emerald-600 font-bold text-[9px] uppercase tracking-tighter">Active</span>
                             }
                             else
                             {
                                 <span class="px-2 py-0.5 border border-[#D1D1D1] text-[#7e7576] font-bold text-[9px] uppercase tracking-tighter">Inactive</span>
                             }
                         </td>
                         <td class="px-4 py-3 whitespace-nowrap">
                             <div class="flex space-x-3">
                                 <a data-modal-target="updateLeaveTypeModal-@lt.val.Id.Value" data-modal-toggle="updateLeaveTypeModal-@lt.val.Id.Value" class="text-[9px] font-bold text-black hover:text-swiss-red uppercase underline decoration-[#cfc4c5] underline-offset-4 cursor-pointer" href="javascript:void(0)">Edit</a>
                                 <a data-modal-target="confirmDelete-@lt.val.Id.Value" data-modal-toggle="confirmDelete-@lt.val.Id.Value" class="text-[9px] font-bold text-swiss-red hover:opacity-70 uppercase underline decoration-[#cfc4c5] underline-offset-4 cursor-pointer" href="javascript:void(0)">Remove</a>
                             </div>
                         </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Desktop Table Pagination Footer -->
        <div class="flex items-center justify-between px-4 py-3 border-t border-[#D1D1D1] bg-[#F5F5F5] font-mono text-[10px] font-bold text-[#4c4546] uppercase">
            <div>
                @if (totalCount > 0)
                {
                    var showStart = startIndex + 1;
                    var showEnd = Math.Min(startIndex + pageSize, totalCount);
                    <span>SHOWING @showStart-@showEnd OF @totalCount LEAVE TYPES</span>
                }
                else
                {
                    <span>NO LEAVE TYPES FOUND</span>
                }
            </div>
            <div class="flex items-center gap-2">
                @if (currentPage > 1)
                {
                    <a href="/leave-type?page=@(currentPage - 1)&pageSize=@pageSize" class="lt-page-btn">PREV</a>
                }
                else
                {
                    <span class="lt-page-btn-disabled">PREV</span>
                }
                <span class="px-3 py-1 font-mono text-[10px] font-bold text-black uppercase">PAGE @currentPage OF @Math.Max(1, totalPages)</span>
                @if (currentPage < totalPages)
                {
                    <a href="/leave-type?page=@(currentPage + 1)&pageSize=@pageSize" class="lt-page-btn">NEXT</a>
                }
                else
                {
                    <span class="lt-page-btn-disabled">NEXT</span>
                }
            </div>
        </div>
    </div>

    <!-- Mobile Stacked List -->
    <div class="lg:hidden flex flex-col gap-4">
        <div class="flex flex-col gap-4">
            @foreach (var lt in Model)
            {
                <div class="bg-white border border-[#D1D1D1] p-4 flex flex-col gap-3 lt-card" data-code="@lt.Code" data-name="@lt.Name">
                    <div class="flex justify-between items-start">
                        <div class="flex flex-col">
                            <span class="mono text-[10px] text-[#4c4546] font-bold">@lt.Code</span>
                            <h2 class="text-[16px] font-bold uppercase tracking-tight">@lt.Name</h2>
                        </div>
                        @if (lt.IsActive)
                        {
                            <span class="bg-black text-white px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider">ACTIVE</span>
                        }
                        else
                        {
                            <span class="bg-[#4c4546] text-white px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider">INACTIVE</span>
                        }
                    </div>

                    <div class="border-y border-[#F1F1F1] py-2">
                        <div class="flex justify-between items-center mb-1">
                            <span class="text-[#4c4546] text-[9px] font-bold uppercase">Default Days</span>
                            <span class="font-mono text-[12px] font-bold text-black">@lt.DefaultDays</span>
                        </div>
                        <span class="text-[#4c4546] text-[9px] font-bold uppercase mb-1 block">Description</span>
                        <p class="text-[11px] text-black">
                            @(string.IsNullOrEmpty(lt.Description) ? "—" : lt.Description)
                        </p>
                    </div>

                    <div class="flex gap-4">
                        <button type="button" data-modal-target="updateLeaveTypeModal-@lt.Id.Value" data-modal-toggle="updateLeaveTypeModal-@lt.Id.Value" class="text-[10px] font-bold uppercase hover:text-primary transition-colors cursor-pointer">[EDIT]</button>
                        <button type="button" data-modal-target="confirmDelete-@lt.Id.Value" data-modal-toggle="confirmDelete-@lt.Id.Value" class="ml-auto text-[#E62429] text-[10px] font-bold uppercase hover:opacity-70 transition-opacity cursor-pointer">[REMOVE]</button>
                    </div>
                </div>
            }
        </div>

        <!-- Mobile Pagination Footer -->
        <div class="mt-6 border border-[#D1D1D1] bg-white p-4 flex flex-col gap-3 font-mono text-[11px]">
            <div class="text-center font-bold text-black uppercase">
                @if (totalCount > 0)
                {
                    var mShowStart = startIndex + 1;
                    var mShowEnd = Math.Min(startIndex + pageSize, totalCount);
                    <span>SHOWING @mShowStart-@mShowEnd OF @totalCount LEAVE TYPES</span>
                }
                else
                {
                    <span>NO LEAVE TYPES FOUND</span>
                }
            </div>
            <div class="flex items-center justify-center gap-2">
                @if (currentPage > 1)
                {
                    <a href="/leave-type?page=@(currentPage - 1)&pageSize=@pageSize" class="lt-page-btn-mobile">PREV</a>
                }
                else
                {
                    <span class="lt-page-btn-mobile-disabled">PREV</span>
                }
                <span class="px-3 py-2 font-mono text-[10px] font-bold text-black uppercase">PAGE @currentPage OF @Math.Max(1, totalPages)</span>
                @if (currentPage < totalPages)
                {
                    <a href="/leave-type?page=@(currentPage + 1)&pageSize=@pageSize" class="lt-page-btn-mobile">NEXT</a>
                }
                else
                {
                    <span class="lt-page-btn-mobile-disabled">NEXT</span>
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal Container -->
@Html.Partial("_CreateLeaveTypePartial")

@foreach (var lt in Model)
{
    @Html.Partial("_UpdateLeaveTypePartial", lt)
    @Html.Partial("_ConfirmDeletePartial", new ConfirmDeleteViewModel()
    {
        Id = lt.Id.Value,
        Type = "LeaveType",
        Name = lt.Name,
        ActionName = "Delete",
        ActionController = "LeaveType"
    })
}

@section Scripts {
<script>
    // Client-side search filter (within current page results)
    function setupSearch(inputId, rowSelector, cardSelector) {
        var input = document.getElementById(inputId);
        if (!input) return;
        input.addEventListener('input', function() {
            var q = this.value.toUpperCase();
            // Desktop rows
            document.querySelectorAll(rowSelector).forEach(function(row) {
                var code = (row.getAttribute('data-code') || '').toUpperCase();
                var name = (row.getAttribute('data-name') || '').toUpperCase();
                row.style.display = (code.indexOf(q) > -1 || name.indexOf(q) > -1) ? '' : 'none';
            });
            // Mobile cards
            document.querySelectorAll(cardSelector).forEach(function(card) {
                var code = (card.getAttribute('data-code') || '').toUpperCase();
                var name = (card.getAttribute('data-name') || '').toUpperCase();
                card.style.display = (code.indexOf(q) > -1 || name.indexOf(q) > -1) ? '' : 'none';
            });
        });
    }
    setupSearch('ltSearchInput', '.lt-row', '.lt-card');
    setupSearch('mobileSearchInput', '.lt-row', '.lt-card');
</script>
}
