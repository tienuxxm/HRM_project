@model Domain.Abstractions.PagedList<Application.LeaveRequests.Get.LeaveRequestResponse>

@{
    ViewBag.Title = "Leave Request Management";
    Layout = "_Layout";
    bool canApprove = ViewBag.CanApprove ?? false;
    bool canCreate = ViewBag.CanCreate ?? false;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = 5; // Mặc định từ controller
    int totalCount = ViewBag.TotalCount ?? 0;
    int startItem = totalCount > 0 ? (currentPage - 1) * pageSize + 1 : 0;
    int endItem = Math.Min(currentPage * pageSize, totalCount);
    bool hasPreviousPage = ViewBag.HasPreviousPage ?? false;
    bool hasNextPage = ViewBag.HasNextPage ?? false;

    // Xây dựng filter query string cho phân trang
    var filterParams = new System.Text.StringBuilder();
    if (ViewBag.CurrentFilterEmployeeId != null)
    {
        filterParams.Append($"&employeeId={ViewBag.CurrentFilterEmployeeId}");
    }
    if (ViewBag.CurrentFilterLeaveTypeId != null)
    {
        filterParams.Append($"&leaveTypeId={ViewBag.CurrentFilterLeaveTypeId}");
    }
    if (ViewBag.CurrentFilterStatus != null)
    {
        filterParams.Append($"&status={ViewBag.CurrentFilterStatus}");
    }
    string filterQuery = filterParams.ToString();
}

<div class="w-full flex flex-col font-geist">
    <!-- Section Header -->
    <div class="mb-6">
        <h2 class="text-[32px] font-bold text-black uppercase tracking-tight">Leave Requests</h2>
        <p class="text-[14px] text-[#4c4546]">View, track, and manage employee leave requests.</p>
    </div>

    <!-- Desktop Filter & Action Bar -->
    <div class="hidden lg:flex flex-row items-center justify-between gap-4 mb-4">
        <form method="get" action="/leave-request" class="flex items-center gap-3">
            @if (canApprove)
            {
                <div>
                    <label for="filterEmployee" class="sr-only">Employee</label>
                    <select id="filterEmployee" name="employeeId" class="h-10 bg-white border border-[#D1D1D1] px-3 font-mono text-[11px] focus:outline-none focus:border-black transition-colors">
                        <option value="">ALL EMPLOYEES</option>
                        @if (ViewBag.Employees != null)
                        {
                            foreach (var emp in (List<Domain.Employees.Employee>)ViewBag.Employees)
                            {
                                <!option value="@emp.Id.Value" selected="@(ViewBag.CurrentFilterEmployeeId == emp.Id.Value)">
                                    @emp.FullName (@emp.EmployeeCode)
                                </!option>
                            }
                        }
                    </select>
                </div>
            }
            <div>
                <label for="filterLeaveType" class="sr-only">Leave Type</label>
                <select id="filterLeaveType" name="leaveTypeId" class="h-10 bg-white border border-[#D1D1D1] px-3 font-mono text-[11px] focus:outline-none focus:border-black transition-colors">
                    <option value="">ALL LEAVE TYPES</option>
                    @if (ViewBag.LeaveTypes != null)
                    {
                        foreach (var lt in (List<Domain.LeaveTypes.LeaveType>)ViewBag.LeaveTypes)
                        {
                            <!option value="@lt.Id.Value" selected="@(ViewBag.CurrentFilterLeaveTypeId == lt.Id.Value)">
                                @lt.Name (@lt.Code)
                            </!option>
                        }
                    }
                </select>
            </div>
            <div>
                <label for="filterStatus" class="sr-only">Status</label>
                <select id="filterStatus" name="status" class="h-10 bg-white border border-[#D1D1D1] px-3 font-mono text-[11px] focus:outline-none focus:border-black transition-colors">
                    <option value="">ALL STATUSES</option>
                    <!option value="1" selected="@(ViewBag.CurrentFilterStatus == 1)">PENDING</!option>
                    <!option value="2" selected="@(ViewBag.CurrentFilterStatus == 2)">APPROVED</!option>
                    <!option value="3" selected="@(ViewBag.CurrentFilterStatus == 3)">REJECTED</!option>
                    <!option value="4" selected="@(ViewBag.CurrentFilterStatus == 4)">CANCELED</!option>
                </select>
            </div>
            <button type="submit" class="h-10 px-6 bg-[#F5F5F5] border border-[#D1D1D1] text-[11px] font-bold uppercase tracking-widest hover:bg-black hover:text-white transition-all cursor-pointer">Filter</button>
            <a href="/leave-request" class="text-[11px] font-bold text-[#4c4546] uppercase underline underline-offset-4 decoration-[#cfc4c5] hover:text-black transition-colors">Clear</a>
        </form>
        @if (canCreate)
        {
            <button type="button" data-modal-target="createLeaveRequestModal" data-modal-toggle="createLeaveRequestModal" class="h-10 px-8 bg-black text-white text-[11px] font-bold uppercase tracking-widest hover:opacity-90 transition-all cursor-pointer">
                Request Leave
            </button>
        }
    </div>

    <!-- Mobile Filter & Action Bar -->
    <div class="lg:hidden mb-4">
        <form method="get" action="/leave-request" class="flex flex-col gap-3">
            <div class="flex flex-col gap-2">
                @if (canApprove)
                {
                    <select id="filterEmployeeMobile" name="employeeId" class="h-10 bg-white border border-[#D1D1D1] px-3 font-mono text-[11px] focus:outline-none focus:border-black transition-colors w-full">
                        <option value="">ALL EMPLOYEES</option>
                        @if (ViewBag.Employees != null)
                        {
                            foreach (var emp in (List<Domain.Employees.Employee>)ViewBag.Employees)
                            {
                                <!option value="@emp.Id.Value" selected="@(ViewBag.CurrentFilterEmployeeId == emp.Id.Value)">
                                    @emp.FullName (@emp.EmployeeCode)
                                </!option>
                            }
                        }
                    </select>
                }
                <select name="leaveTypeId" class="h-10 bg-white border border-[#D1D1D1] px-3 font-mono text-[11px] focus:outline-none focus:border-black transition-colors w-full">
                    <option value="">ALL LEAVE TYPES</option>
                    @if (ViewBag.LeaveTypes != null)
                    {
                        foreach (var lt in (List<Domain.LeaveTypes.LeaveType>)ViewBag.LeaveTypes)
                        {
                            <!option value="@lt.Id.Value" selected="@(ViewBag.CurrentFilterLeaveTypeId == lt.Id.Value)">
                                @lt.Name (@lt.Code)
                            </!option>
                        }
                    }
                </select>
                <select name="status" class="h-10 bg-white border border-[#D1D1D1] px-3 font-mono text-[11px] focus:outline-none focus:border-black transition-colors w-full">
                    <option value="">ALL STATUSES</option>
                    <!option value="1" selected="@(ViewBag.CurrentFilterStatus == 1)">PENDING</!option>
                    <!option value="2" selected="@(ViewBag.CurrentFilterStatus == 2)">APPROVED</!option>
                    <!option value="3" selected="@(ViewBag.CurrentFilterStatus == 3)">REJECTED</!option>
                    <!option value="4" selected="@(ViewBag.CurrentFilterStatus == 4)">CANCELED</!option>
                </select>
            </div>
            <div class="flex items-stretch gap-0 border border-[#D1D1D1]">
                <button type="submit" class="flex-1 h-10 bg-[#F5F5F5] text-[11px] font-bold uppercase tracking-widest hover:bg-black hover:text-white transition-all cursor-pointer">Filter</button>
                <a href="/leave-request" class="flex-1 h-10 flex items-center justify-center text-[11px] font-bold text-[#4c4546] uppercase hover:bg-black hover:text-white transition-all border-l border-[#D1D1D1]">Clear</a>
            </div>
        </form>
        @if (canCreate)
        {
            <button type="button" data-modal-target="createLeaveRequestModal" data-modal-toggle="createLeaveRequestModal" class="w-full h-10 mt-3 bg-black text-white text-[11px] font-bold uppercase tracking-widest hover:opacity-90 transition-all cursor-pointer">
                Request Leave
            </button>
        }
    </div>

    <!-- Desktop Data Grid -->
    <div class="hidden lg:flex flex-col border border-[#D1D1D1] bg-white">
        <div class="overflow-x-auto w-full">
            <table class="w-full text-left border-collapse min-w-[1100px]" style="min-width: 1100px;">
            <thead class="bg-[#F5F5F5]">
                <tr class="border-b border-[#D1D1D1]">
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-12 text-center">No</th>
                    <th class="px-4 py-3 font-bold text-[11px] text-black uppercase border-r border-[#D1D1D1]">Employee</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1]">Leave Type</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] text-center">Period</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-24 text-center">Duration</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1]">Reason</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1] w-28 text-center">Status</th>
                    <th class="px-4 py-3 font-mono text-[10px] font-bold text-[#4c4546] uppercase border-r border-[#D1D1D1]">Process Info</th>
                    <th class="px-4 py-3 font-bold text-[10px] text-[#4c4546] uppercase w-32 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#D1D1D1]">
                @if (Model.Data == null || !Model.Data.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center py-8 text-[#4c4546] font-mono text-[11px] uppercase">
                            No leave requests found.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var lr in Model.Data.Select((val, index) => new { val, index = startItem + index }))
                    {
                        <tr class="hover:bg-[#f4f3f3] transition-colors">
                            <td class="px-4 py-3 font-mono text-[11px] font-bold border-r border-[#D1D1D1] text-center">@lr.index</td>
                            <td class="px-4 py-3 font-bold text-[12px] text-black border-r border-[#D1D1D1]">
                                @lr.val.EmployeeName
                                <span class="block font-mono text-[10px] text-[#4c4546]">@lr.val.EmployeeCode</span>
                            </td>
                            <td class="px-4 py-3 font-mono text-[11px] border-r border-[#D1D1D1]">@lr.val.LeaveTypeName</td>
                            <td class="px-4 py-3 font-mono text-[11px] border-r border-[#D1D1D1] text-center">
                                @lr.val.StartDate.ToString("dd/MM/yyyy") (@lr.val.StartDayPart) - @lr.val.EndDate.ToString("dd/MM/yyyy") (@lr.val.EndDayPart)
                            </td>
                            <td class="px-4 py-3 font-mono text-[11px] font-bold border-r border-[#D1D1D1] text-center">@lr.val.Duration.ToString("G29") Days</td>
                            <td class="px-4 py-3 text-[12px] border-r border-[#D1D1D1] max-w-xs truncate" title="@lr.val.Reason">@lr.val.Reason</td>
                            <td class="px-4 py-3 text-center border-r border-[#D1D1D1]">
                                @if (lr.val.Status == "Pending")
                                {
                                    <span class="px-2 py-0.5 font-mono text-[10px] font-bold bg-[#FFF9E6] border border-[#FFE8A3] text-[#7A5300] uppercase">Pending</span>
                                }
                                else if (lr.val.Status == "Approved")
                                {
                                    <span class="px-2 py-0.5 font-mono text-[10px] font-bold bg-[#E6F9F0] border border-[#A3EBD3] text-[#006644] uppercase">Approved</span>
                                }
                                else if (lr.val.Status == "Rejected")
                                {
                                    <span class="px-2 py-0.5 font-mono text-[10px] font-bold bg-[#FFF0F0] border border-[#FCA5A5] text-[#B91C1C] uppercase">Rejected</span>
                                }
                                else
                                {
                                    <span class="px-2 py-0.5 font-mono text-[10px] font-bold bg-[#F5F5F5] border border-[#D1D1D1] text-[#666666] uppercase">Canceled</span>
                                }
                            </td>
                            <td class="px-4 py-3 font-mono text-[11px] border-r border-[#D1D1D1] text-left">
                                @if (lr.val.Status != "Pending")
                                {
                                    <div class="text-[10px] text-gray-600">
                                        <p><span class="font-bold">By:</span> @(lr.val.ProcessedByName ?? "System/Self")</p>
                                        @if (lr.val.ProcessedAt.HasValue)
                                        {
                                            <p><span class="font-bold">At:</span> @lr.val.ProcessedAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                        }
                                        @if (!string.IsNullOrEmpty(lr.val.Comment))
                                        {
                                            <p class="italic text-gray-500">"@lr.val.Comment"</p>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-gray-400 italic text-[10px]">Waiting approval</span>
                                }
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap text-center">
                                <div class="flex justify-center space-x-3">
                                    <a href="/leave-request/detail/@lr.val.Id" class="text-[10px] font-bold text-black hover:text-[#E62429] uppercase underline decoration-[#cfc4c5] underline-offset-4 transition-colors">Details</a>
                                    @if (lr.val.Status == "Pending" && !canApprove)
                                    {
                                        <button type="button" data-modal-target="confirmCancel-@lr.val.Id" data-modal-toggle="confirmCancel-@lr.val.Id" class="text-[10px] font-bold text-[#E62429] hover:opacity-70 uppercase underline decoration-[#cfc4c5] underline-offset-4 cursor-pointer">
                                            Cancel
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        </div>

        <!-- Pagination Button Styles -->
        <style>
            .lr-page-btn {
                display:inline-block !important;
                padding:2px 12px !important;
                font-family:monospace !important;
                font-size:10px !important;
                font-weight:700 !important;
                text-transform:uppercase !important;
                text-decoration:none !important;
                border:1px solid #D1D1D1 !important;
                background:#fff !important;
                color:#000 !important;
                cursor:pointer !important;
            }
            .lr-page-btn:link, .lr-page-btn:visited, .lr-page-btn:active { color:#000 !important; text-decoration:none !important; }
            .lr-page-btn:hover, .lr-page-btn:hover:link, .lr-page-btn:hover:visited { background:#E0E0E0 !important; color:#000 !important; border-color:#999 !important; }
            .lr-page-btn-disabled {
                display:inline-block !important;
                padding:2px 12px !important;
                font-family:monospace !important;
                font-size:10px !important;
                font-weight:700 !important;
                text-transform:uppercase !important;
                border:1px solid #E0E0E0 !important;
                background:#F0F0F0 !important;
                color:#999 !important;
                cursor:not-allowed !important;
            }
            .lr-page-btn-mobile {
                display:inline-block !important;
                padding:6px 16px !important;
                font-family:monospace !important;
                font-size:10px !important;
                font-weight:700 !important;
                text-transform:uppercase !important;
                text-decoration:none !important;
                border:1px solid #D1D1D1 !important;
                background:#fff !important;
                color:#000 !important;
                cursor:pointer !important;
            }
            .lr-page-btn-mobile:link, .lr-page-btn-mobile:visited, .lr-page-btn-mobile:active { color:#000 !important; text-decoration:none !important; }
            .lr-page-btn-mobile:hover, .lr-page-btn-mobile:hover:link, .lr-page-btn-mobile:hover:visited { background:#E0E0E0 !important; color:#000 !important; border-color:#999 !important; }
            .lr-page-btn-mobile-disabled {
                display:inline-block !important;
                padding:6px 16px !important;
                font-family:monospace !important;
                font-size:10px !important;
                font-weight:700 !important;
                text-transform:uppercase !important;
                border:1px solid #E0E0E0 !important;
                background:#F0F0F0 !important;
                color:#999 !important;
                cursor:not-allowed !important;
            }
        </style>

        <!-- Desktop Table Footer with Pagination -->
        <div class="flex items-center justify-between px-4 py-3 border-t border-[#D1D1D1] bg-[#F5F5F5]">
            <div class="font-mono text-[10px] font-bold text-[#4c4546] uppercase">
                SHOWING @startItem–@endItem OF @totalCount LEAVE REQUESTS
            </div>
            @if (totalPages > 1)
            {
                <div class="flex items-center gap-2">
                    @if (hasPreviousPage)
                    {
                        <a href="/leave-request?page=@(currentPage - 1)@filterQuery" class="lr-page-btn">PREV</a>
                    }
                    else
                    {
                        <span class="lr-page-btn-disabled">PREV</span>
                    }
                    <span class="px-3 py-1 font-mono text-[10px] font-bold text-black uppercase">
                        PAGE @currentPage OF @totalPages
                    </span>
                    @if (hasNextPage)
                    {
                        <a href="/leave-request?page=@(currentPage + 1)@filterQuery" class="lr-page-btn">NEXT</a>
                    }
                    else
                    {
                        <span class="lr-page-btn-disabled">NEXT</span>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Mobile Stacked Cards -->
    <div class="lg:hidden flex flex-col gap-4 pb-24">
        @if (Model.Data == null || !Model.Data.Any())
        {
            <div class="bg-white border border-[#D1D1D1] p-6 text-center">
                <p class="font-mono text-[11px] text-[#4c4546] uppercase">No leave requests found.</p>
            </div>
        }
        else
        {
            <div class="flex flex-col gap-4">
                @foreach (var lr in Model.Data)
                {
                    <div class="bg-white border border-[#D1D1D1] p-4 flex flex-col gap-3">
                        <!-- Card Header -->
                        <div class="flex justify-between items-start">
                            <div class="flex flex-col">
                                <span class="font-mono text-[10px] text-[#4c4546] font-bold">@lr.EmployeeCode</span>
                                <h3 class="text-[16px] font-bold uppercase tracking-tight">@lr.EmployeeName</h3>
                            </div>
                            <!-- Status Badge -->
                            @if (lr.Status == "Pending")
                            {
                                <span class="px-2 py-0.5 font-mono text-[10px] font-bold bg-[#FFF9E6] border border-[#FFE8A3] text-[#7A5300] uppercase">Pending</span>
                            }
                            else if (lr.Status == "Approved")
                            {
                                <span class="px-2 py-0.5 font-mono text-[10px] font-bold bg-[#E6F9F0] border border-[#A3EBD3] text-[#006644] uppercase">Approved</span>
                            }
                            else if (lr.Status == "Rejected")
                            {
                                <span class="px-2 py-0.5 font-mono text-[10px] font-bold bg-[#FFF0F0] border border-[#FCA5A5] text-[#B91C1C] uppercase">Rejected</span>
                            }
                            else
                            {
                                <span class="px-2 py-0.5 font-mono text-[10px] font-bold bg-[#F5F5F5] border border-[#D1D1D1] text-[#666666] uppercase">Canceled</span>
                            }
                        </div>

                        <!-- Card Body -->
                        <div class="border-t border-[#F1F1F1] pt-3 grid grid-cols-2 gap-y-2 gap-x-4">
                            <div class="flex flex-col col-span-2">
                                <span class="font-mono text-[9px] text-[#4c4546] uppercase">Leave Type</span>
                                <span class="font-bold text-[12px]">@lr.LeaveTypeName</span>
                            </div>
                            <div class="flex flex-col col-span-2">
                                <span class="font-mono text-[9px] text-[#4c4546] uppercase">Period</span>
                                <span class="font-medium text-[11px] text-gray-700">
                                    @lr.StartDate.ToString("dd/MM/yyyy") (@lr.StartDayPart) - @lr.EndDate.ToString("dd/MM/yyyy") (@lr.EndDayPart)
                                </span>
                            </div>
                            <div class="flex flex-col">
                                <span class="font-mono text-[9px] text-[#4c4546] uppercase">Duration</span>
                                <span class="font-bold text-[12px]">@lr.Duration.ToString("G29") Days</span>
                            </div>
                            @if (!string.IsNullOrEmpty(lr.Reason))
                            {
                                <div class="flex flex-col col-span-2">
                                    <span class="font-mono text-[9px] text-[#4c4546] uppercase">Reason</span>
                                    <p class="text-[11px] text-gray-700 max-w-full truncate" title="@lr.Reason">@lr.Reason</p>
                                </div>
                            }
                            
                            @if (lr.Status != "Pending")
                            {
                                <div class="flex flex-col col-span-2 bg-[#F9F9F9] p-2 border border-[#EBEBEB]">
                                    <span class="font-mono text-[9px] text-[#4c4546] uppercase mb-1">Process Info</span>
                                    <p class="text-[10px] text-gray-600"><span class="font-bold">By:</span> @(lr.ProcessedByName ?? "System/Self")</p>
                                    @if (lr.ProcessedAt.HasValue)
                                    {
                                        <p class="text-[10px] text-gray-600"><span class="font-bold">At:</span> @lr.ProcessedAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                    }
                                    @if (!string.IsNullOrEmpty(lr.Comment))
                                    {
                                        <p class="text-[10px] text-gray-500 italic mt-1">"@lr.Comment"</p>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="flex flex-col col-span-2">
                                    <span class="font-mono text-[9px] text-[#4c4546] uppercase">Process Info</span>
                                    <span class="text-[11px] text-gray-400 italic">Waiting approval</span>
                                </div>
                            }
                        </div>

                        <!-- Card Actions -->
                        <div class="flex gap-4 border-t border-[#F1F1F1] pt-3 items-center">
                            <a href="/leave-request/detail/@lr.Id" class="text-[10px] font-bold text-black hover:text-[#E62429] uppercase underline decoration-[#cfc4c5] underline-offset-4 transition-colors">Details</a>
                            @if (lr.Status == "Pending" && !canApprove)
                            {
                                <button type="button" data-modal-target="confirmCancel-@lr.Id" data-modal-toggle="confirmCancel-@lr.Id" class="ml-auto text-[#E62429] text-[10px] font-bold uppercase hover:opacity-70 transition-opacity cursor-pointer">
                                    [CANCEL]
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Mobile Footer with Pagination -->
            <div class="mt-2 border border-[#D1D1D1] bg-white p-4 font-mono text-[11px]">
                <div class="text-center font-bold text-black uppercase mb-3">
                    SHOWING @startItem–@endItem OF @totalCount LEAVE REQUESTS
                </div>
                @if (totalPages > 1)
                {
                    <div class="flex items-center justify-center gap-2">
                        @if (hasPreviousPage)
                        {
                            <a href="/leave-request?page=@(currentPage - 1)@filterQuery" class="lr-page-btn-mobile">PREV</a>
                        }
                        else
                        {
                            <span class="lr-page-btn-mobile-disabled">PREV</span>
                        }
                        <span class="px-3 py-2 font-mono text-[10px] font-bold text-black uppercase">
                            @currentPage / @totalPages
                        </span>
                        @if (hasNextPage)
                        {
                            <a href="/leave-request?page=@(currentPage + 1)@filterQuery" class="lr-page-btn-mobile">NEXT</a>
                        }
                        else
                        {
                            <span class="lr-page-btn-mobile-disabled">NEXT</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Modal Container (rendered outside tables/cards to avoid hierarchy breakage) -->
@if (canCreate)
{
    @Html.Partial("_CreateLeaveRequestPartial")
}

@if (Model.Data != null)
{
    @foreach (var lr in Model.Data)
    {
        @if (lr.Status == "Pending" && !canApprove)
        {
            @Html.Partial("_ConfirmCancelPartial", lr)
        }
    }
}

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const form = document.getElementById("createLeaveRequestForm");
        if (form) {
            form.addEventListener("submit", function(e) {
                e.preventDefault();
                const formData = new FormData(form);
                
                fetch("/leave-request/create", {
                    method: "POST",
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, true);
                        window.location.reload();
                    } else {
                        showToast("Error: " + data.message, false);
                    }
                })
                .catch(err => {
                    console.error(err);
                    showToast("An error occurred while submitting the leave request.", false);
                });
            });
        }
    });

    function cancelLeaveRequest(id) {
        const formData = new FormData();
        formData.append("id", id);
        
        // Get anti-forgery token if available
        const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenElement) {
            formData.append("__RequestVerificationToken", tokenElement.value);
        }

        fetch("/leave-request/cancel", {
            method: "POST",
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast(data.message, true);
                window.location.reload();
            } else {
                showToast("Error: " + data.message, false);
            }
        })
        .catch(err => {
            console.error(err);
            showToast("An error occurred while canceling the leave request.", false);
        });
    }
</script>
