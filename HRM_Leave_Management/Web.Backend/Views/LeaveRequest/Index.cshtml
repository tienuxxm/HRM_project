@model List<Application.LeaveRequests.Get.LeaveRequestResponse>

@{
    ViewBag.Title = "Leave Request Management";
    Layout = "_Layout";
    bool canApprove = ViewBag.CanApprove ?? false;
    bool canCreate = ViewBag.CanCreate ?? false;
}

<div class="w-full">
    <div class="w-full flex flex-col">
        <!-- Breadcrumb -->
        <nav class="flex" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">
                        <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                            <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
                        </svg>
                    </a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                        </svg>
                        <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Leave Management</span>
                    </div>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                        </svg>
                        <a href="#" class="ml-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ml-2 dark:text-gray-400 dark:hover:text-white">Leave Requests</a>
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Main Card -->
        <div style="min-height: 543px" class="bg-white w-full p-4 rounded-lg mt-5 flex flex-col justify-between">
            <div class="w-full">
                <!-- Filters and Add Button Header -->
                <div class="flex flex-col md:flex-row md:items-center md:justify-between pb-4 border-b border-gray-200">
                    <form method="get" action="/leave-request" class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                        @if (canApprove)
                        {
                            <!-- Employee Filter (Only for Admin/HR) -->
                            <div>
                                <label for="filterEmployee" class="sr-only">Employee</label>
                                <select id="filterEmployee" name="employeeId" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2">
                                    <option value="">All Employees</option>
                                    @if (ViewBag.Employees != null)
                                    {
                                        foreach (var emp in (List<Domain.Employees.Employee>)ViewBag.Employees)
                                        {
                                            <option value="@emp.Id.Value" selected="@(ViewBag.CurrentFilterEmployeeId == emp.Id.Value)">
                                                @emp.FullName (@emp.EmployeeCode)
                                            </option>
                                        }
                                    }
                                </select>
                            </div>
                        }

                        <!-- Leave Type Filter -->
                        <div>
                            <label for="filterLeaveType" class="sr-only">Leave Type</label>
                            <select id="filterLeaveType" name="leaveTypeId" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2">
                                <option value="">All Leave Types</option>
                                @if (ViewBag.LeaveTypes != null)
                                {
                                    foreach (var lt in (List<Domain.LeaveTypes.LeaveType>)ViewBag.LeaveTypes)
                                    {
                                        <option value="@lt.Id.Value" selected="@(ViewBag.CurrentFilterLeaveTypeId == lt.Id.Value)">
                                            @lt.Name (@lt.Code)
                                        </option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Status Filter -->
                        <div>
                            <label for="filterStatus" class="sr-only">Status</label>
                            <select id="filterStatus" name="status" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2">
                                <option value="">All Statuses</option>
                                <option value="1" selected="@(ViewBag.CurrentFilterStatus == 1)">Pending</option>
                                <option value="2" selected="@(ViewBag.CurrentFilterStatus == 2)">Approved</option>
                                <option value="3" selected="@(ViewBag.CurrentFilterStatus == 3)">Rejected</option>
                                <option value="4" selected="@(ViewBag.CurrentFilterStatus == 4)">Canceled</option>
                            </select>
                        </div>

                        <button type="submit" class="inline-flex items-center rounded bg-gray-100 border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200">
                            Filter
                        </button>
                        <a href="/leave-request" class="inline-flex items-center text-sm font-medium text-blue-600 hover:underline">
                            Clear
                        </a>
                    </form>

                    @if (canCreate)
                    {
                        <div class="mt-3 md:mt-0 flex justify-end">
                            <button type="button" data-modal-target="createLeaveRequestModal" data-modal-toggle="createLeaveRequestModal"
                                    class="inline-block rounded bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:scale-105 hover:shadow-xl focus:outline-none focus:ring active:bg-indigo-500">
                                Request Leave
                            </button>
                            @Html.Partial("_CreateLeaveRequestPartial")
                        </div>
                    }
                </div>

                <!-- Table Content -->
                <div class="overflow-x-auto w-full h-full mt-4">
                    <table class="min-w-full divide-y-2 divide-gray-200 text-sm">
                        <thead class="ltr:text-left rtl:text-right bg-[#F4F7FC]">
                            <tr>
                                <th class="whitespace-nowrap px-4 py-3 font-medium text-black text-center w-12">No</th>
                                <th class="whitespace-nowrap px-4 py-3 font-medium text-black text-left">Employee</th>
                                <th class="whitespace-nowrap px-4 py-3 font-medium text-black text-left">Leave Type</th>
                                <th class="whitespace-nowrap px-4 py-3 font-medium text-black text-center">Period</th>
                                <th class="whitespace-nowrap px-4 py-3 font-medium text-black text-center w-24">Duration</th>
                                <th class="whitespace-nowrap px-4 py-3 font-medium text-black text-left">Reason</th>
                                <th class="whitespace-nowrap px-4 py-3 font-medium text-black text-center w-28">Status</th>
                                <th class="whitespace-nowrap px-4 py-3 font-medium text-black text-left">Process Info</th>
                                <th class="whitespace-nowrap px-4 py-3 font-medium text-black text-center w-32">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center py-8 text-gray-500 font-medium">
                                        No leave requests found.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var lr in Model.Select((val, index) => new { val, index = index + 1 }))
                                {
                                    <tr class="hover:bg-gray-50 transition duration-150">
                                        <td class="whitespace-nowrap px-4 py-3 font-medium text-gray-950 text-center">
                                            @lr.index.ToString()
                                        </td>
                                        <td class="whitespace-nowrap px-4 py-3 text-gray-950 font-semibold text-left">
                                            @lr.val.EmployeeName (@lr.val.EmployeeCode)
                                        </td>
                                        <td class="whitespace-nowrap px-4 py-3 text-gray-900 text-left">
                                            @lr.val.LeaveTypeName
                                        </td>
                                        <td class="whitespace-nowrap px-4 py-3 text-gray-700 text-center font-medium">
                                            @lr.val.StartDate.ToString("dd/MM/yyyy") (@lr.val.StartDayPart) - @lr.val.EndDate.ToString("dd/MM/yyyy") (@lr.val.EndDayPart)
                                        </td>
                                        <td class="whitespace-nowrap px-4 py-3 text-gray-700 text-center font-bold">
                                            @lr.val.Duration.ToString("G29") Days
                                        </td>
                                        <td class="px-4 py-3 text-gray-700 text-left max-w-xs truncate" title="@lr.val.Reason">
                                            @lr.val.Reason
                                        </td>
                                        <td class="whitespace-nowrap px-4 py-3 text-center">
                                            @if (lr.val.Status == "Pending")
                                            {
                                                <span class="inline-flex items-center rounded-full bg-yellow-50 px-2 py-1 text-xs font-semibold text-yellow-800 ring-1 ring-inset ring-yellow-600/20">Pending</span>
                                            }
                                            else if (lr.val.Status == "Approved")
                                            {
                                                <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-semibold text-green-800 ring-1 ring-inset ring-green-600/20">Approved</span>
                                            }
                                            else if (lr.val.Status == "Rejected")
                                            {
                                                <span class="inline-flex items-center rounded-full bg-red-50 px-2 py-1 text-xs font-semibold text-red-800 ring-1 ring-inset ring-red-600/20">Rejected</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center rounded-full bg-gray-50 px-2 py-1 text-xs font-semibold text-gray-600 ring-1 ring-inset ring-gray-500/10">Canceled</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 text-gray-600 text-left text-xs">
                                            @if (lr.val.Status != "Pending")
                                            {
                                                <div>
                                                    <p><span class="font-medium">By:</span> @(lr.val.ProcessedByName ?? "System/Self")</p>
                                                    @if (lr.val.ProcessedAt.HasValue)
                                                    {
                                                        <p><span class="font-medium">At:</span> @lr.val.ProcessedAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                                    }
                                                    @if (!string.IsNullOrEmpty(lr.val.Comment))
                                                    {
                                                        <p class="italic text-gray-500">"@lr.val.Comment"</p>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-gray-400 italic">Waiting approval</span>
                                            }
                                        </td>
                                        <td class="whitespace-nowrap px-4 py-3 text-gray-700 text-center">
                                            <div class="flex justify-center items-center gap-3">
                                                @if (lr.val.Status == "Pending" && !canApprove)
                                                {
                                                    <!-- Chỉ Employee tự huỷ đơn của chính mình khi trạng thái Pending -->
                                                    <button type="button" data-modal-target="confirmCancel-@lr.val.Id" data-modal-toggle="confirmCancel-@lr.val.Id" class="inline-flex items-center rounded bg-red-50 px-2 py-1 text-xs font-semibold text-red-600 ring-1 ring-inset ring-red-600/20 hover:bg-red-100 transition duration-150 cursor-pointer">
                                                        Cancel
                                                    </button>
                                                    @Html.Partial("_ConfirmCancelPartial", lr.val)
                                                }
                                                else
                                                {
                                                    <span class="text-gray-400 text-xs italic">-</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const form = document.getElementById("createLeaveRequestForm");
        if (form) {
            form.addEventListener("submit", function(e) {
                e.preventDefault();
                const formData = new FormData(form);
                
                fetch("/leave-request/create", {
                    method: "POST",
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert(data.message);
                        window.location.reload();
                    } else {
                        alert("Lỗi: " + data.message);
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert("Có lỗi xảy ra trong quá trình gửi đơn nghỉ phép.");
                });
            });
        }
    });

    function cancelLeaveRequest(id) {
        const formData = new FormData();
        formData.append("id", id);
        
        // Lấy token nếu có
        const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenElement) {
            formData.append("__RequestVerificationToken", tokenElement.value);
        }

        fetch("/leave-request/cancel", {
            method: "POST",
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                window.location.reload();
            } else {
                alert("Lỗi: " + data.message);
            }
        })
        .catch(err => {
            console.error(err);
            alert("Có lỗi xảy ra khi hủy đơn nghỉ phép.");
        });
    }
</script>
