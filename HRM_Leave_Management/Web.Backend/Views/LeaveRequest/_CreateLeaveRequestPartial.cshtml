<div id="createLeaveRequestModal" tabindex="-1" aria-hidden="true" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal Panel -->
        <div class="w-full max-w-[600px] bg-white border border-black rounded-none shadow-none flex flex-col max-h-[90vh] overflow-hidden relative">
            <!-- Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white shrink-0">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">SUBMIT LEAVE REQUEST</span>
                <button type="button" class="bg-[#E62429] w-8 h-8 flex items-center justify-center hover:bg-[#c51f24] transition-colors cursor-pointer" data-modal-hide="createLeaveRequestModal">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Body wrapper using form -->
            <form id="createLeaveRequestForm" class="flex flex-col flex-1 min-h-0">
                @Html.AntiForgeryToken()
                <!-- Scrollable Body -->
                <div class="p-6 flex flex-col gap-4 text-left font-geist overflow-y-auto">
                    <!-- Leave Type -->
                    <div>
                        <label for="leaveTypeId" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Leave Type <span class="text-[#E62429]">*</span></label>
                        <select id="leaveTypeId" name="LeaveTypeId" required class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors rounded-none">
                            <option value="">Select Leave Type</option>
                            @if (ViewBag.LeaveTypes != null)
                            {
                                foreach (var lt in (List<Domain.LeaveTypes.LeaveType>)ViewBag.LeaveTypes)
                                {
                                    <option value="@lt.Id.Value">@lt.Name (@lt.Code)</option>
                                }
                            }
                        </select>
                    </div>
                    <!-- Dates -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="startDate" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Start Date <span class="text-[#E62429]">*</span></label>
                            <input type="date" id="startDate" name="StartDate" required class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors rounded-none">
                        </div>
                        <div>
                            <label for="endDate" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">End Date <span class="text-[#E62429]">*</span></label>
                            <input type="date" id="endDate" name="EndDate" required class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors rounded-none">
                        </div>
                    </div>
                    <!-- Sessions -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="startDayPart" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Start Session</label>
                            <select id="startDayPart" name="StartDayPart" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors rounded-none">
                                <option value="1">Full Day</option>
                                <option value="2">Morning</option>
                                <option value="3">Afternoon</option>
                            </select>
                        </div>
                        <div>
                            <label for="endDayPart" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">End Session</label>
                            <select id="endDayPart" name="EndDayPart" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors rounded-none">
                                <option value="1">Full Day</option>
                                <option value="2">Morning</option>
                                <option value="3">Afternoon</option>
                            </select>
                        </div>
                    </div>
                    <!-- Reason -->
                    <div>
                        <label for="reason" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Reason <span class="text-[#E62429]">*</span></label>
                        <textarea id="reason" name="Reason" rows="3" required placeholder="Describe your reason for leave..." class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] focus:outline-none focus:border-black transition-colors resize-none rounded-none"></textarea>
                    </div>
                </div>
                <!-- Footer -->
                <div class="h-16 flex items-center justify-end gap-3 px-6 bg-[#FBFBFB] border-t border-[#D1D1D1] shrink-0">
                    <button type="button" data-modal-hide="createLeaveRequestModal" class="bg-white text-black border border-black px-5 py-2.5 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-gray-100 transition-colors rounded-none cursor-pointer">
                        CANCEL
                    </button>
                    <button type="submit" class="bg-black text-white border border-black px-5 py-2.5 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-gray-800 transition-all rounded-none cursor-pointer">
                        SUBMIT
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
