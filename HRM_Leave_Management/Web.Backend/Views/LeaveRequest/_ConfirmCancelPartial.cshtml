@model Application.LeaveRequests.Get.LeaveRequestResponse
<div id="confirmCancel-@Model.Id" tabindex="-1" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal Panel -->
        <div class="w-full max-w-[480px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white shrink-0">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">CANCEL LEAVE REQUEST</span>
                <button type="button" class="bg-[#E62429] w-8 h-8 flex items-center justify-center hover:bg-[#c51f24] transition-colors cursor-pointer" data-modal-hide="confirmCancel-@Model.Id">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Body -->
            <div class="p-6 text-center font-geist flex flex-col items-center">
                <svg class="mb-4 text-black w-12 h-12" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                    <path stroke="currentColor" stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M10 11V6m0 8h.01M19 10a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
                <h3 class="mb-5 text-[14px] text-black text-wrap leading-relaxed">
                    Are you sure you want to cancel the leave request <strong>@Model.LeaveTypeName</strong> (@Model.Duration.ToString("G29") days, from @Model.StartDate.ToString("dd/MM/yyyy") to @Model.EndDate.ToString("dd/MM/yyyy"))?
                </h3>
            </div>
            <!-- Footer -->
            <div class="h-16 flex items-center justify-end gap-3 px-6 bg-[#FBFBFB] border-t border-[#D1D1D1] shrink-0">
                <button data-modal-hide="confirmCancel-@Model.Id" type="button" class="bg-white text-black border border-black px-5 py-2.5 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-gray-100 transition-colors rounded-none cursor-pointer">
                    CANCEL
                </button>
                <button data-modal-hide="confirmCancel-@Model.Id" type="button" onclick="cancelLeaveRequest('@Model.Id')" class="bg-[#E62429] text-white border border-[#E62429] px-5 py-2.5 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#c51f24] transition-all rounded-none cursor-pointer">
                    CONFIRM
                </button>
            </div>
        </div>
    </div>
</div>
