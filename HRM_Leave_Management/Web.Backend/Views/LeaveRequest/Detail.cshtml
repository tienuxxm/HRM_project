@model Application.LeaveRequests.Get.LeaveRequestResponse

@{
    ViewBag.Title = "Leave Request Details";
    Layout = "_Layout";

    dynamic audit = ViewBag.ReopenAudit;
}

<style>
    /* === Scoped CSS for Detail.cshtml — Enterprise Calm / Swiss International === */

    /* Wrapper rộng hơn, không margin auto để bám lề tự nhiên */
    .detail-wrapper {
        max-width: 1200px;
        width: 100%;
        padding: 0.5rem 0;
    }

    /* Grid chia 2 cột tỉ lệ 1/3 và 2/3 (4:8) chuẩn Stitch */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @@media (min-width: 1024px) {
        .detail-grid {
            grid-template-columns: 1fr 2fr;
            gap: 1.5rem;
        }
    }

    /* Labels và Typography Thụy Sĩ */
    .detail-label {
        font-size: 10px;
        color: #4c4546;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        line-height: 1.2;
    }

    .detail-section-title {
        font-size: 12px;
        font-weight: 600;
        color: #4c4546;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1px solid #cfc4c5;
        padding-bottom: 0.5rem;
        margin-bottom: 1rem;
    }

    /* Card và Viền vuông góc */
    .detail-card {
        border: 1px solid #cfc4c5;
        background-color: #ffffff;
        padding: 1rem;
    }

    .border-thin {
        border: 1px solid #cfc4c5;
    }

    /* Case File Title & Trạng thái */
    .detail-header-section {
        border-bottom: 2px solid #000000;
        padding-bottom: 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    @@media (min-width: 768px) {
        .detail-header-section {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }

    .header-actions {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.75rem;
    }

    .detail-case-title {
        font-size: 24px;
        font-weight: 700;
        color: #000000;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }
    @@media (min-width: 768px) {
        .detail-case-title {
            font-size: 36px;
        }
    }

    .detail-case-id {
        font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        color: #000000;
    }

    /* Status Badges phẳng không bo góc */
    .badge-status {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 0.5rem 1rem;
        border: 1px solid #000000;
        display: inline-block;
    }
    .badge-pending {
        background-color: #000000;
        color: #ffffff;
    }
    .badge-approved {
        background-color: #ffffff;
        color: #000000;
    }
    .badge-rejected {
        background-color: #E62429;
        color: #ffffff;
        border-color: #E62429;
    }

    /* Nút BACK TO LIST */
    .btn-back {
        font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #000000;
        background-color: #ffffff;
        border: 1px solid #cfc4c5;
        padding: 0.5rem 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        text-decoration: none;
        white-space: nowrap;
        min-width: 150px;
        transition: all 0.15s ease;
    }
    .btn-back:hover {
        border-color: #000000;
        background-color: #faf9f9;
        color: #000000;
    }

    /* Audit Warning */
    .audit-warning {
        border: 1px solid #E62429;
        border-left: 4px solid #E62429;
        background-color: #fdf2f2;
        padding: 1rem;
        display: flex;
        gap: 0.75rem;
        align-items: start;
        margin-bottom: 1.5rem;
    }

    /* Decision Panel */
    .decision-panel {
        border: 2px solid #000000;
        background-color: #ffffff;
    }

    .decision-hdr {
        background-color: #000000;
        color: #ffffff;
        padding: 0.75rem 1rem;
    }

    .decision-hdr-title {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .decision-body {
        padding: 1.25rem;
        background-color: #ffffff;
    }

    .decision-textarea {
        width: 100%;
        border: 1px solid #cfc4c5;
        background-color: #faf9f9;
        color: #000000;
        font-size: 16px;
        padding: 0.75rem;
        resize: none;
    }
    .decision-textarea:focus {
        outline: none;
        border-color: #000000;
        box-shadow: none;
    }

    .btn-action {
        flex: 1;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.15s ease;
        border: 1px solid transparent;
        cursor: pointer;
    }

    .btn-approve {
        background-color: #000000;
        color: #ffffff;
        border-color: #000000;
    }
    .btn-approve:hover {
        background-color: #ffffff;
        color: #000000;
    }

    .btn-reject {
        background-color: #E62429;
        color: #ffffff;
        border-color: #E62429;
    }
    .btn-reject:hover {
        background-color: #ffffff;
        color: #E62429;
    }

    /* Particulars List (Mobile nhãn trái - giá trị phải) */
    .particulars-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .particulars-item {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0;
        border-bottom: 1px solid #cfc4c5;
    }
    .particulars-item:last-child {
        border-bottom: none;
    }

    @@media (min-width: 768px) {
        .particulars-item {
            flex-direction: column;
            align-items: flex-start;
            border-bottom: none;
            border-top: 1px solid #cfc4c5;
            padding: 0.75rem 0 0 0;
            margin-top: 0.75rem;
        }
        .particulars-item:first-child {
            border-top: none;
            padding-top: 0;
            margin-top: 0;
        }
    }
</style>

<div class="detail-wrapper">
    <!-- Case File Header -->
    <section class="detail-header-section">
        <div>
            <h1 class="detail-case-title">
                CASE FILE: <span class="detail-case-id">#@Model.Id</span>
            </h1>
        </div>
        <div class="header-actions">
            @if (Model.Status == "Pending")
            {
                <span class="badge-status badge-pending">Pending</span>
            }
            else if (Model.Status == "Approved")
            {
                <span class="badge-status badge-approved">Approved</span>
            }
            else if (Model.Status == "Rejected")
            {
                <span class="badge-status badge-rejected">Rejected</span>
            }
            else
            {
                <span class="badge-status bg-gray-100 text-black">@Model.Status</span>
            }

            <a href="/leave-request" class="btn-back">
                <span class="material-symbols-outlined text-xs">arrow_back</span>
                BACK TO LIST
            </a>
        </div>
    </section>

    <!-- Bento Layout -->
    <div class="detail-grid">

        <!-- LEFT RAIL (Employee + History) -->
        <div class="flex flex-col gap-6">

            <!-- Employee Particulars -->
            <section class="detail-card">
                <h3 class="detail-section-title">Employee Particulars</h3>
                <div class="particulars-list">
                    <div class="particulars-item">
                        <span class="detail-label">Name</span>
                        <span class="text-sm font-semibold text-black">@Model.EmployeeName</span>
                    </div>
                    <div class="particulars-item">
                        <span class="detail-label">ID (Code)</span>
                        <span class="text-sm font-mono font-medium text-black">@Model.EmployeeCode</span>
                    </div>
                </div>
            </section>

            <!-- Processing History -->
            @if (Model.Status != "Pending")
            {
                <section class="detail-card">
                    <h3 class="detail-section-title">Processing History</h3>
                    <table class="w-full text-left border-collapse text-xs">
                        <tbody>
                            <tr class="border-b border-gray-200">
                                <th class="py-2 font-normal text-gray-500 uppercase w-1/3 align-top">Processed By:</th>
                                <td class="py-2 font-medium text-black align-top">@(Model.ProcessedByName ?? "System")</td>
                            </tr>
                            <tr class="border-b border-gray-200">
                                <th class="py-2 font-normal text-gray-500 uppercase align-top">Date:</th>
                                <td class="py-2 font-mono text-black align-top">@(Model.ProcessedAt.HasValue ? Model.ProcessedAt.Value.ToString("dd MMM yyyy HH:mm") : "—")</td>
                            </tr>
                            <tr>
                                <th class="py-2 font-normal text-gray-500 uppercase align-top">Comment:</th>
                                <td class="py-2 text-black align-top italic">
                                    @if (!string.IsNullOrWhiteSpace(Model.Comment))
                                    {
                                        @Model.Comment
                                    }
                                    else
                                    {
                                        <span class="text-gray-400">No comment provided.</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </section>
            }
        </div>

        <!-- RIGHT CONTENT -->
        <div class="flex flex-col gap-6">

            <!-- Audit Warning -->
            @if (audit != null)
            {
                <section class="audit-warning">
                    <span class="material-symbols-outlined text-[#E62429] text-lg">warning</span>
                    <div class="flex flex-col">
                        <span class="detail-label text-[#E62429] font-bold">Audit Warning</span>
                        <p class="text-sm text-black mt-1 leading-snug">
                            This request was recalculated because calendar changes affected your dates.
                            Old approved duration was <span class="font-mono font-semibold">@audit.OldDuration.ToString("G29") days</span>.
                            Please review and resubmit.
                        </p>
                    </div>
                </section>
            }

            <!-- Leave Particulars -->
            <section class="border-thin bg-white flex flex-col">
                <div class="p-4 border-b border-thin bg-gray-50">
                    <h3 class="detail-label font-bold text-xs tracking-wider">Leave Particulars</h3>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2">
                    <!-- Type -->
                    <div class="p-4 border-b md:border-b-0 md:border-r border-thin flex flex-col gap-1">
                        <span class="detail-label">Type</span>
                        <span class="text-lg font-semibold text-black">@Model.LeaveTypeName</span>
                    </div>
                    <!-- Duration -->
                    <div class="p-4 flex items-center justify-between border-b border-thin md:border-b-0">
                        <div class="flex flex-col gap-1">
                            <span class="detail-label">Duration</span>
                            <span class="text-lg font-mono font-semibold text-black">
                                @Model.Duration.ToString("G29")
                                <span class="font-sans text-sm font-normal text-gray-500">days</span>
                            </span>
                        </div>
                    </div>
                </div>
                <!-- Dates & Reason -->
                <div class="border-t border-thin grid grid-cols-1 md:grid-cols-2">
                    <!-- Dates -->
                    <div class="p-4 border-b md:border-b-0 md:border-r border-thin flex flex-col gap-2 justify-center">
                        <span class="detail-label">Dates</span>
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="font-mono text-sm bg-gray-100 px-2 py-1 text-black">
                                @Model.StartDate.ToString("dd MMM yyyy").ToUpper()
                                <span class="text-xs font-sans text-gray-500">(@Model.StartDayPart)</span>
                            </span>
                            <span class="material-symbols-outlined text-gray-400 text-sm">arrow_right_alt</span>
                            <span class="font-mono text-sm bg-gray-100 px-2 py-1 text-black">
                                @Model.EndDate.ToString("dd MMM yyyy").ToUpper()
                                <span class="text-xs font-sans text-gray-500">(@Model.EndDayPart)</span>
                            </span>
                        </div>
                    </div>
                    <!-- Reason -->
                    <div class="p-4 flex flex-col gap-1">
                        <span class="detail-label">Reason provided</span>
                        <p class="text-sm text-black leading-relaxed whitespace-pre-line mt-1" style="font-size:0.8125rem;">
                            @if (string.IsNullOrWhiteSpace(Model.Reason))
                            {
                                <span class="italic text-gray-400">No reason provided.</span>
                            }
                            else
                            {
                                @Model.Reason
                            }
                        </p>
                    </div>
                </div>
            </section>

            <!-- Official Decision Panel -->
            @if (Model.Status == "Pending" && Model.CanApprove)
            {
                <div class="decision-panel flex flex-col">
                    <div class="decision-hdr">
                        <h3 class="decision-hdr-title">
                            <span class="material-symbols-outlined text-sm">gavel</span>
                            Official Decision Panel
                        </h3>
                    </div>
                    <div class="decision-body">
                        <form id="approvalForm" class="flex flex-col gap-4 w-full">
                            <input type="hidden" id="leaveRequestId" value="@Model.Id" name="id" />
                            <div class="flex flex-col gap-2">
                                <label for="approvalComment" class="detail-label">
                                    Approver Comment <span class="text-[#E62429]">(Required for rejection)</span>
                                </label>
                                <textarea id="approvalComment" name="comment" rows="3"
                                          class="decision-textarea"
                                          placeholder="Enter formal notation here..."></textarea>
                            </div>
                            <div class="flex flex-col sm:flex-row gap-4 pt-2">
                                <button type="button" onclick="submitApproval('approve')" class="btn-action btn-approve">
                                    <span class="material-symbols-outlined text-base">check_circle</span>
                                    Approve Request
                                </button>
                                <button type="button" onclick="submitApproval('reject')" class="btn-action btn-reject">
                                    <span class="material-symbols-outlined text-base">cancel</span>
                                    Reject Request
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else if (Model.Status == "Pending" && !Model.CanApprove)
            {
                <section class="border-thin bg-white p-4 flex flex-col gap-2">
                    <h3 class="detail-label font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">hourglass_empty</span>
                        Processing Status
                    </h3>
                    <p class="text-sm text-gray-500">This request is currently awaiting review by an authorized approver.</p>
                </section>
            }

        </div>
    </div>
</div>

<script>
    function submitApproval(action) {
        const id = document.getElementById("leaveRequestId").value;
        const comment = document.getElementById("approvalComment").value;

        // Validation: comment is required for rejection
        if (action === 'reject' && (!comment || comment.trim() === "")) {
            if (typeof showToast === 'function') {
                showToast("Please enter comments when rejecting the request.", false);
            } else {
                alert("Please enter comments when rejecting the request.");
            }
            return;
        }

        const formData = new FormData();
        formData.append("LeaveRequestId", id);
        formData.append("Comment", comment);

        const url = action === 'approve' ? '/leave-request/approve' : '/leave-request/reject';

        fetch(url, {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                if (typeof showToast === 'function') {
                    showToast(data.message, true);
                }
                setTimeout(() => {
                    window.location.href = '/leave-request';
                }, 1000);
            } else {
                if (typeof showToast === 'function') {
                    showToast("Error: " + data.message, false);
                } else {
                    alert("Error: " + data.message);
                }
            }
        })
        .catch(err => {
            console.error(err);
            if (typeof showToast === 'function') {
                showToast("An error occurred while processing the request.", false);
            } else {
                alert("An error occurred while processing the request.");
            }
        });
    }
</script>
