@model Web.Backend.Models.ApprovalRouting.PolicyDetailViewModel
@{
    ViewData["Title"] = "Policy Detail & Rule Configuration";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var detail = Model.Detail;
}

<div class="w-full min-h-screen bg-[#FAF9F9] text-[#111111] p-4 lg:p-8 font-sans">
    <!-- Inline Notification Message Container -->
    <div id="configMessageContainer" class="hidden mb-4 p-4 border text-xs rounded-none font-sans"></div>

    <!-- Breadcrumb & Top Bar -->
    <div class="mb-6 border-b border-[#D1D1D1] pb-4">
        <div class="text-[11px] font-mono text-[#4C4546] uppercase tracking-wider mb-1">
            <a href="/approval-routing/policies" class="underline hover:text-black">HRM Admin</a> / <a href="/approval-routing/policies" class="underline hover:text-black">Approval Routing</a> / <a href="/approval-routing/policies" class="underline hover:text-black">Policies</a> / @detail.PolicyName
        </div>
        <h1 class="text-2xl lg:text-3xl font-bold uppercase tracking-tight text-black">
            @detail.PolicyName.ToUpper()
        </h1>
        <p class="text-xs text-[#4C4546] mt-1 font-mono">
            Department: @detail.DepartmentName | ID: POL-@detail.PolicyId.ToString().Substring(0, 8).ToUpper() | Created: @detail.CreatedAt.ToString("yyyy-MM-dd")
        </p>
    </div>

    <!-- Policy Header Summary Cards (2 Columns on Desktop) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <!-- Overview Card -->
        <div class="bg-white border border-[#D1D1D1] p-5 rounded-none space-y-3">
            <div class="flex justify-between items-center border-b border-[#D1D1D1] pb-2">
                <h3 class="font-bold text-sm uppercase text-black">POLICY OVERVIEW</h3>
                @if (detail.IsActive)
                {
                    <span class="px-2.5 py-0.5 bg-black text-white text-[10px] font-mono font-bold uppercase rounded-none">ACTIVE</span>
                }
                else
                {
                    <span class="px-2.5 py-0.5 bg-white text-[#E62429] border border-[#E62429] text-[10px] font-mono font-bold uppercase rounded-none">INACTIVE</span>
                }
            </div>
            <div class="text-xs text-[#4C4546] space-y-1.5">
                <p><span class="font-semibold text-black">Policy Name:</span> @detail.PolicyName</p>
                <p><span class="font-semibold text-black">Target Department:</span> @detail.DepartmentName</p>
                <p><span class="font-semibold text-black">Routing Execution Mode:</span> Single-Step Superior Approval Routing</p>
            </div>
        </div>

        <!-- Level Slots Summary Card -->
        <div class="bg-white border border-[#D1D1D1] p-5 rounded-none space-y-3">
            <div class="flex justify-between items-center border-b border-[#D1D1D1] pb-2">
                <h3 class="font-bold text-sm uppercase text-black">LEVEL SLOTS SUMMARY (@detail.LevelSlots.Count)</h3>
                @if (Model.CanUpdate)
                {
                    <button type="button" onclick="openAddLevelModal()" class="text-xs font-semibold text-black underline hover:text-[#E62429]">
                        + Add Level Slot
                    </button>
                }
            </div>
            <div class="text-xs space-y-2">
                @if (!detail.LevelSlots.Any())
                {
                    <p class="text-[#4C4546] italic">No level slots defined.</p>
                }
                else
                {
                    @foreach (var slot in detail.LevelSlots)
                    {
                        <div class="flex justify-between items-center p-2 bg-[#FAF9F9] border border-[#D1D1D1]">
                            <div>
                                <span class="font-semibold text-black">Level @slot.LevelRank: @slot.LevelName</span>
                                @if (slot.IsAssigned)
                                {
                                    <p class="text-[11px] text-[#4C4546] font-mono">Assigned: @slot.CurrentlyAssignedEmployeeName (@slot.CurrentlyAssignedEmployeeCode)</p>
                                }
                                else
                                {
                                    <p class="text-[11px] text-[#E62429] font-mono">Unassigned (Vacant)</p>
                                }
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="text-[10px] font-mono px-2 py-0.5 @(slot.IsAssigned ? "bg-black text-white" : "bg-white text-[#E62429] border border-[#E62429]")">
                                    @(slot.IsAssigned ? "ASSIGNED" : "VACANT")
                                </span>
                                @if (Model.CanUpdate)
                                {
                                    <button type="button" onclick="openAssignSlotModal('@slot.LevelId', '@slot.LevelName')" class="text-[10px] font-semibold text-black underline">
                                        Assign
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
            <a href="/approval-routing/levels/assignments?policyId=@detail.PolicyId" class="block w-full text-center py-2 bg-white border border-black text-black text-xs font-semibold uppercase tracking-wider rounded-none hover:bg-black hover:text-white transition-colors">
                Manage Level Slots
            </a>
        </div>
    </div>

    <!-- Position Rules Section -->
    <div class="bg-white border border-[#D1D1D1] p-5 rounded-none mb-8">
        <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-[#D1D1D1] pb-3 mb-4 gap-3">
            <div>
                <h2 class="text-base font-bold uppercase tracking-tight text-black">
                    CONFIGURED POSITION RULES (@detail.PositionRules.Count)
                </h2>
                <p class="text-xs text-[#4C4546]">
                    Configure priority candidate sequences or specific approver overrides per requester position.
                </p>
            </div>
            @if (Model.CanUpdate && detail.LevelSlots.Any())
            {
                <button type="button" onclick="openAddRuleModal()" class="px-4 py-2 bg-black text-white text-xs font-semibold uppercase tracking-wider rounded-none hover:bg-neutral-800 border border-black cursor-pointer">
                    + Add Position Rule
                </button>
            }
        </div>

        @if (!detail.PositionRules.Any())
        {
            <div class="p-8 text-center border border-[#E62429] bg-white text-xs text-[#E62429] mb-4">
                <p class="font-bold uppercase mb-1">WARNING: NO POSITION RULES CONFIGURED</p>
                <p class="mb-3">Employees submitting leave requests from this department will fail routing validation until position rules are configured.</p>
                @if (Model.CanUpdate && detail.LevelSlots.Any())
                {
                    <button type="button" onclick="openAddRuleModal()" class="px-5 py-2 bg-black text-white text-xs font-semibold uppercase tracking-wider rounded-none">
                        + Add Rule For Employee Position
                    </button>
                }
            </div>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var rule in detail.PositionRules)
                {
                    <div class="border border-[#D1D1D1] p-4 bg-white rounded-none space-y-3">
                        <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-[#D1D1D1] pb-2 gap-2">
                            <div>
                                <span class="text-xs font-mono text-[#4C4546] uppercase">REQUESTER POSITION:</span>
                                <h4 class="font-bold text-sm text-black uppercase">@rule.RequesterPositionName</h4>
                            </div>
                            <div>
                                @if (rule.IsSpecificApproverOverride)
                                {
                                    <span class="px-2.5 py-1 bg-black text-white text-[10px] font-mono font-bold uppercase rounded-none">
                                        SPECIFIC APPROVER OVERRIDE ENABLED
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 bg-[#F4F3F3] text-black border border-[#D1D1D1] text-[10px] font-mono font-bold uppercase rounded-none">
                                        CANDIDATE SEQUENCE MODE
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Content Mode Breakdown -->
                        @if (rule.IsSpecificApproverOverride)
                        {
                            <div class="p-3 bg-[#FAF9F9] border border-[#D1D1D1] text-xs">
                                <p class="font-semibold text-black">Direct Specific Approver:</p>
                                <p class="font-mono text-sm text-black">@rule.SpecificApproverName (@rule.SpecificApproverCode)</p>
                                <p class="text-[11px] text-[#4C4546] italic mt-1">Direct single-step route to specified employee override. Candidate sequence bypassed.</p>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-1.5 text-xs">
                                <p class="font-semibold text-black uppercase text-[11px]">Priority Candidates Sequence:</p>
                                @if (!rule.Candidates.Any())
                                {
                                    <p class="text-[#E62429] text-xs italic">No candidates configured for this rule.</p>
                                }
                                else
                                {
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                                        @foreach (var candidate in rule.Candidates)
                                        {
                                            <div class="p-2 border border-[#D1D1D1] bg-[#FAF9F9] flex justify-between items-center">
                                                <div>
                                                    <span class="font-mono font-bold text-black">Priority @candidate.PriorityOrder:</span>
                                                    <span class="text-black font-medium pl-1">Level @candidate.LevelRank (@candidate.LevelName)</span>
                                                    <p class="text-[10px] text-[#4C4546] font-mono">Assigned: @(candidate.AssignedApproverName ?? "Vacant")</p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- Action Footer -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 bg-white border border-[#D1D1D1] p-4">
        <a href="/approval-routing/policies" class="w-full md:w-auto text-center px-4 py-2 bg-white border border-black text-black text-xs font-semibold uppercase tracking-wider rounded-none hover:bg-black hover:text-white transition-colors">
            Back to Policies
        </a>
        <a href="/approval-routing/levels/assignments?policyId=@detail.PolicyId" class="w-full md:w-auto text-center px-5 py-2 bg-black text-white text-xs font-semibold uppercase tracking-wider rounded-none hover:bg-neutral-800 border border-black">
            Configure Level Slot Assignments
        </a>
    </div>
</div>

<!-- Add Level Modal -->
<div id="addLevelModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-white border border-[#D1D1D1] max-w-md w-full p-6 space-y-4 font-sans">
        <div class="flex justify-between items-center border-b border-[#D1D1D1] pb-3">
            <h3 class="font-bold text-sm text-black uppercase">Add Level Slot</h3>
            <button type="button" onclick="closeAddLevelModal()" class="text-black hover:text-[#E62429] font-bold text-sm">X</button>
        </div>
        <form id="addLevelForm" class="space-y-4">
            <input type="hidden" name="PolicyId" value="@detail.PolicyId" />
            <div>
                <label class="block text-xs font-semibold text-black uppercase tracking-wider mb-1">Level Name</label>
                <input type="text" name="LevelName" required placeholder="e.g. Department Manager" class="w-full px-3 py-2 bg-white text-black text-xs border border-[#D1D1D1] focus:outline-none focus:border-black" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-black uppercase tracking-wider mb-1">Level Rank</label>
                <input type="number" name="LevelRank" required value="1" min="1" class="w-full px-3 py-2 bg-white text-black text-xs border border-[#D1D1D1] focus:outline-none focus:border-black" />
            </div>
            <div class="flex items-center gap-2">
                <input type="checkbox" id="canApproveLeave" name="CanApproveLeave" value="true" checked class="border-[#D1D1D1]" />
                <label for="canApproveLeave" class="text-xs font-semibold text-black uppercase">Can Approve Leave Requests</label>
            </div>
            <div class="pt-3 border-t border-[#D1D1D1] flex justify-end gap-2">
                <button type="button" onclick="closeAddLevelModal()" class="px-4 py-2 bg-white border border-[#D1D1D1] text-black text-xs font-semibold uppercase">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-black text-white text-xs font-semibold uppercase">Add Level</button>
            </div>
        </form>
    </div>
</div>

<!-- Add Rule Modal -->
<div id="addRuleModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-white border border-[#D1D1D1] max-w-md w-full p-6 space-y-4 font-sans">
        <div class="flex justify-between items-center border-b border-[#D1D1D1] pb-3">
            <h3 class="font-bold text-sm text-black uppercase">Add Position Rule</h3>
            <button type="button" onclick="closeAddRuleModal()" class="text-black hover:text-[#E62429] font-bold text-sm">X</button>
        </div>
        <form id="addRuleForm" class="space-y-4">
            <input type="hidden" name="PolicyId" value="@detail.PolicyId" />
            <div>
                <label class="block text-xs font-semibold text-black uppercase tracking-wider mb-1">Requester Position</label>
                <select name="RequesterPositionId" required class="w-full px-3 py-2 bg-white text-black text-xs border border-[#D1D1D1] focus:outline-none focus:border-black">
                    <option value="">-- SELECT POSITION --</option>
                    @foreach (var pos in Model.Positions)
                    {
                        <option value="@pos.Id.Value">@pos.Name (@pos.Code)</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-black uppercase tracking-wider mb-1">Target Candidate Level Slot</label>
                <select name="CandidateLevelId" required class="w-full px-3 py-2 bg-white text-black text-xs border border-[#D1D1D1] focus:outline-none focus:border-black">
                    <option value="">-- SELECT LEVEL SLOT --</option>
                    @foreach (var slot in detail.LevelSlots)
                    {
                        <option value="@slot.LevelId">Level @slot.LevelRank: @slot.LevelName</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-black uppercase tracking-wider mb-1">Priority Order</label>
                <input type="number" name="PriorityOrder" required value="1" min="1" class="w-full px-3 py-2 bg-white text-black text-xs border border-[#D1D1D1] focus:outline-none focus:border-black" />
            </div>
            <div class="pt-3 border-t border-[#D1D1D1] flex justify-end gap-2">
                <button type="button" onclick="closeAddRuleModal()" class="px-4 py-2 bg-white border border-[#D1D1D1] text-black text-xs font-semibold uppercase">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-black text-white text-xs font-semibold uppercase">Add Rule</button>
            </div>
        </form>
    </div>
</div>

<!-- Assign Level Slot Modal -->
<div id="assignSlotModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-white border border-[#D1D1D1] max-w-md w-full p-6 space-y-4 font-sans">
        <div class="flex justify-between items-center border-b border-[#D1D1D1] pb-3">
            <h3 class="font-bold text-sm text-black uppercase">Assign Level Slot: <span id="assignSlotTitle"></span></h3>
            <button type="button" onclick="closeAssignSlotModal()" class="text-black hover:text-[#E62429] font-bold text-sm">X</button>
        </div>
        <form id="assignSlotForm" class="space-y-4">
            <input type="hidden" id="assignLevelId" name="LevelId" />
            <div>
                <label class="block text-xs font-semibold text-black uppercase tracking-wider mb-1">Approver Employee</label>
                <select name="ApproverEmployeeId" required class="w-full px-3 py-2 bg-white text-black text-xs border border-[#D1D1D1] focus:outline-none focus:border-black">
                    <option value="">-- SELECT APPROVER EMPLOYEE --</option>
                    @foreach (var emp in Model.Employees)
                    {
                        <option value="@emp.Id.Value">@emp.FullName (@emp.EmployeeCode)</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-black uppercase tracking-wider mb-1">Assignment Reason</label>
                <input type="text" name="Reason" placeholder="Initial level slot assignment..." class="w-full px-3 py-2 bg-white text-black text-xs border border-[#D1D1D1] focus:outline-none focus:border-black" />
            </div>
            <div class="pt-3 border-t border-[#D1D1D1] flex justify-end gap-2">
                <button type="button" onclick="closeAssignSlotModal()" class="px-4 py-2 bg-white border border-[#D1D1D1] text-black text-xs font-semibold uppercase">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-black text-white text-xs font-semibold uppercase">Save Assignment</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showConfigMessage(msg, isError) {
            var box = document.getElementById('configMessageContainer');
            box.classList.remove('hidden', 'bg-black', 'text-white', 'bg-white', 'text-[#E62429]', 'border-[#E62429]', 'border-black');
            if (isError) {
                box.classList.add('bg-white', 'text-[#E62429]', 'border-[#E62429]');
            } else {
                box.classList.add('bg-black', 'text-white', 'border-black');
            }
            box.textContent = msg;
        }

        function openAddLevelModal() { document.getElementById('addLevelModal').classList.remove('hidden'); }
        function closeAddLevelModal() { document.getElementById('addLevelModal').classList.add('hidden'); }

        function openAddRuleModal() { document.getElementById('addRuleModal').classList.remove('hidden'); }
        function closeAddRuleModal() { document.getElementById('addRuleModal').classList.add('hidden'); }

        function openAssignSlotModal(levelId, levelName) {
            document.getElementById('assignLevelId').value = levelId;
            document.getElementById('assignSlotTitle').textContent = levelName;
            document.getElementById('assignSlotModal').classList.remove('hidden');
        }
        function closeAssignSlotModal() { document.getElementById('assignSlotModal').classList.add('hidden'); }

        document.getElementById('addLevelForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            var formData = new FormData(this);
            fetch('/approval-routing/levels/add', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showConfigMessage(data.message, false);
                    window.location.reload();
                } else {
                    showConfigMessage('Error: ' + data.message, true);
                }
            })
            .catch(err => showConfigMessage('Error: ' + err, true));
        });

        document.getElementById('addRuleForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            var formData = new FormData(this);
            fetch('/approval-routing/rules/add', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showConfigMessage(data.message, false);
                    window.location.reload();
                } else {
                    showConfigMessage('Error: ' + data.message, true);
                }
            })
            .catch(err => showConfigMessage('Error: ' + err, true));
        });

        document.getElementById('assignSlotForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            var formData = new FormData(this);
            fetch('/approval-routing/levels/assign', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showConfigMessage(data.message, false);
                    window.location.reload();
                } else {
                    showConfigMessage('Error: ' + data.message, true);
                }
            })
            .catch(err => showConfigMessage('Error: ' + err, true));
        });
    </script>
}
