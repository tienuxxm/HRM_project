@{
    ViewData["Title"] = "Create Approval Routing Policy";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var departments = ViewBag.Departments as List<Domain.Departments.Department> ?? new();
    string? errorMessage = TempData["ErrorMessage"] as string;
}

<div class="w-full min-h-screen bg-[#FAF9F9] text-[#111111] p-4 lg:p-8 font-sans">
    <!-- Breadcrumb -->
    <div class="mb-6 border-b border-[#D1D1D1] pb-4">
        <div class="text-[11px] font-mono text-[#4C4546] uppercase tracking-wider mb-1">
            <a href="/approval-routing/policies" class="underline hover:text-black">HRM Admin</a> / <a href="/approval-routing/policies" class="underline hover:text-black">Approval Routing</a> / Policies / Create
        </div>
        <h1 class="text-2xl lg:text-3xl font-bold uppercase tracking-tight text-black">
            CREATE APPROVAL ROUTING POLICY
        </h1>
        <p class="text-xs text-[#4C4546] mt-1">
            Define a new department-specific superior routing policy for leave request processing.
        </p>
    </div>

    <!-- Error Banner if any -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="mb-6 p-4 bg-white border-l-4 border-[#E62429] border-y border-r border-[#D1D1D1] text-xs text-[#E62429]">
            <p class="font-bold uppercase mb-1">POLICY CREATION FAILED:</p>
            <p>@errorMessage</p>
        </div>
    }

    <!-- Policy Creation Form Card -->
    <div class="max-w-2xl bg-white border border-[#D1D1D1] p-6 rounded-none shadow-none">
        <form method="post" action="/approval-routing/policies/create" class="space-y-6">
            <!-- Target Department -->
            <div class="space-y-1.5">
                <label for="departmentId" class="block text-xs font-semibold text-black uppercase tracking-wider">
                    Target Department <span class="text-[#E62429]">*</span>
                </label>
                <select id="departmentId" name="DepartmentId" required class="w-full px-3 py-2.5 bg-white text-black text-xs border border-[#D1D1D1] rounded-none focus:outline-none focus:border-black font-sans">
                    <option value="">-- SELECT DEPARTMENT --</option>
                    @foreach (var dept in departments)
                    {
                        <option value="@dept.Id.Value">@dept.Name (@dept.Code)</option>
                    }
                </select>
                <p class="text-[11px] text-[#4C4546]">Each department can have at most 1 active superior routing policy.</p>
            </div>

            <!-- Policy Name -->
            <div class="space-y-1.5">
                <label for="name" class="block text-xs font-semibold text-black uppercase tracking-wider">
                    Policy Name <span class="text-[#E62429]">*</span>
                </label>
                <input type="text" id="name" name="Name" required placeholder="e.g. Information Technology Approval Policy" class="w-full px-3 py-2.5 bg-white text-black text-xs border border-[#D1D1D1] rounded-none focus:outline-none focus:border-black font-sans" />
            </div>

            <!-- Description -->
            <div class="space-y-1.5">
                <label for="description" class="block text-xs font-semibold text-black uppercase tracking-wider">
                    Description
                </label>
                <textarea id="description" name="Description" rows="3" placeholder="Standard 1-step superior approval routing policy..." class="w-full px-3 py-2.5 bg-white text-black text-xs border border-[#D1D1D1] rounded-none focus:outline-none focus:border-black font-sans resize-none"></textarea>
            </div>

            <!-- Action Buttons -->
            <div class="pt-4 border-t border-[#D1D1D1] flex items-center gap-3">
                <button type="submit" class="px-6 py-2.5 bg-black text-white text-xs font-semibold uppercase tracking-wider rounded-none hover:bg-neutral-800 border border-black cursor-pointer">
                    + Create Policy
                </button>
                <a href="/approval-routing/policies" class="px-6 py-2.5 bg-white text-black text-xs font-semibold uppercase tracking-wider rounded-none border border-[#D1D1D1] hover:border-black transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
