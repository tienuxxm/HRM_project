@model Web.Backend.Models.ApprovalRouting.ImpactPreviewModalViewModel
@{
    var impact = Model.ImpactData;
    var hasImpact = impact.TotalPendingRequestsCount > 0;
}

<div id="impactModalBackdrop" onclick="window.handleBackdropClick(event)" class="fixed inset-0 z-[9999] bg-black/75 p-3 sm:p-4 font-sans flex items-center justify-center overflow-hidden">
    <div class="bg-white border-2 border-black w-full max-w-3xl rounded-none shadow-none max-h-[85vh] flex flex-col overflow-hidden text-[#111111] leading-normal min-h-0">
        <!-- Modal Header -->
        <div class="bg-black text-white px-4 sm:px-5 py-3 flex justify-between items-center flex-shrink-0 border-b border-black gap-2">
            <div class="min-w-0 flex-1">
                <div class="text-[10px] font-mono uppercase text-[#D1D1D1] tracking-wider truncate">
                    SYSTEM IMPACT SIMULATION & REASSIGNMENT DECISION
                </div>
                <h2 class="text-xs sm:text-base font-bold uppercase tracking-tight text-white truncate">
                    UNASSIGN LEVEL SLOT - DRY-RUN IMPACT PREVIEW
                </h2>
                <p class="text-[10px] sm:text-[11px] text-[#D1D1D1] font-mono mt-0.5 truncate">
                    Target: @Model.TargetSlotName - Assigned: @Model.AssignedEmployeeName
                </p>
            </div>
            <button type="button" onclick="window.closeImpactModal()" class="flex-shrink-0 whitespace-nowrap text-[#E62429] bg-black border border-[#E62429] hover:bg-[#E62429] hover:text-white transition-colors cursor-pointer text-xs font-mono font-bold px-2.5 py-1" title="Close Modal (Esc)">
                [ X ]
            </button>
        </div>

        <!-- Inline Modal Error Banner -->
        <div id="modalErrorMessage" class="hidden p-3 bg-[#FFF5F5] border-b border-[#E62429] text-[#E62429] text-xs font-semibold uppercase font-mono"></div>

        <!-- Scrollable Modal Body -->
        <div class="p-4 sm:p-5 space-y-4 overflow-y-auto flex-1 min-h-0 text-[#111111] bg-[#FAF9F9]">

            @if (!hasImpact)
            {
                <!-- Safe Unassignment Card (0 Pending Impacted Requests) -->
                <div class="p-4 bg-white border border-black rounded-none space-y-2">
                    <div class="flex items-center gap-2 text-black font-bold text-xs uppercase tracking-wide">
                        <span class="px-2 py-0.5 bg-black text-white text-[10px] font-mono font-bold uppercase">SAFE</span>
                        <span>SAFE UNASSIGNMENT - NO PENDING LEAVE REQUESTS IMPACTED</span>
                    </div>
                    <p class="text-xs text-[#4C4546] leading-relaxed">
                        No pending leave requests are impacted by this action. Slot can be safely deactivated.
                    </p>
                </div>

                <!-- Simple Form for 0 Impact -->
                <form id="reassignmentExecutionForm" class="bg-white border border-[#D1D1D1] p-4 rounded-none space-y-3">
                    <input type="hidden" name="levelAssignmentId" value="@Model.TargetLevelAssignmentId" />
                    <input type="hidden" name="employeeId" value="@Model.TargetEmployeeId" />
                    <input type="hidden" name="strategy" value="AUTO" />

                    <div class="space-y-1 text-xs">
                        <label class="font-semibold text-black uppercase block text-[11px]">Reason for Unassign (Optional):</label>
                        <input type="text" name="reason" value="Operator level slot unassignment via UI console" class="w-full px-3 py-1.5 bg-white text-black border border-[#D1D1D1] rounded-none focus:outline-none focus:border-black font-sans text-xs" />
                    </div>
                </form>
            }
            else
            {
                <!-- Summary Metrics Cards Row -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <!-- Total Impacted Card -->
                    <div class="bg-white border border-[#D1D1D1] p-3 rounded-none">
                        <p class="text-[10px] font-mono uppercase text-[#4C4546] font-bold">TOTAL PENDING IMPACTED</p>
                        <p class="text-xl font-bold font-mono text-black mt-0.5">@impact.TotalPendingRequestsCount</p>
                        <p class="text-[10px] text-[#4C4546]">Assigned to this slot.</p>
                    </div>
                    <!-- Auto Re-routable Card -->
                    <div class="bg-white border border-[#D1D1D1] p-3 rounded-none">
                        <p class="text-[10px] font-mono uppercase text-[#4C4546] font-bold">AUTO RE-ROUTABLE</p>
                        <p class="text-xl font-bold font-mono text-black mt-0.5">@impact.AutoReroutableCount</p>
                        <p class="text-[10px] text-[#4C4546]">Valid active candidates exist.</p>
                    </div>
                    <!-- Escalation / Needs Admin Attention Card -->
                    <div class="bg-white border border-[#E62429] p-3 rounded-none">
                        <p class="text-[10px] font-mono uppercase text-[#E62429] font-bold">NEEDS ADMIN ATTENTION</p>
                        <p class="text-xl font-bold font-mono text-[#E62429] mt-0.5">@impact.NeedsAdminAttentionCount</p>
                        <p class="text-[10px] text-[#4C4546]">No active candidate slot.</p>
                    </div>
                </div>

                <!-- Affected Pending Requests Table -->
                <div class="bg-white border border-[#D1D1D1] rounded-none p-3.5 space-y-2">
                    <h3 class="font-bold text-xs uppercase text-black">AFFECTED PENDING LEAVE REQUESTS</h3>
                    <div class="overflow-x-auto max-h-48 overflow-y-auto border border-[#D1D1D1]">
                        <table class="w-full text-left border-collapse font-sans text-xs min-w-[500px]">
                            <thead class="sticky top-0 bg-[#F4F3F3]">
                                <tr class="border-b border-[#D1D1D1] text-[10px] font-semibold text-black uppercase">
                                    <th class="py-2 px-2.5 border-r border-[#D1D1D1]">Code</th>
                                    <th class="py-2 px-2.5 border-r border-[#D1D1D1]">Requester</th>
                                    <th class="py-2 px-2.5 border-r border-[#D1D1D1]">Type</th>
                                    <th class="py-2 px-2.5 border-r border-[#D1D1D1]">Dates</th>
                                    <th class="py-2 px-2.5 border-r border-[#D1D1D1]">Proposed Approver</th>
                                    <th class="py-2 px-2.5">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-[#D1D1D1]">
                                @foreach (var req in impact.AffectedRequests)
                                {
                                    <tr class="hover:bg-[#FAF9F9]">
                                        <td class="py-1.5 px-2.5 border-r border-[#D1D1D1] font-mono text-[11px]">
                                            LR-@req.LeaveRequestId.ToString().Substring(0, 8).ToUpper()
                                        </td>
                                        <td class="py-1.5 px-2.5 border-r border-[#D1D1D1] font-medium text-black">
                                            @req.RequesterName
                                        </td>
                                        <td class="py-1.5 px-2.5 border-r border-[#D1D1D1] text-[#4C4546]">
                                            @req.LeaveTypeName
                                        </td>
                                        <td class="py-1.5 px-2.5 border-r border-[#D1D1D1] font-mono text-[11px]">
                                            @req.StartDate.ToString("MM-dd") -> @req.EndDate.ToString("MM-dd")
                                        </td>
                                        <td class="py-1.5 px-2.5 border-r border-[#D1D1D1] font-medium">
                                            @req.ProposedApproverName
                                        </td>
                                        <td class="py-1.5 px-2.5">
                                            @if (req.IsAutoReroutable)
                                            {
                                                <span class="px-2 py-0.5 bg-black text-white text-[10px] font-mono font-bold uppercase">
                                                    @req.ResolverStatus
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="px-2 py-0.5 bg-white text-[#E62429] border border-[#E62429] text-[10px] font-mono font-bold uppercase">
                                                    @req.ResolverStatus
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Reassignment Strategy Decision Selection Form -->
                <form id="reassignmentExecutionForm" class="bg-white border border-[#D1D1D1] p-3.5 rounded-none space-y-3">
                    <h3 class="font-bold text-xs uppercase text-black border-b border-[#D1D1D1] pb-1.5">
                        REASSIGNMENT STRATEGY DECISION
                    </h3>

                    <input type="hidden" name="levelAssignmentId" value="@Model.TargetLevelAssignmentId" />
                    <input type="hidden" name="employeeId" value="@Model.TargetEmployeeId" />

                    <div class="space-y-2 text-xs">
                        <label class="flex items-start gap-2.5 p-2.5 bg-[#FAF9F9] border border-[#D1D1D1] cursor-pointer hover:border-black transition-colors">
                            <input type="radio" name="strategy" value="AUTO" checked onclick="window.toggleManualApprover(false)" class="mt-0.5 rounded-none accent-black" />
                            <div>
                                <span class="font-bold text-black uppercase">Strategy 1: Automatic Re-route via Resolver (Recommended)</span>
                                <p class="text-[#4C4546] text-[11px] mt-0.5">
                                    Automatically re-route pending requests to the next active candidate in rule sequence.
                                </p>
                            </div>
                        </label>

                        <label class="flex items-start gap-2.5 p-2.5 bg-[#FAF9F9] border border-[#D1D1D1] cursor-pointer hover:border-black transition-colors">
                            <input type="radio" name="strategy" value="MANUAL" onclick="window.toggleManualApprover(true)" class="mt-0.5 rounded-none accent-black" />
                            <div>
                                <span class="font-bold text-black uppercase">Strategy 2: Manual Reassign All to Specific Employee</span>
                                <p class="text-[#4C4546] text-[11px] mt-0.5">
                                    Manually select a single active replacement employee with approval permission.
                                </p>
                            </div>
                        </label>
                    </div>

                    <!-- Manual Approver Select Dropdown -->
                    <div id="manualApproverSelectContainer" class="hidden p-3 bg-white border border-black space-y-1.5 text-xs">
                        <label class="font-bold text-black uppercase block text-[11px]">Select Manual Replacement Approver:</label>
                        <select name="newApproverEmployeeId" class="w-full px-3 py-1.5 bg-white text-black border border-[#D1D1D1] rounded-none focus:outline-none focus:border-black font-sans text-xs">
                            <option value="">-- Select Active Replacement Approver --</option>
                            @foreach (var emp in Model.AvailableApprovers)
                            {
                                <option value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode) - @emp.PositionName, @emp.DepartmentName</option>
                            }
                        </select>
                        <p class="text-[10px] text-[#4C4546] italic">Pre-filtered for active employee status, APPROVE_LEAVE_REQUEST permission, and department / company scope.</p>
                    </div>

                    <div class="space-y-1 text-xs">
                        <label class="font-semibold text-black uppercase block text-[11px]">Reason for Unassign / Reassignment:</label>
                        <input type="text" name="reason" value="Operator level slot unassignment via UI console" class="w-full px-3 py-1.5 bg-white text-black border border-[#D1D1D1] rounded-none focus:outline-none focus:border-black font-sans text-xs" />
                    </div>
                </form>
            }
        </div>

        <!-- Sticky Modal Footer Actions -->
        <div class="bg-white border-t border-[#D1D1D1] px-4 sm:px-5 py-3 flex flex-row justify-end gap-2.5 flex-shrink-0">
            <button type="button" onclick="window.closeImpactModal()" class="px-4 py-2 bg-white border border-black text-black text-xs font-semibold uppercase tracking-wider rounded-none hover:bg-black hover:text-white transition-colors">
                Cancel
            </button>
            <button type="button" onclick="window.submitReassignmentExecution()" class="px-4 py-2 bg-black text-white text-xs font-semibold uppercase tracking-wider rounded-none hover:bg-neutral-800 transition-colors border border-black">
                @(hasImpact ? "Execute Reassignment & Deactivate Slot" : "Deactivate Slot")
            </button>
        </div>
    </div>
</div>
