@model Application.WorkCalendars.GetImportBatchDetails.CalendarImportBatchDetailsResponse

@{
    ViewBag.Title = "Import Preview";
    Layout = "_Layout";
    bool hasErrors = Model.Rows.Any(r => !r.IsValid);
}

<div class="w-full">
    <div class="w-full flex flex-col">
        <!-- Main Card Wrapper -->
        <div style="min-height: 543px" class="bg-white w-full p-6 rounded-none border border-[#D1D1D1] flex flex-col justify-between">
            <div class="w-full">

                <!-- Batch Summary Card -->
                <div class="bg-white border-2 border-black p-4 mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4 rounded-none">
                    <div class="text-sm">
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Import Verification Summary</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                            <div>
                                <span class="block text-xs font-semibold text-gray-400 uppercase">File Name</span>
                                <span class="font-semibold text-black">@Model.FileName</span>
                            </div>
                            <div>
                                <span class="block text-xs font-semibold text-gray-400 uppercase">Total Rows</span>
                                <span class="font-semibold text-black font-mono mono">@Model.Rows.Count rows</span>
                            </div>
                            <div>
                                <span class="block text-xs font-semibold text-gray-400 uppercase">Status</span>
                                @if (hasErrors)
                                {
                                    <span class="inline-flex items-center rounded-none border border-red-500 bg-red-50 px-2 py-0.5 text-xs font-bold text-red-800">Verification Failed</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center rounded-none border border-black bg-white px-2 py-0.5 text-xs font-bold text-black">Verification Passed</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-3">
                        <a href="/work-calendar" class="bg-white border border-black text-black px-6 py-2.5 font-semibold text-sm uppercase tracking-wider hover:bg-gray-100 transition-colors rounded-none text-center">
                            Cancel
                        </a>
                        <div id="confirmImportForm">
                            <input type="hidden" id="confirmBatchId" value="@Model.BatchId" />
                            @if (hasErrors)
                            {
                                <button type="button" disabled id="confirmImportBtn"
                                        class="bg-gray-200 border border-gray-300 text-gray-500 px-6 py-2.5 font-semibold text-sm uppercase tracking-wider rounded-none cursor-not-allowed">
                                    Apply Import
                                </button>
                            }
                            else
                            {
                                <button type="button" onclick="confirmImport()" id="confirmImportBtn"
                                        class="bg-black border border-black text-white px-6 py-2.5 font-semibold text-sm uppercase tracking-wider hover:bg-white hover:text-black rounded-none transition-colors">
                                    Apply Import
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <!-- Error Alert Box -->
                @if (hasErrors)
                {
                    <div class="p-4 mb-6 text-sm text-red-800 rounded-none bg-red-50 border-l-4 border-red-500">
                        <div class="flex items-start">
                            <span class="material-symbols-outlined text-red-500 mr-2">error</span>
                            <div>
                                <span class="font-bold">Cannot import work calendar:</span> The file contains validation errors. Please fix all errors highlighted below and upload again.
                            </div>
                        </div>
                    </div>
                }

                <!-- Table Preview Grid -->
                <div class="overflow-x-auto w-full border border-[#D1D1D1] rounded-none">
                    <table class="min-w-full divide-y divide-[#D1D1D1] text-sm text-left">
                        <thead class="bg-[#eeeeee]">
                            <tr>
                                <th class="px-4 py-3 font-semibold text-gray-900 text-center w-16 border-r border-[#D1D1D1]">Row</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Date</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Day Type</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Work Shift</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Description</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 text-center w-32 border-r border-[#D1D1D1]">Validation</th>
                                <th class="px-4 py-3 font-semibold text-gray-900">Issues/Errors</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#D1D1D1] bg-white">
                            @foreach (var row in Model.Rows)
                            {
                                string rowBg = row.IsValid ? "bg-white hover:bg-[#F1F5F9] transition-colors" : "bg-red-50 hover:bg-red-100/50 transition-colors";
                                <tr class="@rowBg">
                                    <td class="px-4 py-3 text-center text-gray-900 font-mono mono border-r border-[#D1D1D1]">@row.RowIndex</td>
                                    <td class="px-4 py-3 text-gray-900 font-mono mono border-r border-[#D1D1D1]">@(row.Date?.ToString("yyyy-MM-dd") ?? "-")</td>
                                    <td class="px-4 py-3 text-gray-900 border-r border-[#D1D1D1]">
                                        @if (row.DayType == "PublicHoliday")
                                        {
                                            <span class="inline-flex items-center rounded-none border border-red-500 bg-red-50 px-2 py-0.5 text-xs font-semibold text-red-800">Public Holiday</span>
                                        }
                                        else if (row.DayType == "CompanyCustomNonWorkingDay")
                                        {
                                            <span class="inline-flex items-center rounded-none border border-gray-400 bg-gray-50 px-2 py-0.5 text-xs font-semibold text-gray-800">Company Non-Working</span>
                                        }
                                        else if (row.DayType == "StandardWorkingDayOverride")
                                        {
                                            <span class="inline-flex items-center rounded-none border border-black bg-white px-2 py-0.5 text-xs font-semibold text-black">Working Override</span>
                                        }
                                        else if (row.DayType == "WorkingSaturdayOverride")
                                        {
                                            <span class="inline-flex items-center rounded-none border border-gray-600 bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-900">Working Saturday</span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center rounded-none border border-gray-500 bg-gray-50 px-2 py-0.5 text-xs font-semibold text-gray-800">@row.DayType</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3 text-gray-700 border-r border-[#D1D1D1]">@row.WorkShift</td>
                                    <td class="px-4 py-3 text-gray-500 border-r border-[#D1D1D1]">@(row.Description ?? "-")</td>
                                    <td class="px-4 py-3 text-center border-r border-[#D1D1D1]">
                                        @if (row.IsValid)
                                        {
                                            <span class="inline-flex items-center rounded-none border border-black bg-white px-2 py-0.5 text-xs font-bold text-black">Valid</span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center rounded-none border border-red-500 bg-red-50 px-2 py-0.5 text-xs font-bold text-red-800">Invalid</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3">
                                        @if (row.IsValid)
                                        {
                                            <span class="text-xs text-gray-400 font-semibold italic">No issues</span>
                                        }
                                        else
                                        {
                                            <div class="text-xs text-red-700 font-bold flex items-center gap-1">
                                                <span class="material-symbols-outlined text-[14px]">error_outline</span>
                                                <span>@(row.ErrorMessage ?? "Unknown validation error")</span>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Inline Error Banner for Confirm Import -->
<div id="confirmErrorBanner" class="fixed top-5 right-5 z-50 max-w-sm p-4 bg-white border-2 border-[#E62429] text-red-800 text-sm font-semibold rounded-none shadow-none hidden">
    <div class="flex items-start gap-2">
        <span class="material-symbols-outlined text-[#E62429] text-[18px] flex-shrink-0">error</span>
        <span id="confirmErrorMessage">An error occurred.</span>
        <button type="button" onclick="document.getElementById('confirmErrorBanner').classList.add('hidden')" class="ml-auto text-gray-500 hover:text-black">
            <span class="material-symbols-outlined text-[16px]">close</span>
        </button>
    </div>
</div>

@section Scripts {
<script>
    function confirmImport() {
        var batchId = document.getElementById('confirmBatchId').value;
        var btn = document.getElementById('confirmImportBtn');
        var originalText = btn.textContent;

        btn.disabled = true;
        btn.textContent = 'Processing...';
        btn.className = 'bg-gray-200 border border-gray-300 text-gray-500 px-6 py-2.5 font-semibold text-sm uppercase tracking-wider rounded-none cursor-not-allowed';

        // Hide any previous error
        document.getElementById('confirmErrorBanner').classList.add('hidden');

        $.ajax({
            url: '/work-calendar/confirm',
            type: 'POST',
            contentType: 'application/x-www-form-urlencoded',
            data: { batchId: batchId },
            success: function(response) {
                if (response.success) {
                    window.location.href = '/work-calendar/summary/' + batchId;
                } else {
                    btn.disabled = false;
                    btn.textContent = originalText;
                    btn.className = 'bg-black border border-black text-white px-6 py-2.5 font-semibold text-sm uppercase tracking-wider hover:bg-white hover:text-black rounded-none transition-colors';
                    showConfirmError(response.message || 'Import confirmation failed.');
                }
            },
            error: function() {
                btn.disabled = false;
                btn.textContent = originalText;
                btn.className = 'bg-black border border-black text-white px-6 py-2.5 font-semibold text-sm uppercase tracking-wider hover:bg-white hover:text-black rounded-none transition-colors';
                showConfirmError('An error occurred during import confirmation.');
            }
        });
    }

    function showConfirmError(message) {
        var banner = document.getElementById('confirmErrorBanner');
        document.getElementById('confirmErrorMessage').textContent = message;
        banner.classList.remove('hidden');
        // Auto-hide after 8 seconds
        setTimeout(function() {
            banner.classList.add('hidden');
        }, 8000);
    }
</script>
}
