@model Application.WorkCalendars.GetImportBatchSummary.CalendarImportBatchSummaryResponse

@{
    ViewBag.Title = "Import Summary";
    Layout = "_Layout";
}

<div class="w-full">
    <div class="w-full flex flex-col">
        <!-- Breadcrumb -->
        <nav class="flex" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">
                        <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                            <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
                        </svg>
                    </a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                        </svg>
                        <a href="/work-calendar" class="ml-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ml-2 dark:text-gray-400 dark:hover:text-white">Work Calendar</a>
                    </div>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                        </svg>
                        <span class="ml-1 text-sm font-medium text-gray-700 md:ml-2 dark:text-gray-400">Import Summary</span>
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Summary Card -->
        <div style="min-height: 543px" class="bg-white w-full p-6 rounded-lg mt-5 flex flex-col justify-between shadow-sm">
            <div class="w-full">
                <!-- Status Success Header -->
                <div class="flex items-center gap-4 p-4 mb-6 bg-green-50 border border-green-200 rounded-lg">
                    <div class="flex-shrink-0 w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-green-950">Excel Import Successfully Processed!</h2>
                        <p class="text-sm text-green-800">
                            Work calendar day configurations have been updated, and affected leave requests have been recalculated automatically.
                        </p>
                    </div>
                </div>

                <!-- Batch Details -->
                <div class="bg-gray-50 border border-gray-100 rounded-lg p-4 mb-6">
                    <h3 class="text-md font-bold text-gray-900 mb-3">Recalculation Summary</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 text-sm">
                        <div>
                            <span class="block text-xs font-semibold text-gray-400 uppercase">File Name</span>
                            <span class="font-semibold text-gray-900">@Model.FileName</span>
                        </div>
                        <div>
                            <span class="block text-xs font-semibold text-gray-400 uppercase">Processed At</span>
                            <span class="font-semibold text-gray-900">@(Model.ProcessedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</span>
                        </div>
                        <div>
                            <span class="block text-xs font-semibold text-gray-400 uppercase">Calendar Days Modified</span>
                            <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-bold text-blue-700 ring-1 ring-inset ring-blue-700/10">@Model.UpdatedDaysCount days</span>
                        </div>
                        <div>
                            <span class="block text-xs font-semibold text-gray-400 uppercase">Affected Leave Requests</span>
                            <span class="inline-flex items-center rounded-md bg-amber-50 px-2 py-1 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-700/10">@Model.AffectedRequests.Count requests</span>
                        </div>
                    </div>
                </div>

                <!-- Affected Requests Section -->
                <div>
                    <h3 class="text-md font-semibold text-gray-900 mb-3 uppercase tracking-wider">Recalculation Audit Logs</h3>
                    <div class="overflow-x-auto w-full">
                        <table class="min-w-full divide-y-2 divide-gray-200 text-sm">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-left">Employee</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-left">Leave Type</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-left">Date Range</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-center">Status Change</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-center">Duration Change</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-center">Difference</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 bg-white">
                                @if (!Model.AffectedRequests.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="px-4 py-6 text-center text-gray-500">
                                            No leave requests were affected by this change.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var audit in Model.AffectedRequests)
                                    {
                                        decimal diff = audit.NewDuration - audit.OldDuration;
                                        string diffClass = diff < 0 ? "text-green-600 font-bold" : (diff > 0 ? "text-red-600 font-bold" : "text-gray-500");
                                        string diffText = diff > 0 ? $"+{diff:0.#}" : $"{diff:0.#}";

                                        <tr>
                                            <td class="px-4 py-3 text-gray-900 font-semibold">@audit.EmployeeName</td>
                                            <td class="px-4 py-3 text-gray-700">@audit.LeaveTypeName</td>
                                            <td class="px-4 py-3 text-gray-500">@audit.StartDate.ToString("yyyy-MM-dd") to @audit.EndDate.ToString("yyyy-MM-dd")</td>
                                            <td class="px-4 py-3 text-center">
                                                <span class="text-gray-500">@audit.OldStatus</span>
                                                <span class="mx-2 text-gray-400">&rarr;</span>
                                                <span class="font-semibold text-indigo-700">@audit.NewStatus</span>
                                            </td>
                                            <td class="px-4 py-3 text-center text-gray-700">
                                                <span>@audit.OldDuration:0.#</span>
                                                <span class="mx-2 text-gray-400">&rarr;</span>
                                                <span class="font-semibold text-gray-950">@audit.NewDuration:0.#</span>
                                            </td>
                                            <td class="px-4 py-3 text-center @diffClass">
                                                @diffText
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Back button -->
                <div class="mt-6 flex justify-end">
                    <a href="/work-calendar" class="inline-flex items-center text-white bg-indigo-600 hover:bg-indigo-700 focus:ring-4 focus:ring-indigo-300 font-medium rounded-lg text-sm px-6 py-2.5 focus:outline-none">
                        Back to Work Calendar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
