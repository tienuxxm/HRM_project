@model Application.WorkCalendars.GetImportBatchSummary.CalendarImportBatchSummaryResponse

@{
    ViewBag.Title = "Import Summary";
    Layout = "_Layout";
}

<div class="w-full">
    <div class="w-full flex flex-col">
        <!-- Minimal Breadcrumb -->
        <div class="flex items-center gap-2 mb-6 font-label-md text-label-md text-on-surface-variant uppercase tracking-widest">
            <span>HRM Management</span>
            <span class="text-[10px] opacity-50">/</span>
            <span>Work Calendar</span>
            <span class="text-[10px] opacity-50">/</span>
            <span class="text-primary font-bold">Import Summary</span>
        </div>

        <!-- Summary Card Wrapper -->
        <div style="min-height: 543px" class="bg-white w-full p-6 rounded-none border border-[#D1D1D1] flex flex-col justify-between">
            <div class="w-full">
                <!-- Status Success Header (Swiss Black Box Banner) -->
                <div class="flex items-start gap-4 p-4 mb-6 bg-white border-2 border-black rounded-none">
                    <div class="bg-black text-white p-2 flex items-center justify-center rounded-none">
                        <span class="material-symbols-outlined text-[24px]">check_circle</span>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-black uppercase tracking-wider">Excel Import Successfully Processed</h2>
                        <p class="text-sm text-gray-600 mt-1 leading-relaxed">
                            Work calendar day configurations have been updated, and affected leave requests have been recalculated automatically.
                        </p>
                    </div>
                </div>

                <!-- Batch Details (Recalculation Summary) -->
                <div class="bg-white border border-[#D1D1D1] p-4 mb-6 rounded-none">
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Recalculation Summary</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 text-sm">
                        <div>
                            <span class="block text-xs font-semibold text-gray-500 uppercase mb-1">File Name</span>
                            <span class="font-semibold text-black">@Model.FileName</span>
                        </div>
                        <div>
                            <span class="block text-xs font-semibold text-gray-500 uppercase mb-1">Processed At</span>
                            <span class="font-semibold text-black font-mono mono">@(Model.ProcessedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</span>
                        </div>
                        <div>
                            <span class="block text-xs font-semibold text-gray-500 uppercase mb-1">Calendar Days Modified</span>
                            <span class="inline-flex items-center rounded-none bg-blue-50 border border-blue-500 px-2.5 py-0.5 text-xs font-bold text-blue-800">@Model.UpdatedDaysCount days</span>
                        </div>
                        <div>
                            <span class="block text-xs font-semibold text-gray-500 uppercase mb-1">Affected Leave Requests</span>
                            <span class="inline-flex items-center rounded-none bg-amber-50 border border-amber-500 px-2.5 py-0.5 text-xs font-bold text-amber-800">@Model.AffectedRequests.Count requests</span>
                        </div>
                    </div>
                </div>

                <!-- Affected Requests Section -->
                <div>
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Recalculation Audit Logs</h3>
                    <div class="overflow-x-auto w-full border border-[#D1D1D1] rounded-none">
                        <table class="min-w-full divide-y divide-[#D1D1D1] text-sm text-left">
                            <thead class="bg-[#eeeeee]">
                                <tr>
                                    <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Employee</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Leave Type</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Date Range</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-center border-r border-[#D1D1D1]">Status Change</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-center border-r border-[#D1D1D1]">Duration Change</th>
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-center">Difference</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-[#D1D1D1] bg-white">
                                @if (!Model.AffectedRequests.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="px-4 py-8 text-center text-gray-500 italic">
                                            No leave requests were affected by this change.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var audit in Model.AffectedRequests)
                                    {
                                        decimal diff = audit.NewDuration - audit.OldDuration;
                                        string diffClass = diff < 0 ? "text-green-600 font-bold font-mono mono" : (diff > 0 ? "text-red-600 font-bold font-mono mono" : "text-gray-500 font-mono mono");
                                        string diffText = diff > 0 ? $"+{diff:0.#}" : $"{diff:0.#}";

                                        <tr class="bg-white hover:bg-[#F1F5F9] transition-colors">
                                            <td class="px-4 py-3 text-gray-900 font-semibold border-r border-[#D1D1D1]">@audit.EmployeeName</td>
                                            <td class="px-4 py-3 text-gray-700 border-r border-[#D1D1D1]">@audit.LeaveTypeName</td>
                                            <td class="px-4 py-3 text-gray-500 font-mono mono border-r border-[#D1D1D1]">@audit.StartDate.ToString("yyyy-MM-dd") to @audit.EndDate.ToString("yyyy-MM-dd")</td>
                                            <td class="px-4 py-3 text-center border-r border-[#D1D1D1]">
                                                <span class="text-gray-500">@audit.OldStatus</span>
                                                <span class="mx-2 text-gray-400">&rarr;</span>
                                                <span class="font-semibold text-indigo-700">@audit.NewStatus</span>
                                            </td>
                                            <td class="px-4 py-3 text-center text-gray-700 border-r border-[#D1D1D1] font-mono mono">
                                                <span>@audit.OldDuration.ToString("0.#")</span>
                                                <span class="mx-2 text-gray-400">&rarr;</span>
                                                <span class="font-semibold text-gray-950">@audit.NewDuration.ToString("0.#")</span>
                                            </td>
                                            <td class="px-4 py-3 text-center @diffClass">
                                                @diffText
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Action Button -->
                <div class="mt-6 flex justify-end">
                    <a href="/work-calendar" class="bg-black border border-black text-white px-6 py-2.5 font-semibold text-sm uppercase tracking-wider hover:bg-white hover:text-black rounded-none transition-colors">
                        Back to Work Calendar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
