@model List<Application.WorkCalendars.GetWorkCalendarDays.WorkCalendarDayResponse>

@{
    ViewBag.Title = "Work Calendar List";
    Layout = "_Layout";
    int currentYear = ViewBag.CurrentYear;
    int? currentMonth = ViewBag.CurrentMonth;
    bool canUpdate = ViewBag.CanUpdate;
}

<div class="w-full">
    <div class="w-full flex flex-col">
        <!-- Main Card Wrapper -->
        <div style="min-height: 543px" class="bg-white w-full p-6 rounded-none border border-[#D1D1D1] flex flex-col justify-between">
            <div class="w-full">
                <!-- Header Actions (Filter Form & Action Buttons) -->
                <div class="flex flex-col md:flex-row md:items-end md:justify-between pb-6 border-b border-[#D1D1D1] gap-4">
                    <form method="get" action="/work-calendar" class="flex flex-wrap items-end gap-4">
                        <div class="flex flex-col gap-2">
                            <label class="font-label-sm text-label-sm uppercase text-gray-500">Year</label>
                            <input type="number" name="year" value="@currentYear" min="2000" max="2100"
                                   class="border border-black bg-white px-4 py-2 w-32 font-body-md rounded-none focus:ring-0 focus:border-black outline-none" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="font-label-sm text-label-sm uppercase text-gray-500">Month</label>
                            <select name="month" class="border border-black bg-white px-4 py-2 w-48 font-body-md rounded-none focus:ring-0 focus:border-black outline-none appearance-none">
                                <option value="">All Months</option>
                                @for (int m = 1; m <= 12; m++)
                                {
                                    if (currentMonth == m)
                                    {
                                        <option value="@m" selected>@(new DateTime(2026, m, 1).ToString("MMMM"))</option>
                                    }
                                    else
                                    {
                                        <option value="@m">@(new DateTime(2026, m, 1).ToString("MMMM"))</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <button type="submit" class="bg-white border border-black text-black px-6 py-2 h-[42px] font-semibold text-sm uppercase tracking-wider hover:bg-black hover:text-white transition-colors rounded-none">
                                Filter
                            </button>
                        </div>
                    </form>

                    <div class="flex flex-wrap items-center gap-2">
                        <a href="/work-calendar/download-template" class="bg-white border border-black text-black px-6 py-2 h-[42px] inline-flex items-center gap-2 font-semibold text-sm uppercase tracking-wider hover:bg-gray-100 transition-colors rounded-none">
                            <span class="material-symbols-outlined text-[18px]">download</span>
                            Download Template
                        </a>

                        @if (canUpdate)
                        {
                            <button type="button" onclick="openManualModal('', 'PublicHoliday', 'None', '', true)" class="bg-black border border-black text-white px-6 py-2 h-[42px] inline-flex items-center gap-2 font-semibold text-sm uppercase tracking-wider hover:bg-white hover:text-black hover:border-black transition-colors rounded-none">
                                <span class="material-symbols-outlined text-[18px]">add</span>
                                Add Calendar Day
                            </button>
                            <button type="button" onclick="openImportModal()" class="bg-black border border-black text-white px-6 py-2 h-[42px] inline-flex items-center gap-2 font-semibold text-sm uppercase tracking-wider hover:bg-white hover:text-black hover:border-black transition-colors rounded-none">
                                <span class="material-symbols-outlined text-[18px]">upload</span>
                                Import Excel
                            </button>
                        }
                    </div>
                </div>

                <!-- Table Content -->
                <div class="overflow-x-auto w-full mt-6 border border-[#D1D1D1] rounded-none">
                    <table class="min-w-full divide-y divide-[#D1D1D1] text-sm text-left">
                        <thead class="bg-[#eeeeee]">
                            <tr>
                                <th class="px-4 py-3 font-semibold text-gray-900 text-center w-16 border-r border-[#D1D1D1]">NO</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Date</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Day Type</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Work Shift</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Description</th>
                                <th class="px-4 py-3 font-semibold text-gray-900 text-center w-32 border-r border-[#D1D1D1]">Status</th>
                                @if (canUpdate)
                                {
                                    <th class="px-4 py-3 font-semibold text-gray-900 text-center w-24">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#D1D1D1] bg-white">
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="@(canUpdate ? 7 : 6)" class="px-4 py-8 text-center text-gray-500">
                                        No work calendar days defined for this period.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                int index = 1;
                                foreach (var day in Model)
                                {
                                    <tr class="bg-white hover:bg-[#F1F5F9] transition-colors group">
                                        <td class="px-4 py-3 text-center text-gray-900 font-mono mono">@index</td>
                                        <td class="px-4 py-3 text-gray-900 font-mono mono border-r border-[#D1D1D1]">@day.Date.ToString("yyyy-MM-dd")</td>
                                        <td class="px-4 py-3 border-r border-[#D1D1D1]">
                                            @if (day.DayType == "PublicHoliday")
                                            {
                                                <span class="inline-flex items-center rounded-none border border-red-500 bg-red-50 px-2.5 py-0.5 text-xs font-semibold text-red-800">Public Holiday</span>
                                            }
                                            else if (day.DayType == "CompanyCustomNonWorkingDay")
                                            {
                                                <span class="inline-flex items-center rounded-none border border-gray-400 bg-gray-50 px-2.5 py-0.5 text-xs font-semibold text-gray-800">Company Non-Working</span>
                                            }
                                            else if (day.DayType == "StandardWorkingDayOverride")
                                            {
                                                <span class="inline-flex items-center rounded-none border border-black bg-white px-2.5 py-0.5 text-xs font-semibold text-black">Working Override</span>
                                            }
                                            else if (day.DayType == "WorkingSaturdayOverride")
                                            {
                                                <span class="inline-flex items-center rounded-none border border-gray-600 bg-gray-100 px-2.5 py-0.5 text-xs font-semibold text-gray-900">Working Saturday</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center rounded-none border border-gray-500 bg-gray-50 px-2.5 py-0.5 text-xs font-semibold text-gray-800">@day.DayType</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 text-gray-700 border-r border-[#D1D1D1]">@day.WorkShift</td>
                                        <td class="px-4 py-3 text-gray-500 border-r border-[#D1D1D1]">@(day.Description ?? "-")</td>
                                        <td class="px-4 py-3 text-center border-r border-[#D1D1D1]">
                                            @if (day.IsActive)
                                            {
                                                <span class="inline-flex items-center rounded-none border border-black bg-white px-2.5 py-0.5 text-xs font-semibold text-black">Active</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center rounded-none border border-red-500 bg-red-50 px-2.5 py-0.5 text-xs font-semibold text-red-800">Inactive</span>
                                            }
                                        </td>
                                        @if (canUpdate)
                                        {
                                            <td class="px-4 py-3 text-center">
                                                <button type="button"
                                                        class="js-edit-calendar text-black underline hover:text-gray-600 font-semibold bg-transparent border-0 focus:outline-none" data-date="@day.Date.ToString("yyyy-MM-dd")" data-day-type="@day.DayType" data-work-shift="@day.WorkShift" data-description="@(day.Description ?? "")" data-is-active="@(day.IsActive ? "true" : "false")"
                                                        >
                                                    Edit
                                                </button>
                                            </td>
                                        }
                                    </tr>
                                    index++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Import Excel Modal -->
<div id="importModal" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative w-full max-w-lg max-h-full">
        <div class="relative bg-white border-2 border-black rounded-none shadow-none">
            <button type="button" class="absolute top-3 right-3 text-black bg-transparent hover:bg-gray-100 border border-black w-8 h-8 flex justify-center items-center rounded-none focus:outline-none" onclick="closeImportModal()">
                <span class="material-symbols-outlined text-[16px]">close</span>
            </button>
            <div class="px-6 py-6">
                <div class="flex items-start gap-4">
                    <div class="flex-shrink-0 flex items-center justify-center h-10 w-10 border border-black bg-gray-50 rounded-none">
                        <span class="material-symbols-outlined text-black">upload_file</span>
                    </div>
                    <div class="text-left w-full">
                        <h3 class="text-lg font-bold uppercase tracking-wider text-black border-b border-black pb-2" id="modal-title">Import Work Calendar</h3>
                        <div class="mt-3">
                            <p class="text-sm text-gray-600 leading-relaxed">
                                Select a valid Excel file to import day overrides. Duplicate dates in Excel will update current day records.
                            </p>
                        </div>
                        <div class="mt-4">
                            <input type="file" id="excelFile" accept=".xlsx" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:border file:border-black file:text-sm file:font-semibold file:bg-black file:text-white hover:file:bg-white hover:file:text-black hover:file:border-black rounded-none focus:outline-none" />
                        </div>
                        <div id="uploadError" class="mt-2 text-sm text-red-600 hidden font-bold"></div>
                    </div>
                </div>

                <div class="mt-6 flex items-center justify-end space-x-3 border-t border-gray-200 pt-4">
                    <button type="button" onclick="closeImportModal()"
                            class="text-black bg-white border border-black font-semibold text-sm uppercase tracking-wider px-5 py-2.5 hover:bg-gray-100 rounded-none">
                        Cancel
                    </button>
                    <button type="button" onclick="uploadExcel()" id="uploadBtn"
                            class="text-white bg-black border border-black font-semibold text-sm uppercase tracking-wider px-5 py-2.5 hover:bg-white hover:text-black rounded-none transition-colors">
                        Upload
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Manual Day Modal -->
<div id="manualModal" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative w-full max-w-3xl max-h-full">
        <div class="relative bg-white border-2 border-black rounded-none shadow-none">
            <button type="button" class="absolute top-3 right-3 text-black bg-transparent hover:bg-gray-100 border border-black w-8 h-8 flex justify-center items-center rounded-none focus:outline-none" onclick="closeManualModal()">
                <span class="material-symbols-outlined text-[16px]">close</span>
            </button>
            <div class="px-6 py-6">
                <h3 class="mb-4 text-lg font-bold uppercase tracking-wider text-black border-b border-black pb-2" id="manual-modal-title">
                    Manual Calendar Day
                </h3>
                <form id="manualForm" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="manualDate" class="block mb-1 text-xs font-semibold uppercase text-gray-500">Date</label>
                            <input type="date" id="manualDate" required
                                   class="bg-white border border-black text-black text-sm rounded-none focus:ring-0 focus:border-black block w-full p-2.5" />
                        </div>
                        <div>
                            <label for="manualIsActive" class="block mb-1 text-xs font-semibold uppercase text-gray-500">Active Status</label>
                            <div class="flex items-center h-[46px] px-3 bg-white border border-black rounded-none">
                                <input type="checkbox" id="manualIsActive" checked
                                       class="w-4 h-4 text-black bg-white border-black rounded-none focus:ring-0 focus:ring-offset-0" />
                                <span class="ml-2 text-sm font-semibold text-black">Active</span>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="manualDayType" class="block mb-1 text-xs font-semibold uppercase text-gray-500">Day Type</label>
                            <select id="manualDayType" onchange="adjustWorkShiftOptions()"
                                    class="bg-white border border-black text-black text-sm rounded-none focus:ring-0 focus:border-black block w-full p-2.5">
                                <option value="PublicHoliday">Public Holiday</option>
                                <option value="CompanyCustomNonWorkingDay">Company Non-Working</option>
                                <option value="StandardWorkingDayOverride">Standard Working Day Override</option>
                                <option value="WorkingSaturdayOverride">Working Saturday Override</option>
                            </select>
                        </div>
                        <div>
                            <label for="manualWorkShift" class="block mb-1 text-xs font-semibold uppercase text-gray-500">Work Shift</label>
                            <select id="manualWorkShift"
                                    class="bg-white border border-black text-black text-sm rounded-none focus:ring-0 focus:border-black block w-full p-2.5">
                                <option value="None">None</option>
                                <option value="FullDay">FullDay</option>
                                <option value="MorningOnly">MorningOnly</option>
                                <option value="AfternoonOnly">AfternoonOnly</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label for="manualDescription" class="block mb-1 text-xs font-semibold uppercase text-gray-500">Description</label>
                        <textarea id="manualDescription" rows="2"
                                  class="bg-white border border-black text-black text-sm rounded-none focus:ring-0 focus:border-black block w-full p-2.5"
                                  placeholder="E.g., National Day, Make up day..."></textarea>
                    </div>

                    <div id="manualValidationError" class="text-sm text-red-600 hidden font-bold"></div>

                    <!-- Dynamic Preview Section inside Form -->
                    <div id="manualDynamicPreview" class="mt-6 pt-6 border-t border-black hidden">
                        <h4 class="text-sm font-bold uppercase tracking-wider text-black mb-3">Affected Leave Requests (Preview)</h4>

                        <div id="manualPreviewLoading" class="flex items-center justify-center py-4 hidden">
                            <svg class="animate-spin h-5 w-5 text-black mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span class="text-sm text-gray-600">Analyzing affected requests...</span>
                        </div>

                        <div id="previewWarningBanner" class="p-4 mb-4 bg-red-50 border-l-4 border-[#E62429] text-red-900 text-sm hidden rounded-none">
                            <div class="flex items-start">
                                <span class="material-symbols-outlined text-[#E62429] mr-2">warning</span>
                                <div>
                                    <span class="font-bold">Attention!</span> Some approved requests will be reopened to <span class="font-bold">Pending</span> and their leave balance will be restored.
                                </div>
                            </div>
                        </div>

                        <div id="previewNoEffects" class="p-3 bg-gray-50 text-gray-900 text-xs font-semibold hidden rounded-none border-l-4 border-gray-400">
                            No leave requests are affected by this calendar change.
                        </div>

                        <div id="previewTableContainer" class="overflow-x-auto w-full max-h-60 border border-[#D1D1D1] rounded-none hidden">
                            <table class="min-w-full divide-y divide-[#D1D1D1] text-xs text-left">
                                <thead class="bg-[#eeeeee]">
                                    <tr>
                                        <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Employee</th>
                                        <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Dates</th>
                                        <th class="px-4 py-3 font-semibold text-gray-900 border-r border-[#D1D1D1]">Type</th>
                                        <th class="px-4 py-3 text-center font-semibold text-gray-900 border-r border-[#D1D1D1]">Old</th>
                                        <th class="px-4 py-3 text-center font-semibold text-gray-900 border-r border-[#D1D1D1]">New</th>
                                        <th class="px-4 py-3 text-center font-semibold text-gray-900">Status</th>
                                    </tr>
                                </thead>
                                <tbody id="previewTableBody" class="divide-y divide-[#D1D1D1] bg-white">
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="mt-6 flex items-center justify-end space-x-3 border-t border-[#D1D1D1] pt-4">
                        <button type="button" onclick="closeManualModal()"
                                class="text-black bg-white border border-black font-semibold text-sm uppercase tracking-wider px-5 py-2.5 hover:bg-gray-100 rounded-none">
                            Cancel
                        </button>
                        <button type="button" onclick="saveManualChange()" id="confirmSaveBtn" disabled
                                class="text-white bg-black border border-black font-semibold text-sm uppercase tracking-wider px-5 py-2.5 hover:bg-white hover:text-black rounded-none disabled:bg-gray-300 disabled:text-gray-500 disabled:border-gray-300 disabled:cursor-not-allowed">
                            Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div id="customToastContainer" class="fixed top-5 right-5 z-50 flex flex-col gap-2"></div>

@section Scripts {
<script>
    function cleanupModalFocusAndBackdrop(modalElement) {
        if (modalElement && modalElement.contains(document.activeElement)) {
            document.activeElement.blur();
        }

        document.querySelectorAll('[modal-backdrop]').forEach(backdrop => backdrop.remove());
    }

    function openImportModal() {
        $('#excelFile').val('');
        $('#uploadError').addClass('hidden').text('');

        const $targetEl = document.getElementById('importModal');
        const instanceOptions = {
            id: 'importModal',
            override: true
        };
        const modal = new Modal($targetEl, { closable: true }, instanceOptions);
        modal.show();
    }

    // Ensure Backdrop is correctly removed
    function closeImportModal() {
        const $targetEl = document.getElementById('importModal');
        cleanupModalFocusAndBackdrop($targetEl);
        const instanceOptions = {
            id: 'importModal',
            override: true
        };
        const modal = new Modal($targetEl, { closable: true }, instanceOptions);
        modal.hide();
        cleanupModalFocusAndBackdrop($targetEl);
    }

    function showToast(message, isSuccess = true) {
        const id = 'toast-' + Math.random().toString(36).substr(2, 9);
        const bgClass = isSuccess ? 'bg-white text-gray-900 border border-black shadow-none rounded-none' : 'bg-white text-red-700 border border-red-500 shadow-none rounded-none';
        const iconColor = isSuccess ? 'text-black' : 'text-red-500';
        const iconName = isSuccess ? 'check_circle' : 'error';

        const html = `
            <div id="${id}" class="flex items-center w-full max-w-xs p-4 border ${bgClass} transition-all duration-300 transform translate-x-full" role="alert">
                <span class="material-symbols-outlined ${iconColor} mr-2">${iconName}</span>
                <div class="ml-3 text-sm font-semibold">${message}</div>
                <button type="button" class="ml-auto -mx-1.5 -my-1.5 bg-transparent text-gray-500 hover:text-black p-1.5 inline-flex items-center justify-center h-8 w-8 focus:outline-none" onclick="$('#${id}').remove()">
                    <span class="material-symbols-outlined text-[16px]">close</span>
                </button>
            </div>
        `;

        $('#customToastContainer').append(html);

        // Animate slide in
        setTimeout(() => {
            $(`#${id}`).removeClass('translate-x-full');
        }, 50);

        // Auto remove
        setTimeout(() => {
            $(`#${id}`).addClass('opacity-0 translate-x-full');
            setTimeout(() => {
                $(`#${id}`).remove();
            }, 300);
        }, 4000);
    }

    function uploadExcel() {
        const fileInput = document.getElementById('excelFile');
        if (!fileInput.files || fileInput.files.length === 0) {
            $('#uploadError').removeClass('hidden').text('Please select a file.');
            return;
        }

        const file = fileInput.files[0];
        const formData = new FormData();
        formData.append('file', file);

        $('#uploadBtn').prop('disabled', true).text('Uploading...');
        $('#uploadError').addClass('hidden');

        $.ajax({
            url: '/work-calendar/upload',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function(response) {
                if (response.success) {
                    closeImportModal();
                    showToast('Excel uploaded successfully. Redirecting to preview...', true);
                    setTimeout(() => {
                        window.location.href = '/work-calendar/preview/' + response.batchId;
                    }, 1000);
                } else {
                    $('#uploadBtn').prop('disabled', false).text('Upload');
                    $('#uploadError').removeClass('hidden').text(response.message || 'Failed to upload.');
                }
            },
            error: function() {
                $('#uploadBtn').prop('disabled', false).text('Upload');
                $('#uploadError').removeClass('hidden').text('An error occurred during upload.');
            }
        });
    }

    function openManualModal(dateStr = '', dayType = 'PublicHoliday', workShift = 'None', description = '', isActive = true) {
        $('#manualValidationError').addClass('hidden').text('');
        $('#manualDynamicPreview').addClass('hidden');
        $('#confirmSaveBtn').prop('disabled', true).text('Save');

        $('#manualDate').val(dateStr);
        if (dateStr) {
            $('#manualDate').prop('readonly', true);
            $('#manualDate').removeAttr('min');
        } else {
            $('#manualDate').prop('readonly', false);
            const todayStr = new Date().toLocaleDateString('en-CA');
            $('#manualDate').attr('min', todayStr);
        }

        $('#manualDayType').val(dayType);
        $('#manualWorkShift').val(workShift);
        $('#manualDescription').val(description);
        $('#manualIsActive').prop('checked', isActive);

        adjustWorkShiftOptions();

        const $targetEl = document.getElementById('manualModal');
        const instanceOptions = {
            id: 'manualModal',
            override: true
        };
        const modal = new Modal($targetEl, { closable: true }, instanceOptions);
        modal.show();

        // Trigger preview if we edit an existing configuration
        if (dateStr) {
            triggerPreviewManualChange();
        }
    }

    function closeManualModal() {
        const $targetEl = document.getElementById('manualModal');
        cleanupModalFocusAndBackdrop($targetEl);
        const instanceOptions = {
            id: 'manualModal',
            override: true
        };
        const modal = new Modal($targetEl, { closable: true }, instanceOptions);
        modal.hide();
        cleanupModalFocusAndBackdrop($targetEl);
        $('#manualForm')[0].reset();
        $('#manualValidationError').addClass('hidden').text('');
        $('#manualDynamicPreview').addClass('hidden');
        $('#confirmSaveBtn').prop('disabled', true).text('Save');
    }

    function adjustWorkShiftOptions() {
        const dayType = $('#manualDayType').val();
        const workShiftSelect = $('#manualWorkShift');

        if (dayType === 'PublicHoliday' || dayType === 'CompanyCustomNonWorkingDay') {
            workShiftSelect.val('None');
            workShiftSelect.find('option[value!="None"]').prop('disabled', true);
        } else {
            workShiftSelect.find('option').prop('disabled', false);
            if (workShiftSelect.val() === 'None') {
                workShiftSelect.val('FullDay');
            }
        }
    }

    let previewTimeout = null;

    function triggerPreviewManualChange() {
        if (previewTimeout) {
            clearTimeout(previewTimeout);
        }

        previewTimeout = setTimeout(() => {
            const date = $('#manualDate').val();
            if (!date) {
                $('#manualDynamicPreview').addClass('hidden');
                $('#confirmSaveBtn').prop('disabled', true);
                $('#manualValidationError').addClass('hidden').text('');
                return;
            }

            const dayType = $('#manualDayType').val();
            const workShift = $('#manualWorkShift').val();
            const isActive = $('#manualIsActive').is(':checked');

            if ((dayType === 'PublicHoliday' || dayType === 'CompanyCustomNonWorkingDay') && workShift !== 'None') {
                $('#manualValidationError').removeClass('hidden').text('Non-working days must have Work Shift set to None.');
                $('#manualDynamicPreview').addClass('hidden');
                $('#confirmSaveBtn').prop('disabled', true);
                return;
            }
            if ((dayType === 'StandardWorkingDayOverride' || dayType === 'WorkingSaturdayOverride') && workShift === 'None') {
                $('#manualValidationError').removeClass('hidden').text('Working override days cannot have Work Shift set to None.');
                $('#manualDynamicPreview').addClass('hidden');
                $('#confirmSaveBtn').prop('disabled', true);
                return;
            }

            $('#manualValidationError').addClass('hidden').text('');
            $('#manualDynamicPreview').removeClass('hidden');

            $('#manualPreviewLoading').removeClass('hidden');
            $('#previewWarningBanner').addClass('hidden');
            $('#previewNoEffects').addClass('hidden');
            $('#previewTableContainer').addClass('hidden');
            $('#confirmSaveBtn').prop('disabled', true);

            $.ajax({
                url: '/work-calendar/preview-manual',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    date: date,
                    dayType: dayType,
                    workShift: workShift,
                    isActive: isActive
                }),
                success: function(response) {
                    $('#manualPreviewLoading').addClass('hidden');
                    if (response.success) {
                        showPreviewResults(response.affectedRequests);
                        $('#confirmSaveBtn').prop('disabled', false);
                    } else {
                        $('#manualValidationError').removeClass('hidden').text(response.message || 'Error loading preview.');
                        $('#manualDynamicPreview').addClass('hidden');
                        $('#confirmSaveBtn').prop('disabled', true);
                    }
                },
                error: function() {
                    $('#manualPreviewLoading').addClass('hidden');
                    $('#manualValidationError').removeClass('hidden').text('Failed to load preview from server.');
                    $('#manualDynamicPreview').addClass('hidden');
                    $('#confirmSaveBtn').prop('disabled', true);
                }
            });
        }, 300);
    }

    function showPreviewResults(affectedRequests) {
        const tbody = $('#previewTableBody');
        tbody.empty();

        if (!affectedRequests || affectedRequests.length === 0) {
            $('#previewNoEffects').removeClass('hidden');
            $('#previewWarningBanner').addClass('hidden');
            $('#previewTableContainer').addClass('hidden');
            return;
        }

        $('#previewNoEffects').addClass('hidden');
        $('#previewTableContainer').removeClass('hidden');

        let hasApproved = false;
        affectedRequests.forEach(req => {
            if (req.oldStatus === 'Approved' || req.newStatus === 'Pending') {
                hasApproved = true;
            }

            const row = `
                <tr class="bg-white hover:bg-[#F1F5F9] transition-colors">
                    <td class="px-3 py-2 text-gray-900 font-semibold border-r border-[#D1D1D1]">${req.employeeName}</td>
                    <td class="px-3 py-2 text-gray-500 font-mono mono border-r border-[#D1D1D1]">${req.startDate} to ${req.endDate}</td>
                    <td class="px-3 py-2 text-gray-700 border-r border-[#D1D1D1]">${req.leaveTypeName}</td>
                    <td class="px-3 py-2 text-center text-gray-500 font-semibold font-mono mono border-r border-[#D1D1D1]">${req.oldDuration}</td>
                    <td class="px-3 py-2 text-center text-black font-bold font-mono mono border-r border-[#D1D1D1]">${req.newDuration}</td>
                    <td class="px-3 py-2 text-center">
                        <span class="inline-flex items-center rounded-none px-2 py-0.5 text-xs font-semibold border ${
                            req.oldStatus === 'Approved' ? 'bg-red-50 text-red-800 border-[#E62429]' : 'bg-gray-50 text-gray-800 border-gray-300'
                        }">${req.oldStatus} &rarr; ${req.newStatus}</span>
                    </td>
                </tr>
            `;
            tbody.append(row);
        });

        if (hasApproved) {
            $('#previewWarningBanner').removeClass('hidden');
        } else {
            $('#previewWarningBanner').addClass('hidden');
        }
    }

    function saveManualChange() {
        const date = $('#manualDate').val();
        const dayType = $('#manualDayType').val();
        const workShift = $('#manualWorkShift').val();
        const description = $('#manualDescription').val();
        const isActive = $('#manualIsActive').is(':checked');

        $('#confirmSaveBtn').prop('disabled', true).text('Saving...');

        $.ajax({
            url: '/work-calendar/save-manual',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                date: date,
                dayType: dayType,
                workShift: workShift,
                description: description,
                isActive: isActive
            }),
            success: function(response) {
                if (response.success) {
                    closeManualModal();
                    showToast('Calendar day saved successfully.', true);
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                } else {
                    $('#confirmSaveBtn').prop('disabled', false).text('Save');
                    $('#manualValidationError').removeClass('hidden').text('Error: ' + response.message);
                    showToast('Failed to save configuration: ' + response.message, false);
                }
            },
            error: function() {
                $('#confirmSaveBtn').prop('disabled', false).text('Save');
                $('#manualValidationError').removeClass('hidden').text('An error occurred while saving.');
                showToast('An error occurred while saving configuration.', false);
            }
        });
    }

    // Attach reactive event handlers
    $(document).ready(function() {
        $('#manualDate, #manualDayType, #manualWorkShift, #manualIsActive').on('change input', function() {
            triggerPreviewManualChange();
        });

        $(document).on('click', '.js-edit-calendar', function() {
            const dateStr = $(this).data('date') || '';
            const dayType = $(this).data('day-type') || 'PublicHoliday';
            const workShift = $(this).data('work-shift') || 'None';
            const description = $(this).data('description') || '';
            const isActive = $(this).data('is-active') === true || $(this).data('is-active') === 'true';

            openManualModal(dateStr, dayType, workShift, description, isActive);
        });
    });
</script>
}
