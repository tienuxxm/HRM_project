@using Application.Roles.GetOne
@model List<Domain.Employees.Employee>

@{
    ViewBag.Title = "Employee List";
    Layout = "_Layout";
    var departments = ViewBag.Departments as List<Domain.Departments.Department> ?? new List<Domain.Departments.Department>();
    var roles = ViewBag.Roles as List<RoleResponse> ?? new List<RoleResponse>();
}

<div class="w-full flex flex-col gap-6">
    <!-- Dummy inputs to intercept browser autofill -->
    <div style="position: absolute; top: -1000px; left: -1000px; width: 1px; height: 1px; overflow: hidden;">
        <input type="text" name="username_fake" autocomplete="off" />
        <input type="password" name="password_fake" autocomplete="new-password" />
    </div>
    <!-- Section Header -->
    <section class="space-y-2">
        <h2 class="font-headline-sm text-2xl font-bold uppercase tracking-tight text-black" style="font-family: 'Geist', sans-serif;">Employees</h2>
        <p class="text-gray-500 font-body-md text-sm leading-tight max-w-[90%]" style="font-family: 'Geist', sans-serif;">Manage HRM employee records, status, departments, and reporting lines.</p>
    </section>

    <!-- Filter Bar (Desktop): visible on large screens and up -->
    <div class="hidden lg:flex flex-wrap items-end gap-4 pb-6 border-b border-swiss-border">
        <div class="flex flex-col gap-1">
            <label class="text-[10px] uppercase font-bold tracking-wider text-gray-500 font-mono">Search Directory</label>
            <div class="relative">
                <input id="searchInput" autocomplete="off" class="w-[320px] bg-white border border-swiss-border px-4 py-2 text-xs font-mono rounded-none focus:border-black focus:ring-0 placeholder:text-gray-400" placeholder="Search by name, code or email..." type="text"/>
                <span class="material-symbols-outlined absolute right-3 top-2.5 text-gray-400">search</span>
            </div>
        </div>
        <div class="flex flex-col gap-1">
            <label class="text-[10px] uppercase font-bold tracking-wider text-gray-500 font-mono">Dept</label>
            <select id="deptFilter" class="bg-white border border-swiss-border px-3 py-2 text-xs font-mono rounded-none focus:border-black focus:ring-0 min-w-[160px]">
                <option value="">ALL DEPARTMENTS</option>
                @foreach (var dept in departments)
                {
                    <option value="@dept.Name.ToUpper()">@dept.Name.ToUpper()</option>
                }
            </select>
        </div>
        <div class="flex flex-col gap-1">
            <label class="text-[10px] uppercase font-bold tracking-wider text-gray-500 font-mono">Position</label>
            <select id="positionFilter" class="bg-white border border-swiss-border px-3 py-2 text-xs font-mono rounded-none focus:border-black focus:ring-0 min-w-[160px]">
                <option value="">ALL POSITIONS</option>
                @foreach (var pos in ViewBag.Positions as List<Domain.Positions.Position> ?? new List<Domain.Positions.Position>())
                {
                    <option value="@pos.Name.ToUpper()">@pos.Name.ToUpper()</option>
                }
            </select>
        </div>
        <div class="flex flex-col gap-1">
            <label class="text-[10px] uppercase font-bold tracking-wider text-gray-500 font-mono">Status</label>
            <select id="statusFilter" class="bg-white border border-swiss-border px-3 py-2 text-xs font-mono rounded-none focus:border-black focus:ring-0 min-w-[120px]">
                <option value="">ALL STATUS</option>
                <option value="ACTIVE">ACTIVE</option>
                <option value="INACTIVE">INACTIVE</option>
            </select>
        </div>
        <div class="ml-auto">
            <button type="button" data-modal-target="createEmployeeModal" data-modal-toggle="createEmployeeModal"
                    class="bg-black text-white px-6 py-2.5 text-xs font-bold uppercase tracking-widest rounded-none hover:bg-white hover:text-black hover:border hover:border-black border border-black transition-all flex items-center gap-2 cursor-pointer">
                <span class="material-symbols-outlined">add</span> ADD EMPLOYEE
            </button>
        </div>
    </div>

    <!-- Filter Bar (Mobile): visible on mobile devices -->
    <div class="block lg:hidden space-y-4 pb-4 border-b border-swiss-border">
        <button type="button" data-modal-target="createEmployeeModal" data-modal-toggle="createEmployeeModal"
                class="w-full bg-black text-white py-4 font-bold uppercase tracking-widest text-sm hover:bg-white hover:text-black hover:border hover:border-black border border-black transition-all duration-75 cursor-pointer">
            + Add Employee
        </button>
        <div class="relative">
            <input id="mobileSearchInput" autocomplete="off" class="w-full border border-swiss-border bg-white px-4 py-3 font-mono text-[11px] placeholder:text-outline outline-none focus:border-black focus:ring-0" placeholder="SEARCH BY CODE / NAME / EMAIL..." type="text"/>
        </div>
        <div class="grid grid-cols-2 gap-2">
            <select id="mobileDeptFilter" class="w-full border border-swiss-border bg-white px-3 py-3 font-mono text-[11px] outline-none focus:border-black focus:ring-0">
                <option value="">DEPT: ALL</option>
                @foreach (var dept in departments)
                {
                    <option value="@dept.Name.ToUpper()">@dept.Name.ToUpper()</option>
                }
            </select>
            <select id="mobileStatusFilter" class="w-full border border-swiss-border bg-white px-3 py-3 font-mono text-[11px] outline-none focus:border-black focus:ring-0">
                <option value="">STATUS: ALL</option>
                <option value="ACTIVE">ACTIVE</option>
                <option value="INACTIVE">INACTIVE</option>
            </select>
        </div>
    </div>

    <!-- Desktop Table View: visible on large screens and up -->
    <div class="hidden lg:block bg-white border border-[#D1D1D1] overflow-x-auto w-full">
        <table id="employeeTable" class="w-full border-collapse text-[11px] leading-[14px]">
            <thead class="bg-[#F5F5F5]">
                <tr class="border-b border-[#D1D1D1]">
                    <th class="px-3 py-2 font-bold text-[#4c4546] text-left border-r border-[#D1D1D1] uppercase tracking-wider w-[100px] text-[12px]" style="font-family: 'Geist', sans-serif;">CODE</th>
                    <th class="px-3 py-2 font-bold text-[#4c4546] border-r border-[#D1D1D1] uppercase tracking-wider text-left text-[12px]" style="font-family: 'Geist', sans-serif;">NAME</th>
                    <th class="px-3 py-2 font-bold text-[#4c4546] border-r border-[#D1D1D1] uppercase tracking-wider text-left text-[12px]" style="font-family: 'Geist', sans-serif;">EMAIL</th>
                    <th class="px-3 py-2 font-bold text-[#4c4546] border-r border-[#D1D1D1] uppercase tracking-wider text-left text-[12px]" style="font-family: 'Geist', sans-serif;">DEPT</th>
                    <th class="px-3 py-2 font-bold text-[#4c4546] border-r border-[#D1D1D1] uppercase tracking-wider text-left text-[12px]" style="font-family: 'Geist', sans-serif;">POSITION</th>
                    <th class="px-3 py-2 font-bold text-[#4c4546] border-r border-[#D1D1D1] uppercase tracking-wider text-left text-[12px]" style="font-family: 'Geist', sans-serif;">SYSTEM ACCOUNT</th>
                    <th class="px-3 py-2 font-bold text-[#4c4546] border-r border-[#D1D1D1] uppercase tracking-wider text-center w-[90px] text-[12px]" style="font-family: 'Geist', sans-serif;">STATUS</th>
                    <th class="px-3 py-2 font-bold text-[#4c4546] uppercase tracking-wider text-right w-[180px] text-[12px]" style="font-family: 'Geist', sans-serif;">ACTIONS</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#D1D1D1]">
            @foreach (var emp in @Model)
            {
                <tr class="hover:bg-[#F8F8F8] border-b border-[#D1D1D1] transition-colors duration-150 cursor-pointer">
                    <td class="emp-code whitespace-nowrap px-3 py-2 text-black font-mono font-bold border-r border-[#D1D1D1] text-[11px]">
                        @emp.EmployeeCode
                    </td>
                    <td class="emp-name whitespace-nowrap px-3 py-2 text-black font-bold border-r border-[#D1D1D1] text-left uppercase text-[11px]">
                        @emp.FullName
                    </td>
                    <td class="emp-email whitespace-nowrap px-3 py-2 text-gray-500 font-mono border-r border-[#D1D1D1] text-left text-[11px]">
                        @(emp.EmployeeCode.ToLower() + "@hrm.local")
                    </td>
                    <td class="emp-dept whitespace-nowrap px-3 py-2 text-black border-r border-[#D1D1D1] uppercase text-[11px]">
                        @(emp.Department?.Name ?? "—")
                    </td>
                    <td class="emp-position whitespace-nowrap px-3 py-2 text-black border-r border-[#D1D1D1] text-[11px]">
                        @(emp.Position?.Name ?? "—")
                    </td>
                    <td class="whitespace-nowrap px-3 py-2 border-r border-[#D1D1D1] text-[11px]">
                        @if (emp.UserId == null)
                        {
                            <span class="inline-block border border-[#D1D1D1] bg-[#F5F5F5] text-[#666666] px-[6px] py-[2px] text-[9px] font-mono font-bold uppercase tracking-wider">NO SYSTEM ACCOUNT</span>
                        }
                        else
                        {
                            <div class="flex flex-col gap-0.5">
                                <span class="inline-block border border-black bg-black text-white px-[6px] py-[2px] text-[9px] font-mono font-bold uppercase tracking-wider w-fit">LINKED ACCOUNT</span>
                                @if (emp.User != null && emp.User.Username != null && !string.IsNullOrEmpty(emp.User.Username.Value))
                                {
                                    <span class="font-mono text-[9px] text-black font-bold">Username: @emp.User.Username.Value</span>
                                    @if (emp.User.Email != null && !string.IsNullOrEmpty(emp.User.Email.Value))
                                    {
                                        <span class="font-mono text-[9px] text-[#666666]">Email: @emp.User.Email.Value</span>
                                    }
                                }

                            </div>
                        }
                    </td>

                    <td class="whitespace-nowrap px-3 py-2 text-center border-r border-[#D1D1D1]">
                        <span class="emp-status hidden">@(emp.IsActive ? "ACTIVE" : "INACTIVE")</span>
                        @if (emp.IsActive)
                        {
                            <span class="border border-black px-[6px] py-[2px] text-[9px] font-bold text-black uppercase tracking-widest bg-white">ACTIVE</span>
                        }
                        else
                        {
                            <span class="border border-dashed border-[#cfc4c5] text-[#4c4546] px-[6px] py-[2px] text-[9px] font-bold uppercase tracking-widest bg-[#FAF9F9]">INACTIVE</span>
                        }
                    </td>
                    <td class="whitespace-nowrap px-3 py-2 text-right">
                        <div class="flex justify-end gap-3 text-[11px] font-bold uppercase">
                            @if (emp.UserId == null)
                            {
                                <button type="button" data-modal-target="provisionAccountModal-@emp.Id.Value" data-modal-toggle="provisionAccountModal-@emp.Id.Value"
                                        class="text-black hover:underline cursor-pointer">PROVISION ACCOUNT</button>
                            }
                            else
                            {
                                <span class="text-gray-400 cursor-default font-mono text-[10px]" title="Employee linked to system user account">[LINKED]</span>
                            }
                            <button type="button" data-modal-target="updateEmployeeModal-@emp.Id.Value" data-modal-toggle="updateEmployeeModal-@emp.Id.Value"
                                    class="text-black hover:underline cursor-pointer">EDIT</button>
                            <button type="button" data-modal-target="confirmDelete-@emp.Id.Value" data-modal-toggle="confirmDelete-@emp.Id.Value"
                                    class="text-[#bb0015] hover:underline cursor-pointer">DELETE</button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <!-- Mobile Stacked Card View: visible on smaller screens -->
    <div class="block lg:hidden w-full space-y-4">
        @foreach (var emp in @Model.Select((val, index) => new { val, index = index + 1 }))
        {
            <div class="mobile-card bg-white border border-[#D1D1D1] p-0 flex flex-col @(emp.val.IsActive ? "" : "border-dashed opacity-80")">
                <!-- Card Header -->
                <div class="p-4 border-b border-[#D1D1D1] flex justify-between items-center @(emp.val.IsActive ? "bg-[#FBFBFB]" : "border-dashed bg-[#F4F3F3]")">
                    <span class="card-code font-mono text-[11px] font-bold text-black uppercase tracking-wider">@emp.val.EmployeeCode</span>
                    <span class="card-status hidden">@(emp.val.IsActive ? "ACTIVE" : "INACTIVE")</span>
                    @if (emp.val.IsActive)
                    {
                        <span class="text-[9px] font-bold border border-black px-2 py-0.5 tracking-tighter bg-white">ACTIVE</span>
                    }
                    else
                    {
                        <span class="text-[9px] font-bold border border-dashed border-[#cfc4c5] px-2 py-0.5 tracking-tighter text-[#4c4546] bg-[#FAF9F9]">INACTIVE</span>
                    }
                </div>

                <!-- Card Body -->
                <div class="p-4 space-y-3">
                    <h3 class="font-bold text-lg uppercase leading-none card-name @(emp.val.IsActive ? "" : "text-gray-500")">@emp.val.FullName</h3>
                    <div class="grid grid-cols-[90px_1fr] gap-x-2 gap-y-1 text-[11px]">
                        <span class="text-gray-500 uppercase font-semibold">Dept:</span>
                        <span class="font-medium text-black card-dept uppercase">@(emp.val.Department?.Name ?? "—")</span>
                        <span class="text-gray-500 uppercase font-semibold">Role:</span>
                        <span class="font-medium text-black card-position uppercase">@(emp.val.Position?.Name ?? "—")</span>
                        <span class="text-gray-500 uppercase font-semibold">Email:</span>
                        <span class="font-mono text-[10px] text-black card-email">@(emp.val.EmployeeCode.ToLower() + "@hrm.local")</span>
                        <span class="text-gray-500 uppercase font-semibold">Account:</span>
                        <div>
                            @if (emp.val.UserId == null)
                            {
                                <span class="border border-[#D1D1D1] bg-[#F5F5F5] text-[#666666] px-1.5 py-0.5 text-[9px] font-mono font-bold uppercase">NO SYSTEM ACCOUNT</span>
                            }
                            else
                            {
                                <span class="border border-black bg-black text-white px-1.5 py-0.5 text-[9px] font-mono font-bold uppercase">LINKED ACCOUNT</span>
                            }
                        </div>
                        <span class="text-gray-500 uppercase font-semibold">Report To:</span>
                        <span class="font-medium text-black uppercase">@(emp.val.Manager?.FullName ?? "—")</span>
                    </div>
                </div>

                <!-- Card Actions -->
                <div class="grid grid-cols-3 divide-x divide-[#D1D1D1] border-t border-[#D1D1D1] text-center text-[10px] font-bold @(emp.val.IsActive ? "" : "border-dashed divide-dashed")">
                    @if (emp.val.UserId == null)
                    {
                        <button type="button" data-modal-target="provisionAccountModal-@emp.val.Id.Value" data-modal-toggle="provisionAccountModal-@emp.val.Id.Value" class="py-3 hover:bg-black hover:text-white transition-colors cursor-pointer">[PROVISION]</button>
                    }
                    else
                    {
                        <button type="button" disabled class="py-3 text-gray-400 cursor-not-allowed">[LINKED]</button>
                    }
                    <button type="button" data-modal-target="updateEmployeeModal-@emp.val.Id.Value" data-modal-toggle="updateEmployeeModal-@emp.val.Id.Value" class="py-3 hover:bg-black hover:text-white transition-colors cursor-pointer">[EDIT]</button>
                    <button type="button" data-modal-target="confirmDelete-@emp.val.Id.Value" data-modal-toggle="confirmDelete-@emp.val.Id.Value" class="py-3 text-[#bb0015] hover:bg-[#bb0015] hover:text-white transition-colors cursor-pointer">[DELETE]</button>
                </div>
            </div>
        }
    </div>


    <!-- Desktop Pagination: visible on large screens and up -->
    <div class="hidden lg:flex items-center justify-between border-t border-[#D1D1D1] pt-6 mt-4">
        <div class="font-label-sm text-[10px] uppercase text-gray-500 font-medium tracking-wider" style="font-family: Geist, sans-serif;">
            SHOWING 1-@Model.Count OF @Model.Count EMPLOYEES
        </div>
        <div class="flex items-center gap-4">
            <button class="border border-[#D1D1D1] px-4 py-2 text-xs uppercase opacity-50 cursor-not-allowed font-medium" style="font-family: Geist, sans-serif;">PREV</button>
            <span class="text-xs uppercase font-bold" style="font-family: Geist, sans-serif;">PAGE 1 OF 1</span>
            <button class="border border-[#D1D1D1] px-4 py-2 text-xs uppercase opacity-50 cursor-not-allowed font-medium" style="font-family: Geist, sans-serif;">NEXT</button>
        </div>
    </div>

    <!-- Mobile Pagination: visible on mobile devices -->
    <section class="block lg:hidden space-y-4 pt-4 border-t border-[#D1D1D1] mt-6">
        <div class="font-mono text-[11px] text-center tracking-tight text-gray-500 uppercase">
            Showing 1-@Model.Count of @Model.Count Employees
        </div>
        <div class="grid grid-cols-2 gap-2 font-mono text-[11px] font-bold">
            <button disabled class="border border-black/30 py-3 text-gray-400 cursor-not-allowed">[PREV PAGE]</button>
            <button disabled class="border border-black/30 py-3 text-gray-400 cursor-not-allowed">[NEXT PAGE]</button>
        </div>
    </section>
</div>

<!-- Modal Containers (Rendered once at bottom of page to prevent DOM ID duplication) -->
@Html.Partial("_CreateEmployeePartial")
@foreach (var emp in Model)
{
    if (emp.UserId == null)
    {
        @Html.Partial("_ProvisionAccountPartial", emp)
    }
    @Html.Partial("_UpdateEmployeePartial", emp)
    @Html.Partial("_ConfirmDeletePartial", new ConfirmDeleteViewModel()
    {
        Id = emp.Id.Value,
        Type = "Employee",
        Name = emp.FullName,
        ActionName = "Delete",
        ActionController = "Employee"
    })
}


@section Scripts {
<script>
    function submitProvisionAccount(employeeId) {
        const prefix = 'prov';
        const username = $(`#${prefix}Username-${employeeId}`).val();
        const email = $(`#${prefix}Email-${employeeId}`).val();
        const password = $(`#${prefix}Password-${employeeId}`).val();
        const roleIds = $(`#${prefix}Roles-${employeeId}`).val();
        const errorBox = $(`#provisionError-${employeeId}`);
        const submitBtn = $(`#${prefix}SubmitBtn-${employeeId}`);

        // Reset errors
        errorBox.addClass('hidden').text('');
        $(`#${prefix}UsernameError-${employeeId}`).addClass('hidden').text('');
        $(`#${prefix}EmailError-${employeeId}`).addClass('hidden').text('');
        $(`#${prefix}PasswordError-${employeeId}`).addClass('hidden').text('');
        $(`#${prefix}RolesError-${employeeId}`).addClass('hidden').text('');

        // Client-side validation
        let hasError = false;
        if (!username || username.trim() === '') {
            $(`#${prefix}UsernameError-${employeeId}`).removeClass('hidden').text('Please enter username.');
            hasError = true;
        }
        if (!email || email.trim() === '') {
            $(`#${prefix}EmailError-${employeeId}`).removeClass('hidden').text('Please enter email.');
            hasError = true;
        }
        if (!password || password.trim() === '') {
            $(`#${prefix}PasswordError-${employeeId}`).removeClass('hidden').text('Please enter password.');
            hasError = true;
        } else if (password.length < 6) {
            $(`#${prefix}PasswordError-${employeeId}`).removeClass('hidden').text('Password must be at least 6 characters.');
            hasError = true;
        }
        if (!roleIds || roleIds.length === 0) {
            $(`#${prefix}RolesError-${employeeId}`).removeClass('hidden').text('Please select at least 1 role.');
            hasError = true;
        }
        if (hasError) return;

        // Disable button
        submitBtn.prop('disabled', true).text('PROCESSING...');

        const formData = new FormData();
        formData.append('EmployeeId', employeeId);
        formData.append('Username', username);
        formData.append('Email', email);
        formData.append('Password', password);
        if (roleIds) {
            roleIds.forEach(function(roleId, index) {
                formData.append(`RoleIds[${index}]`, roleId);
            });
        }

        $.ajax({
            type: 'POST',
            url: '/employee/provision-account',
            data: formData,
            processData: false,
            contentType: false,
            success: function (response) {
                showToast('Employee account provisioned successfully!');
                setTimeout(function() {
                    location.href = '/employee';
                }, 1500);
            },
            error: function (xhr) {
                submitBtn.prop('disabled', false).text('PROVISION ACCOUNT');
                let errorMsg = 'An error occurred. Please try again.';
                try {
                    const resp = JSON.parse(xhr.responseText);
                    if (resp.name) errorMsg = resp.name;
                    else if (resp.description) errorMsg = resp.description;
                    else if (resp.Name) errorMsg = resp.Name;
                    else if (resp.Description) errorMsg = resp.Description;
                } catch (e) {}
                errorBox.removeClass('hidden').text(errorMsg);
                showToast(errorMsg, false);
            }
        });
    }

    $(document).ready(function() {

        // Create Employee handler
        $(document).on('click', '#saveEmpButton', function (){
            const toastContainer = $('#toast-container');
            const empFullNameError = $('#empFullNameError');
            empFullNameError.addClass('hidden');
            const empFullName = $('#empFullName').val();
            const empDepartment = $('#empDepartment').val();
            const empPosition = $('#empPosition').val();
            const empJoinDate = $('#empJoinDate').val();

            if(!empFullName || empFullName.trim() === ''){
                empFullNameError.removeClass('hidden').text("Please enter full name");
                return;
            }

            const formData = new FormData();
            formData.append('FullName', empFullName);
            if(empDepartment) formData.append('DepartmentId', empDepartment);
            if(empPosition) formData.append('PositionId', empPosition);
            formData.append('JoinDate', empJoinDate || new Date().toISOString().split('T')[0]);
            $.ajax({
                type: "POST",
                url: `/employee/create`,
                data: formData,
                processData: false,
                contentType: false,
                success: function (e) {
                    toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Employee created successfully" }, null)');
                    setTimeout(() => {
                        location.href="/employee";
                    }, 1500);
                },
                error: function (error){
                    toastContainer.load('@Url.Action("FailToastPartial", "Main", new { message = "Employee creation failed" }, null)');
                },
            });
        });

        // Update Employee handler
        $(document).on('click', '.save-employee-btn', function (){
            const empId = $(this).data('employee-id');
            const toastContainer = $('#toast-container');
            const empCodeError = $(`#empCodeError-${empId}`);
            const empFullNameError = $(`#empFullNameError-${empId}`);
            empCodeError.addClass('hidden');
            empFullNameError.addClass('hidden');

            const empCode = $(`#empCode-${empId}`).val();
            const empFullName = $(`#empFullName-${empId}`).val();
            const empDepartment = $(`#empDepartment-${empId}`).val();
            const empPosition = $(`#empPosition-${empId}`).val();
            const empJoinDate = $(`#empJoinDate-${empId}`).val();

            if(!empCode || empCode.trim() === ''){
                empCodeError.removeClass('hidden').text("Please enter employee code");
                return;
            }
            if(!empFullName || empFullName.trim() === ''){
                empFullNameError.removeClass('hidden').text("Please enter full name");
                return;
            }

            const formData = new FormData();
            formData.append('Id', empId);
            formData.append('EmployeeCode', empCode);
            formData.append('FullName', empFullName);
            if(empDepartment) formData.append('DepartmentId', empDepartment);
            if(empPosition) formData.append('PositionId', empPosition);
            formData.append('JoinDate', empJoinDate || new Date().toISOString().split('T')[0]);

            $.ajax({
                type: "POST",
                url: `/employee/update`,
                data: formData,
                processData: false,
                contentType: false,
                success: function (e) {
                    toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Employee updated successfully" }, null)');
                    setTimeout(() => {
                        location.href="/employee";
                    }, 1500);
                },
                error: function (error){
                    toastContainer.load('@Url.Action("FailToastPartial", "Main", new { message = "Employee update failed" }, null)');
                },
            });
        });

        function filterDirectory() {
            const isMobile = window.innerWidth < 1024;
            let searchQuery = '';
            let selectedDept = '';
            let selectedStatus = '';
            let selectedPosition = '';

            if (isMobile) {
                searchQuery = $('#mobileSearchInput').val().toUpperCase().trim();
                selectedDept = $('#mobileDeptFilter').val().toUpperCase();
                selectedStatus = $('#mobileStatusFilter').val().toUpperCase();
                selectedPosition = $('#positionFilter').val() ? $('#positionFilter').val().toUpperCase() : '';
            } else {
                searchQuery = $('#searchInput').val().toUpperCase().trim();
                selectedDept = $('#deptFilter').val().toUpperCase();
                selectedPosition = $('#positionFilter').val().toUpperCase();
                selectedStatus = $('#statusFilter').val().toUpperCase();
            }

            // Filter Desktop Table
            $('#employeeTable tbody tr').each(function() {
                const code = $(this).find('.emp-code').text().toUpperCase().trim();
                const name = $(this).find('.emp-name').text().toUpperCase().trim();
                const email = $(this).find('.emp-email').text().toUpperCase().trim();
                const dept = $(this).find('.emp-dept').text().toUpperCase().trim();
                const position = $(this).find('.emp-position').text().toUpperCase().trim();
                const status = $(this).find('.emp-status').text().toUpperCase().trim();

                const matchesSearch = code.includes(searchQuery) || name.includes(searchQuery) || email.includes(searchQuery);
                const matchesDept = selectedDept === "" || dept === selectedDept;
                const matchesPosition = selectedPosition === "" || position === selectedPosition;
                const matchesStatus = selectedStatus === "" || status === selectedStatus;

                if (matchesSearch && matchesDept && matchesPosition && matchesStatus) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });

            // Filter Mobile Cards
            $('.mobile-card').each(function() {
                const code = $(this).find('.card-code').text().toUpperCase().trim();
                const name = $(this).find('.card-name').text().toUpperCase().trim();
                const email = $(this).find('.card-email').text().toUpperCase().trim();
                const dept = $(this).find('.card-dept').text().toUpperCase().trim();
                const position = $(this).find('.card-position').text().toUpperCase().trim();
                const status = $(this).find('.card-status').text().toUpperCase().trim();

                const matchesSearch = code.includes(searchQuery) || name.includes(searchQuery) || email.includes(searchQuery);
                const matchesDept = selectedDept === "" || dept === selectedDept;
                const matchesPosition = selectedPosition === "" || position === selectedPosition;
                const matchesStatus = selectedStatus === "" || status === selectedStatus;

                if (matchesSearch && matchesDept && matchesPosition && matchesStatus) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });
        }

        // Sync inputs & filters
        $('#searchInput').on('input', function() {
            $('#mobileSearchInput').val($(this).val());
            filterDirectory();
        });
        $('#mobileSearchInput').on('input', function() {
            $('#searchInput').val($(this).val());
            filterDirectory();
        });

        $('#deptFilter').on('change', function() {
            $('#mobileDeptFilter').val($(this).val());
            filterDirectory();
        });
        $('#mobileDeptFilter').on('change', function() {
            $('#deptFilter').val($(this).val());
            filterDirectory();
        });

        $('#positionFilter').on('change', filterDirectory);

        $('#statusFilter').on('change', function() {
            $('#mobileStatusFilter').val($(this).val());
            filterDirectory();
        });
        $('#mobileStatusFilter').on('change', function() {
            $('#statusFilter').val($(this).val());
            filterDirectory();
        });

        // Clear search inputs and force filter directory once event handlers are ready
        $('#searchInput').val('').trigger('input');
        $('#mobileSearchInput').val('').trigger('input');
        filterDirectory();

        // Interval reset to capture and clear delayed browser autofill attempts
        let autofillChecks = 0;
        const autofillTimer = setInterval(function() {
            autofillChecks++;
            const val = $('#searchInput').val() || $('#mobileSearchInput').val();
            if (val === 'admin' || val === 'admin@hrm.local') {
                $('#searchInput').val('').trigger('input');
                $('#mobileSearchInput').val('').trigger('input');
                filterDirectory();
            }
            if (autofillChecks >= 15) {
                clearInterval(autofillTimer);
            }
        }, 100);
    });
</script>

@if (TempData["ErrorMessage"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            showToast('@Html.Raw(TempData["ErrorMessage"])', false);
        });
    </script>
}
@if (TempData["SuccessMessage"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            showToast('@Html.Raw(TempData["SuccessMessage"])', true);
        });
    </script>
}
}
