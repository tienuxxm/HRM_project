@using Application.Roles.GetOne
@model Domain.Employees.Employee

@{
    var roles = ViewBag.Roles as List<RoleResponse> ?? new List<RoleResponse>();
    var modalId = $"provisionAccountModal-{Model.Id.Value}";
}
<div id="@modalId" tabindex="-1" aria-hidden="true" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Static Backdrop (Enterprise Calm Dim style) -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal content panel -->
        <div class="w-full max-w-[640px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Modal Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">PROVISION ACCOUNT</span>
                <button type="button" class="bg-swiss-accent-red w-8 h-8 flex items-center justify-center hover:bg-swiss-red transition-colors" data-modal-hide="@modalId">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Modal Body -->
            <div class="p-6 grid grid-cols-2 gap-6 text-left">
                <div class="col-span-2">
                    <p class="text-[10px] uppercase tracking-wider text-black/75">
                        EMPLOYEE: <strong class="font-bold text-black font-mono text-[11px]">@Model.FullName (@Model.EmployeeCode)</strong>
                    </p>
                </div>
                
                <div id="provisionError-@Model.Id.Value" class="col-span-2 hidden p-4 text-[10px] font-mono uppercase tracking-wider text-swiss-accent-red bg-[#FFF0F0] border border-swiss-accent-red" role="alert">
                </div>

                <div class="flex flex-col gap-2">
                    <label for="provUsername-@Model.Id.Value" class="font-geist font-bold text-[10px] uppercase tracking-widest text-[#4C4546]">Username <span class="text-swiss-accent-red">*</span></label>
                    <input type="text" placeholder="ENTER USERNAME" id="provUsername-@Model.Id.Value" class="mono-text text-[11px] p-2 bg-white border border-swiss-border focus:ring-0 focus:outline-none focus:border-black rounded-none" required>
                    <p id="provUsernameError-@Model.Id.Value" class="mt-1 text-[10px] font-mono uppercase tracking-wider text-swiss-accent-red hidden"></p>
                </div>
                
                <div class="flex flex-col gap-2">
                    <label for="provEmail-@Model.Id.Value" class="font-geist font-bold text-[10px] uppercase tracking-widest text-[#4C4546]">Email <span class="text-swiss-accent-red">*</span></label>
                    <input type="email" placeholder="ENTER EMAIL" id="provEmail-@Model.Id.Value" class="mono-text text-[11px] p-2 bg-white border border-swiss-border focus:ring-0 focus:outline-none focus:border-black rounded-none" required>
                    <p id="provEmailError-@Model.Id.Value" class="mt-1 text-[10px] font-mono uppercase tracking-wider text-swiss-accent-red hidden"></p>
                </div>
                
                <div class="flex flex-col gap-2">
                    <label for="provPassword-@Model.Id.Value" class="font-geist font-bold text-[10px] uppercase tracking-widest text-[#4C4546]">Password <span class="text-swiss-accent-red">*</span></label>
                    <input type="password" placeholder="MINIMUM 6 CHARACTERS" id="provPassword-@Model.Id.Value" class="mono-text text-[11px] p-2 bg-white border border-swiss-border focus:ring-0 focus:outline-none focus:border-black rounded-none" required>
                    <p id="provPasswordError-@Model.Id.Value" class="mt-1 text-[10px] font-mono uppercase tracking-wider text-swiss-accent-red hidden"></p>
                </div>
                
                <div class="flex flex-col gap-2">
                    <label for="provRoles-@Model.Id.Value" class="font-geist font-bold text-[10px] uppercase tracking-widest text-[#4C4546]">Role <span class="text-swiss-accent-red">*</span></label>
                    <select multiple id="provRoles-@Model.Id.Value" class="font-mono text-[11px] p-2 bg-white border border-swiss-border focus:ring-0 focus:outline-none focus:border-black rounded-none" style="min-height: 80px;">
                        @foreach (var role in roles)
                        {
                            <option value="@role.Id">@role.DisplayName.ToUpper()</option>
                        }
                    </select>
                    <p class="mt-1 text-[9px] uppercase tracking-wider text-black/50 font-mono">Hold CTRL to select multiple.</p>
                    <p id="provRolesError-@Model.Id.Value" class="mt-1 text-[10px] font-mono uppercase tracking-wider text-swiss-accent-red hidden"></p>
                </div>

                <!-- Info Box -->
                <div class="col-span-2 p-4 bg-swiss-light border border-swiss-border">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-[#7e7576] text-[18px]">info</span>
                        <p class="mono-text text-[9px] text-[#4C4546] leading-relaxed uppercase">
                            INFO: PROVISIONING CREATES LOGIN ACCESS AND ROLE-BASED PERMISSIONS.
                        </p>
                    </div>
                </div>
            </div>
            <!-- Modal Footer -->
            <div class="h-16 flex items-center justify-between px-6 bg-white border-t border-swiss-border">
                <div class="mono-text text-[9px] text-[#7e7576] font-bold uppercase tracking-tighter">
                    REALM: <span class="text-black">HRM</span>
                </div>
                <div class="flex gap-4">
                    <button type="button" class="bg-white border border-swiss-border px-6 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-swiss-light transition-colors rounded-none" data-modal-hide="@modalId">
                        CANCEL
                    </button>
                    <button type="button" id="provSubmitBtn-@Model.Id.Value" class="bg-black text-white border border-black px-6 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-white hover:text-black transition-all rounded-none" onclick="submitProvisionAccount('@Model.Id.Value')">
                        PROVISION ACCOUNT
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
