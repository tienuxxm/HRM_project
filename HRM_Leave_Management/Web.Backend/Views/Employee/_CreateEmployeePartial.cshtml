@{
    var departments = ViewBag.Departments as List<Domain.Departments.Department> ?? new List<Domain.Departments.Department>();
    var positions = ViewBag.Positions as List<Domain.Positions.Position> ?? new List<Domain.Positions.Position>();
}
<div id="createEmployeeModal" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative w-full max-w-lg max-h-full">
        <!-- Modal content -->
        <div class="relative bg-white rounded-lg shadow dark:bg-gray-700">
            <button type="button" class="absolute top-3 right-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ml-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="createEmployeeModal">
                <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
                <span class="sr-only">Close modal</span>
            </button>
            <div class="px-6 py-6 lg:px-8">
                <h3 class="mb-4 text-xl font-medium text-gray-900 dark:text-white">Add Employee</h3>
                <div class="space-y-4">
                    <div>
                        <label for="empCode" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Employee Code</label>
                        <input type="text" placeholder="e.g. EMP001" id="empCode" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" required>
                        <p id="empCodeError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                    </div>
                    <div>
                        <label for="empFullName" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Full Name</label>
                        <input type="text" placeholder="Enter Full Name" id="empFullName" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" required>
                        <p id="empFullNameError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                    </div>
                    <div>
                        <label for="empDepartment" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Department (Optional)</label>
                        <select id="empDepartment" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white">
                            <option value="">-- Select Department --</option>
                            @foreach (var dept in departments)
                            {
                                <option value="@dept.Id.Value">@dept.Name</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label for="empPosition" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Position (Optional)</label>
                        <select id="empPosition" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white">
                            <option value="">-- Select Position --</option>
                            @foreach (var pos in positions)
                            {
                                <option value="@pos.Id">@pos.Name</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label for="empJoinDate" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Join Date</label>
                        <input type="date" id="empJoinDate" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" required>
                    </div>
                    <button type="button" id="saveEmpButton" class="w-full text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">Create</button>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    const toastContainer = $('#toast-container')
    const empCodeError = $('#empCodeError')
    const empFullNameError = $('#empFullNameError')
    empCodeError.hide();
    empFullNameError.hide();
    $('#saveEmpButton').on('click', function (){
        empCodeError.hide();
        empFullNameError.hide();
        const empCode = $('#empCode').val()
        const empFullName = $('#empFullName').val()
        const empDepartment = $('#empDepartment').val()
        const empPosition = $('#empPosition').val()
        const empJoinDate = $('#empJoinDate').val()
        
        if(!empCode || empCode.trim() === ''){
            empCodeError.show();
            empCodeError.text("Please enter employee code")
            return;
        }
        if(!empFullName || empFullName.trim() === ''){
            empFullNameError.show();
            empFullNameError.text("Please enter full name")
            return;
        }
    
        const formData = new FormData()
        formData.append('EmployeeCode', empCode)
        formData.append('FullName', empFullName)
        if(empDepartment) formData.append('DepartmentId', empDepartment)
        if(empPosition) formData.append('PositionId', empPosition)
        formData.append('JoinDate', empJoinDate || new Date().toISOString().split('T')[0])
        $.ajax({
            type: "POST",
            url: `/employee/create`,
            data: formData,
            processData: false,
            contentType: false,
            success: function (e) {
                toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Employee created successfully" }, null)')
                setTimeout(() => {
                    location.href="/employee"
                }, 1500)
            },
            error: function (error){
                toastContainer.load('@Url.Action("FailToastPartial", "Main", new { message = "Employee creation failed" }, null)')
            },
        })
    })
</script>
