@{
    var departments = ViewBag.Departments as List<Domain.Departments.Department> ?? new List<Domain.Departments.Department>();
    var positions = ViewBag.Positions as List<Domain.Positions.Position> ?? new List<Domain.Positions.Position>();
}
<div id="createEmployeeModal" tabindex="-1" aria-hidden="true" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Static Backdrop (Enterprise Calm Dim style) -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal content panel -->
        <div class="w-full max-w-[640px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Modal Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">ADD EMPLOYEE</span>
                <button type="button" class="bg-swiss-accent-red w-8 h-8 flex items-center justify-center hover:bg-swiss-red transition-colors" data-modal-hide="createEmployeeModal">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Modal Body -->
            <div class="p-6 grid grid-cols-2 gap-6 text-left">
                <div class="flex flex-col gap-2">
                    <label for="empCode" class="font-geist font-bold text-[10px] uppercase tracking-widest text-[#4C4546]">Employee Code <span class="text-swiss-accent-red">*</span></label>
                    <input type="text" placeholder="E.G. EMP001" id="empCode" class="mono-text text-[11px] p-2 bg-white border border-swiss-border focus:ring-0 focus:outline-none focus:border-black uppercase rounded-none" required>
                    <p id="empCodeError" class="mt-1 text-[10px] font-mono uppercase tracking-wider text-swiss-accent-red hidden"></p>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="empFullName" class="font-geist font-bold text-[10px] uppercase tracking-widest text-[#4C4546]">Full Name <span class="text-swiss-accent-red">*</span></label>
                    <input type="text" placeholder="ENTER FULL NAME" id="empFullName" class="font-geist font-bold uppercase text-[11px] p-2 bg-white border border-swiss-border focus:ring-0 focus:outline-none focus:border-black rounded-none" required>
                    <p id="empFullNameError" class="mt-1 text-[10px] font-mono uppercase tracking-wider text-swiss-accent-red hidden"></p>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="empDepartment" class="font-geist font-bold text-[10px] uppercase tracking-widest text-[#4C4546]">Department (Optional)</label>
                    <select id="empDepartment" class="font-geist text-[11px] p-2 bg-white border border-swiss-border focus:ring-0 focus:outline-none focus:border-black appearance-none rounded-none">
                        <option value="">-- SELECT DEPARTMENT --</option>
                        @foreach (var dept in departments)
                        {
                            <option value="@dept.Id.Value">@dept.Name.ToUpper()</option>
                        }
                    </select>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="empPosition" class="font-geist font-bold text-[10px] uppercase tracking-widest text-[#4C4546]">Position (Optional)</label>
                    <select id="empPosition" class="font-geist text-[11px] p-2 bg-white border border-swiss-border focus:ring-0 focus:outline-none focus:border-black appearance-none rounded-none">
                        <option value="">-- SELECT POSITION --</option>
                        @foreach (var pos in positions)
                        {
                            <option value="@pos.Id.Value">@pos.Name.ToUpper()</option>
                        }
                    </select>
                </div>
                <div class="col-span-2 flex flex-col gap-2">
                    <label for="empJoinDate" class="font-geist font-bold text-[10px] uppercase tracking-widest text-[#4C4546]">Join Date</label>
                    <input type="date" id="empJoinDate" class="mono-text text-[11px] p-2 bg-white border border-swiss-border focus:ring-0 focus:outline-none focus:border-black rounded-none" required>
                </div>
                <!-- Info Box -->
                <div class="col-span-2 p-4 bg-swiss-light border border-swiss-border">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-[#7e7576] text-[18px]">info</span>
                        <p class="mono-text text-[9px] text-[#4C4546] leading-relaxed uppercase">
                            INFO: ACCOUNT ACCESS IS NOT CREATED UNTIL PROVISIONING IS COMPLETED.
                        </p>
                    </div>
                </div>
            </div>
            <!-- Modal Footer -->
            <div class="h-16 flex items-center justify-between px-6 bg-white border-t border-swiss-border">
                <div class="mono-text text-[9px] text-[#7e7576] font-bold uppercase tracking-tighter">
                    SYSTEM: <span class="text-black">LIVE</span>
                </div>
                <div class="flex gap-4">
                    <button type="button" class="bg-white border border-swiss-border px-6 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-swiss-light transition-colors rounded-none" data-modal-hide="createEmployeeModal">
                        CANCEL
                    </button>
                    <button type="button" id="saveEmpButton" class="bg-black text-white border border-black px-6 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-white hover:text-black transition-all rounded-none">
                        CREATE EMPLOYEE
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

