@model Domain.Departments.Department

<div id="updateDepartmentModal-@Model.Id.Value" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative w-full max-w-md max-h-full">
        <!-- Modal content -->
        <div class="relative bg-white rounded-lg shadow dark:bg-gray-700">
            <button type="button" class="absolute top-3 right-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ml-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="updateDepartmentModal-@Model.Id.Value">
                <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
                <span class="sr-only">Close modal</span>
            </button>
            <div class="px-6 py-6 lg:px-8">
                <h3 class="mb-4 text-xl font-medium text-gray-900 dark:text-white">Edit Department</h3>
                <div class="space-y-4">
                    <input type="hidden" id="deptId-@Model.Id.Value" value="@Model.Id.Value">
                    <div>
                        <label for="deptCode-@Model.Id.Value" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Department Code</label>
                        <input type="text" placeholder="e.g. IT, HR, FIN" id="deptCode-@Model.Id.Value" value="@Model.Code" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" required>
                        <p id="deptCodeError-@Model.Id.Value" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                    </div>
                    <div>
                        <label for="deptName-@Model.Id.Value" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Department Name</label>
                        <input type="text" placeholder="Enter Department Name" id="deptName-@Model.Id.Value" value="@Model.Name" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" required>
                        <p id="deptNameError-@Model.Id.Value" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                    </div>
                    <div>
                        <label for="deptDescription-@Model.Id.Value" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Description (Optional)</label>
                        <textarea placeholder="Enter Description" id="deptDescription-@Model.Id.Value" rows="3" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white">@Model.Description</textarea>
                    </div>
                    <button type="button" id="saveDeptButton-@Model.Id.Value" class="w-full text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">Save</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        const toastContainer = $('#toast-container')
        const deptCodeError = $('#deptCodeError-@Model.Id.Value')
        const deptNameError = $('#deptNameError-@Model.Id.Value')
        deptCodeError.hide();
        deptNameError.hide();

        $('#saveDeptButton-@Model.Id.Value').on('click', function (){
            deptCodeError.hide();
            deptNameError.hide();
            const deptId = $('#deptId-@Model.Id.Value').val()
            const deptCode = $('#deptCode-@Model.Id.Value').val()
            const deptName = $('#deptName-@Model.Id.Value').val()
            const deptDescription = $('#deptDescription-@Model.Id.Value').val()
            
            if(!deptCode || deptCode.trim() === ''){
                deptCodeError.show();
                deptCodeError.text("Please enter department code")
                return;
            }
            if(!deptName || deptName.trim() === ''){
                deptNameError.show();
                deptNameError.text("Please enter department name")
                return;
            }
        
            const formData = new FormData()
            formData.append('Id', deptId)
            formData.append('Code', deptCode)
            formData.append('Name', deptName)
            formData.append('Description', deptDescription)

            $.ajax({
                type: "POST",
                url: `/department/update`,
                data: formData,
                processData: false,
                contentType: false,
                success: function (e) {
                    toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Department updated successfully" }, null)')
                    setTimeout(() => {
                        location.href="/department"
                    }, 1500)
                },
                error: function (error){
                    toastContainer.load('@Url.Action("FailToastPartial", "Main", new { message = "Department update failed" }, null)')
                },
            })
        })
    });
</script>
