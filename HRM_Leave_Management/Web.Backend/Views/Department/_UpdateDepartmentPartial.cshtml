@model Domain.Departments.Department

<div id="updateDepartmentModal-@Model.Id.Value" tabindex="-1" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <!-- Static Backdrop (Enterprise Calm Dim style) -->
    <div class="fixed inset-0 hrm-modal-backdrop" aria-hidden="true"></div>
    <div class="min-h-screen flex items-center justify-center p-4 relative z-10">
        <!-- Modal content panel -->
        <div class="w-full max-w-[480px] bg-white border border-black rounded-none shadow-none flex flex-col overflow-hidden relative">
            <!-- Modal Header -->
            <div class="h-12 flex items-center justify-between px-4 bg-black text-white">
                <span class="font-geist font-bold text-[14px] uppercase tracking-wider">EDIT DEPARTMENT</span>
                <button type="button" class="bg-[#E62429] w-8 h-8 flex items-center justify-center hover:bg-[#c51f24] transition-colors" data-modal-hide="updateDepartmentModal-@Model.Id.Value">
                    <span class="material-symbols-outlined text-[20px] text-white">close</span>
                </button>
            </div>
            <!-- Modal Body -->
            <div class="p-6 flex flex-col gap-4 text-left font-geist">
                <input type="hidden" id="deptId-@Model.Id.Value" value="@Model.Id.Value">
                <div>
                    <label for="deptCode-@Model.Id.Value" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider font-mono">Department Code</label>
                    <input type="text" placeholder="E.G. IT, HR, FIN" id="deptCode-@Model.Id.Value" value="@Model.Code" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 font-mono text-[11px] uppercase focus:outline-none focus:border-black transition-colors" required autocomplete="off">
                    <p id="deptCodeError-@Model.Id.Value" style="display: none;" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide"></p>
                </div>
                <div>
                    <label for="deptName-@Model.Id.Value" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">Department Name</label>
                    <input type="text" placeholder="ENTER DEPARTMENT NAME" id="deptName-@Model.Id.Value" value="@Model.Name" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 text-[12px] uppercase font-bold focus:outline-none focus:border-black transition-colors" required autocomplete="off">
                    <p id="deptNameError-@Model.Id.Value" style="display: none;" class="mt-1 text-[10px] font-bold text-[#E62429] uppercase tracking-wide"></p>
                </div>
                <div>
                    <label for="deptDescription-@Model.Id.Value" class="block mb-1 text-[10px] font-bold text-[#4c4546] uppercase tracking-wider">Description (Optional)</label>
                    <textarea placeholder="ENTER DESCRIPTION" id="deptDescription-@Model.Id.Value" rows="3" class="w-full bg-white border border-[#D1D1D1] px-3 py-2 text-[11px] focus:outline-none focus:border-black transition-colors" autocomplete="off">@Model.Description</textarea>
                </div>
            </div>
            <!-- Modal Footer -->
            <div class="h-16 flex items-center justify-end gap-3 px-6 bg-[#FBFBFB] border-t border-[#D1D1D1]">
                <button data-modal-hide="updateDepartmentModal-@Model.Id.Value" type="button" class="bg-white border border-[#D1D1D1] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-[#F4F3F3] transition-colors rounded-none cursor-pointer">
                    CANCEL
                </button>
                <button type="button" id="saveDeptButton-@Model.Id.Value" class="bg-[#E62429] text-white border border-[#E62429] px-4 py-2 font-geist font-bold text-[11px] uppercase tracking-widest hover:bg-white hover:text-[#E62429] transition-all rounded-none cursor-pointer">
                    SAVE
                </button>
            </div>
        </div>
    </div>
</div>

