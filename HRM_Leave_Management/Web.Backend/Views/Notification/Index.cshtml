@using Domain.Notifications
@model NotificationViewModel

@{
    ViewBag.Title = "Notification";
    Layout = "_Layout";
}

<div class="w-full">
    <div class="w-full flex flex-col">
        <nav class="flex" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">
                        <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                            <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z" />
                        </svg>
                    </a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4" />
                        </svg>
                        <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Marketing</span>
                    </div>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4" />
                        </svg>
                        <a href="#" class="ml-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ml-2 dark:text-gray-400 dark:hover:text-white">Thông báo</a>
                    </div>
                </li>
            </ol>
        </nav>

        <div class="w-full flex items-center justify-content-end">
            <a type="button" data-modal-target="popup-modal-create-notification" data-modal-toggle="popup-modal-create-notification" class="inline-block rounded bg-indigo-600 px-4 py-1 px-2 text-sm font-medium text-white transition hover:scale-110 hover:shadow-xl focus:outline-none focus:ring active:bg-indigo-500">
                Add Notification
            </a>
            <div id="popup-modal-create-notification" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
                <div class="relative p-4 w-full max-w-md max-h-full">
                    <!-- Modal content -->
                    <div class="relative bg-white rounded-lg shadow dark:bg-gray-700">
                        <!-- Modal header -->
                        <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600">
                            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                                Add Notification
                            </h3>
                            <button type="button" class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="popup-modal-create-notification">
                                <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
                                </svg>
                                <span class="sr-only">Close modal</span>
                            </button>
                        </div>
                        <!-- Modal body -->
                        <div class="p-4 md:p-5">
                            <div class="space-y-4">
                                <div>
                                    <label class=" block mb-2 text-sm font-medium text-gray-900 dark:text-white">Notification title</label>
                                    <input type="text" id="notiTitle" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" placeholder="Enter Title" required>
                                </div>
                                <div>
                                    <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Notification content</label>
                                    <textarea rows="3" type="text" id="notiContent" placeholder="Enter title" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" required></textarea>
                                </div>
                                <div>
                                    <label for="memberIds" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Customer / All </label>
                                    <select multiple id="memberIds">
                                        @foreach (var op in Model.Members)
                                        {
                                            <option value="@op.Id">@op.FullName</option>
                                        }
                                    </select>
                                </div>
                                <button id="submitNotification" class="w-full text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">Add Notification</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div style="min-height: 543px" class="bg-white w-full p-3 rounded-lg mt-3">
            <h1 class="text-xl py-2 mb-2 font-bold text-black">Notification List</h1>
            <div class="overflow-x-auto w-full h-full overflow-y-auto">
                <table class="min-w-full divide-y-2 divide-gray-200 text-sm">
                    <thead class="ltr:text-left rtl:text-right bg-[#F4F7FC]">
                        <tr>
                            <th class="whitespace-nowrap px-4 py-2 font-medium text-black text-center">
                                NO
                            </th>
                            <th class="whitespace-nowrap px-4 py-2 font-medium text-black">
                                Content
                            </th>
                            <th class="whitespace-nowrap px-4 py-2 font-medium text-black">
                                Date
                            </th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-gray-200">

                        @foreach (var noti in Model.Notifications.Data.Select((val, index) => new { val, index = index + 1 }))
                        {
                            <tr class="my-2 py-4">
                                <td class="whitespace-nowrap px-4 py-2 font-medium text-gray-900 text-center">
                                    <strong>@noti.index.ToString()</strong>
                                </td>

                                <td class="whitespace-nowrap px-4 py-2 text-blue-600 text-left font-medium">
                                    @if (noti.val.Type == NotificationTypes.Order)
                                    {
                                        @Html.ActionLink(noti.val.Title, "Detail", "OrderAndDelivery", new { orderId = noti.val.ReferenceId })
                                    }
                                    else if (noti.val.Type == NotificationTypes.Booking)
                                    {
                                        @Html.ActionLink(noti.val.Title, "Detail", "Booking", new { bookingId = noti.val.ReferenceId })
                                    }
                                    else
                                    {
                                        @noti.val.Title
                                    }
                                </td>
                                <td class="text-wrap min-w-[160px] px-4 py-2 text-gray-900 text-left">
                                    @noti.val.CreatedAt.ToString("dd/MM/yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@Html.Partial("_Pagination", new PaginationViewModel { CurrentPage = Model.Notifications.CurrentPage, TotalPage = Model.Notifications.TotalPages, PageSize = Model.Notifications.PageSize, HasNext = Model.Notifications.HasNext, HasPrevious = Model.Notifications.HasPrevious, TotalItem = Model.Notifications.TotalCount })

@section Scripts
{
    <script>
            const loadingBookingOverlay = $('#loadingOverlay');
            loadingBookingOverlay.hide();
            const toastContainer = $('#toast-container')

            $(document).ready(function (){
                $('#memberIds').SumoSelect({
                    placeholder: 'Select Customer',
                });
            })

            $('#submitNotification').on('click', function (){
                const memberIds = $('#memberIds').val()
                const title = $('#notiTitle').val();
                const content = $('#notiContent').text()
                $.ajax({
                    type: "POST",
                    url: `/notification/create-notification`,
                    data: {
                        title,
                        content,
                        memberIds
                    },
                    dataType: 'multipart/form-data',
                    success: function () {
                        loadingBookingOverlay.hide();
                        toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Save Success" }, null)')
                        location.reload();
                    },error: function (error){
                        if (error.status === 200){
                            loadingBookingOverlay.hide();
                            toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Save Success" }, null)')
                            location.reload();
                        }else{
                            loadingBookingOverlay.hide();
                            toastContainer.load('@Url.Action("FailToastPartial", "Main", new { message = "Save Failed" }, null)')
                        }
                    }
                })
        })
    </script>
}