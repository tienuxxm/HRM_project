@using System.Text.Json.Serialization
@using Application.Orders.GetRevenue
@using Newtonsoft.Json
@model DashboardViewModel

@{
    ViewBag.Title = "Dashboard";
    Layout = "_Layout";
}
<div class="w-full mt-3 p-3">
    <div class="grid grid-cols-12 2xl:gap-6 xl:gap-6 lg:gap-4 md:gap-4 sm:gap-3">
        <div class="col-span-12">
            <span class="text-lg font-medium">BOOKING</span>
        </div>
        <div class="2xl:col-span-4 xl:col-span-4 lg:col-span-4 col-span-4 md:col-span-12 sm:col-span-12 bg-white rounded-2xl p-4">
            <div class="flex-col flex">
                <div class="flex justify-between items-start">
                    <div class="flex-col flex">
                        <span class="text-sm font-semibold text-lime-500">
                            Completed
                        </span>
                        <span class="text-2xl font-bold mt-1">
                            @Model.BookingReportResponse.BookingSuccessReport.TotalQuantity
                        </span>
                    </div>

                    <svg width="27" height="26" viewBox="0 0 27 26" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                        <rect x="0.28479" width="25.9177" height="26" fill="url(#pattern0)"/>
                        <defs>
                            <pattern id="pattern02" patternContentUnits="objectBoundingBox" width="1" height="1">
                                <use xlink:href="#image0_228_4192" transform="matrix(0.00195933 0 0 0.00195312 -0.00158732 0)"/>
                            </pattern>
                            <image id="image0_228_4192" width="512" height="512" xlink:href="data:image/png;base64,"/>
                        </defs>
                    </svg>
                </div>
                <div class="flex mt-3 items-center">
                    <span class="p-1 px-3 rounded-xl bg-lime-500 text-white font-light">
                        @Model.BookingReportResponse.BookingSuccessReport.GrowthRateResponse
                    </span>
                    <span class="font-normal ml-2">
                        Compared to last month
                    </span>
                </div>
            </div>
        </div>
        <div class="2xl:col-span-4 xl:col-span-4 lg:col-span-4 col-span-4 md:col-span-12 sm:col-span-12 bg-white rounded-2xl p-4">
            <div class="flex-col flex">
                <div class="flex justify-between items-start">
                    <div class="flex-col flex">
                        <span class="text-sm font-semibold text-blue-500">
                            Processing
                        </span>
                        <span class="text-2xl font-bold mt-1">
                            @Model.BookingReportResponse.BookingInProcessReport.TotalQuantity
                        </span>
                    </div>
                    <svg width="27" height="26" viewBox="0 0 27 26" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                        <rect x="0.28479" width="25.9177" height="26" fill="url(#pattern0)"/>
                        <defs>
                            <pattern id="pattern0" patternContentUnits="objectBoundingBox" width="1" height="1">
                                <use xlink:href="#image0_228_419" transform="matrix(0.00195933 0 0 0.00195312 -0.00158732 0)"/>
                            </pattern>
                            <image id="image0_228_419" width="512" height="512" xlink:href="data:image/png;base64,"/>
                        </defs>
                    </svg>
                </div>
                <div class="flex mt-3 items-center">
                    <span class="p-1 px-3 rounded-xl bg-blue-500 text-white font-light">
                        @Model.BookingReportResponse.BookingInProcessReport.GrowthRateResponse
                    </span>
                    <span class="font-normal ml-2">
                        Compared to last month
                    </span>
                </div>
            </div>
        </div>
        <div class="2xl:col-span-4 xl:col-span-4 lg:col-span-4 md:col-span-12 sm:col-span-12 bg-white rounded-2xl p-4">
            <div class="flex-col flex">
                <div class="flex justify-between items-start">
                    <div class="flex-col flex">
                        <span class="text-sm font-semibold text-red-500">
                            Canceled
                        </span>
                        <span class="text-2xl font-bold mt-1">
                            @Model.BookingReportResponse.BookingCancelReport.TotalQuantity
                        </span>
                    </div>
                    <svg width="27" height="26" viewBox="0 0 27 26" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                        <rect x="0.28479" width="25.9177" height="26" fill="url(#pattern0)"/>
                        <defs>
                            <pattern id="pattern0" patternContentUnits="objectBoundingBox" width="1" height="1">
                                <use xlink:href="#image0_228_419" transform="matrix(0.00195933 0 0 0.00195312 -0.00158732 0)"/>
                            </pattern>
                            <image id="image0_228_419" width="512" height="512" xlink:href="data:image/png;base64,"/>
                        </defs>
                    </svg>
                </div>
                <div class="flex mt-3 items-center">
                    <span class="p-1 px-3 rounded-xl bg-red-500 text-white font-light">
                        @Model.BookingReportResponse.BookingCancelReport.GrowthRateResponse
                    </span>
                    <span class="font-normal ml-2">
                        Compared to last month
                    </span>
                </div>
            </div>
        </div>

        <div class="2xl:col-span-4 xl:col-span-4 lg:col-span-4 col-span-4 md:col-span-12 sm:col-span-12 min-h-[28rem] bg-white rounded-2xl p-4">
            <div class="flex flex-col gap-2">
                <span class="text-gray-400 text-sm font-light">
                    Statistics
                </span>
                <span class="text-2xl font-bold mt-1">
                    ORDERS @(DateTime.Now.ToString("M/yyyy"))
                </span>
                <hr class="h-px my-8 bg-gray-500 border-0 dark:bg-gray-700">

                <canvas id="doughnut-chart" width="200" height="200"></canvas>
            </div>
        </div>
        <div class="2xl:col-span-8 xl:col-span-8 lg:col-span-8 col-span-8 md:col-span-12 sm:col-span-12 min-h-[28rem] bg-white rounded-2xl p-4">
            <div class="flex flex-col gap-2">
                <span class="text-gray-400 text-sm font-light">
                    Statistics
                </span>
                <div class="flex justify-content-between items-center">
                    <span class="text-2xl font-bold mt-1">
                        SALES REVENUE
                    </span>
                    <button id="dropdownBottomButtonDashboard" data-dropdown-toggle="dropdownBottomDashboard" data-dropdown-placement="bottom" class="mr-3 mb-3 md:mb-0 text-gray-400 bg-gray-300 hover:bg-gray-500 hover:text-white transition ease-in-out  delay-150 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-2 py-1 text-center inline-flex items-center" type="button">
                        @if ((RevenueDataRangeType)Model.RevenueRange == RevenueDataRangeType.Week)
                        {
                            <span>
                                By Week
                            </span>
                        }
                        else
                        {
                            <span>
                                By Month
                            </span>
                        }
                        <svg class="w-1.5 h-1.5 ml-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                        </svg>
                    </button>

                    <!-- Dropdown menu -->
                    <div id="dropdownBottomDashboard" class="z-10 hidden bg-white divide-y divide-gray-100 rounded-lg shadow w-44 dark:bg-gray-700">
                        <ul class="py-2 text-sm text-gray-700 dark:text-gray-200" aria-labelledby="dropdownBottomButton">
                            <li>
                                <a href="?revenueRangeType=@((int)RevenueDataRangeType.Week)" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white">Theo tuần</a>
                            </li>
                            <li>
                                <a href="?revenueRangeType=@((int)RevenueDataRangeType.Month)" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white">Theo tháng</a>
                            </li>
                        </ul>
                    </div>
                </div>
                <hr class="h-px my-8 bg-gray-500 border-0 dark:bg-gray-700">
                <canvas id="bar-chart"></canvas>
            </div>
        </div>

    </div>
</div>

@section Scripts
{
    <script>
        new Chart(document.getElementById("doughnut-chart"), {
            type: 'doughnut',
            data: {
              labels: ["Completed", "Processing", "Cancelled" ],
              datasets: [
                {
                  backgroundColor: ["#84CC16", "#3F83F8", "#F05252"],
                  data: [@Model.BookingReportResponse.TotalCompleteOrder,@Model.BookingReportResponse.TotalInProgressOrder,@Model.BookingReportResponse.TotalCancelOrder]
                }
              ]
            },
            options: {
              title: {
                display: true,
                text: 'Predicted world population (millions) in 2050'
              },
              plugins: {
                      datalabels: {
                          formatter: (value, ctx) => {
                              let sum = 0;
                              let dataArr = ctx.chart.data.datasets[0].data;
                              dataArr.map(data => {
                                  sum += data;
                              });
                              return  Math.floor(value*100 / sum)+"%";
                          },
                          color: '#fff',
                          font: {
                              size: 12,
                              weight: 'bold'
                          }
                      }
                  }
            },
            plugins: [ChartDataLabels],
        });
        
        $(document).ready(function (){
            const days = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"]
            const revenue = @(Json.Serialize(Model.RevenueResponse));
            const labels = revenue.map(r => {
                const day = parseDate(r.name).getDay()
                return days[day];
            })
            const backgroundColors = revenue.map(r => r.isCurrent ? '#F4B200' : '#97ACF5')
            const data = revenue.map(r => r.value)
            
            new Chart(document.getElementById("bar-chart"), {
            type: 'bar',
            data: {
              labels: labels,
              datasets: [
                {
                  label: "",
                  backgroundColor: backgroundColors,
                  data: data
                }
              ]
            },
            options: {
              legend: { display: false },
            }
        });
            
        })
        
        
    </script>
}