@model Web.Backend.Models.DashboardViewModel

@{
    ViewBag.Title = "Operational Dashboard - HRM Leave Management";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="hrm-dashboard-container">
    <!-- Header Section -->
    <div class="hrm-dashboard-header">
        <div class="hrm-dashboard-title-group">
            <h1>HRM OPERATIONAL DASHBOARD</h1>
            <p>Enterprise workforce and leave intelligence (Swiss Operational Shell)</p>
        </div>
        <div class="hrm-period-filter-group">
            <label for="periodSelect" class="sr-only">Reporting Period</label>
            <select id="periodSelect" class="hrm-filter-select" aria-label="Reporting Period">
                <option value="CurrentMonth" selected="@(Model.PeriodFilter == "CurrentMonth")">Period: Current Month</option>
                <option value="NextMonth" selected="@(Model.PeriodFilter == "NextMonth")">Period: Next Month</option>
                <option value="YearToDate" selected="@(Model.PeriodFilter == "YearToDate")">Period: Year To Date (YTD)</option>
            </select>
        </div>
    </div>

    <!-- Main Operational Grid -->
    <div class="hrm-dashboard-grid">

        <!-- W1: My Leave Requests -->
        @if (Model.ShowW1MyLeaveRequests)
        {
            <div class="col-span-4">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge">W1</span> MY LEAVE REQUESTS
                        </h2>
                        <a href="/leave-request" class="hrm-card-action">View All &rarr;</a>
                    </div>
                    @if (Model.MyLeaveRequests.Any())
                    {
                        <table class="hrm-data-table">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Dates</th>
                                    <th>Days</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var req in Model.MyLeaveRequests)
                                {
                                    <tr>
                                        <td>@req.LeaveTypeName</td>
                                        <td>@req.StartDate.ToString("dd MMM") - @req.EndDate.ToString("dd MMM yyyy")</td>
                                        <td>@req.Duration</td>
                                        <td><span class="hrm-status hrm-status-@req.Status.ToLower()">@req.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="hrm-empty-state">
                            <span class="hrm-empty-text">No leave requests submitted yet</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- W2: Leave Status Distribution -->
        @if (Model.ShowW2StatusDistribution)
        {
            <div class="col-span-8">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge">W2</span> LEAVE STATUS DISTRIBUTION
                        </h2>
                        <a href="/leave-request" class="hrm-card-action">Filter by Status &rarr;</a>
                    </div>
                    @if (Model.StatusDistribution != null && Model.StatusDistribution.TotalCount > 0)
                    {
                        var total = (double)Model.StatusDistribution.TotalCount;
                        var appPct = (Model.StatusDistribution.ApprovedCount / total * 100).ToString("F1");
                        var pendPct = (Model.StatusDistribution.PendingCount / total * 100).ToString("F1");
                        var rejPct = (Model.StatusDistribution.RejectedCount / total * 100).ToString("F1");
                        var cancPct = (Model.StatusDistribution.CanceledCount / total * 100).ToString("F1");

                        <div class="hrm-distribution-bar">
                            <div class="hrm-bar-segment hrm-bar-approved" style="width: @appPct%" title="Approved: @Model.StatusDistribution.ApprovedCount"></div>
                            <div class="hrm-bar-segment hrm-bar-pending" style="width: @pendPct%" title="Pending: @Model.StatusDistribution.PendingCount"></div>
                            <div class="hrm-bar-segment hrm-bar-rejected" style="width: @rejPct%" title="Rejected: @Model.StatusDistribution.RejectedCount"></div>
                            <div class="hrm-bar-segment hrm-bar-canceled" style="width: @cancPct%" title="Canceled: @Model.StatusDistribution.CanceledCount"></div>
                        </div>
                        <div class="hrm-legend-grid">
                            <div>Approved: @Model.StatusDistribution.ApprovedCount</div>
                            <div>Pending: @Model.StatusDistribution.PendingCount</div>
                            <div>Rejected: @Model.StatusDistribution.RejectedCount</div>
                            <div>Other: @Model.StatusDistribution.CanceledCount</div>
                        </div>
                    }
                    else
                    {
                        <div class="hrm-empty-state">
                            <span class="hrm-empty-text">No leave status data available</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- W3: 6-Month Leave Trend -->
        @if (Model.ShowW3MonthlyTrend)
        {
            <div class="col-span-8">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge">W3</span> 6-MONTH LEAVE TREND
                        </h2>
                        <a href="/leave-request" class="hrm-card-action">View Schedule &rarr;</a>
                    </div>
                    @if (Model.MonthlyTrend.Any())
                    {
                        var maxCount = Model.MonthlyTrend.Max(m => m.RequestCount);
                        var chartMax = maxCount > 0 ? maxCount : 1;
                        var count = Model.MonthlyTrend.Count;

                        // Calculate SVG polyline points with guaranteed top (18) and bottom (72) padding in viewBox 0 0 400 90
                        var pointsStr = new System.Text.StringBuilder();
                        for (int i = 0; i < count; i++)
                        {
                            var x = count > 1 ? 20 + i * (360 / (count - 1)) : 200;
                            var y = 72 - (int)Math.Round((Model.MonthlyTrend[i].RequestCount / (double)chartMax) * 54);
                            pointsStr.Append($"{x},{y} ");
                        }

                        <div class="hrm-trend-line-container">
                            <div class="w-full h-[95px] relative overflow-hidden">
                                <svg class="w-full h-full" viewBox="0 0 400 90" preserveAspectRatio="none">
                                    <polyline fill="none" points="@pointsStr.ToString().Trim()" stroke="#111111" stroke-width="1.5"></polyline>
                                    @for (int i = 0; i < count; i++)
                                    {
                                        var cx = count > 1 ? 20 + i * (360 / (count - 1)) : 200;
                                        var cy = 72 - (int)Math.Round((Model.MonthlyTrend[i].RequestCount / (double)chartMax) * 54);
                                        <circle cx="@cx" cy="@cy" fill="#111111" r="3"></circle>
                                    }
                                </svg>
                            </div>
                            <div class="flex justify-between w-full text-[10px] font-mono text-gray-500 pt-2 border-t border-gray-100 select-none shrink-0">
                                @foreach (var month in Model.MonthlyTrend)
                                {
                                    <span>@month.MonthLabel</span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="hrm-empty-state">
                            <span class="hrm-empty-text">No monthly trend data available</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- W4: Approval Queue -->
        @if (Model.ShowW4ApprovalQueue)
        {
            <div class="col-span-6">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge">W4</span> APPROVAL QUEUE
                        </h2>
                        <a href="/leave-request" class="hrm-card-action">Review Queue &rarr;</a>
                    </div>
                    @if (Model.PendingApprovals.Any())
                    {
                        <div class="hrm-approval-queue">
                            @foreach (var item in Model.PendingApprovals)
                            {
                                <div class="hrm-approval-card">
                                    <div class="hrm-approval-card-header">
                                        <span class="hrm-approval-name">@item.EmployeeName</span>
                                        <span class="hrm-approval-age @(item.PendingDays >= 3 ? "hrm-age-overdue" : "")">@(item.PendingDays == 0 ? "Today" : item.PendingDays + "d ago")</span>
                                    </div>
                                    <div class="hrm-approval-card-body">
                                        <span class="hrm-approval-type">@item.LeaveTypeName</span>
                                        <span class="hrm-approval-dates">@item.StartDate.ToString("dd MMM") - @item.EndDate.ToString("dd MMM")</span>
                                        <span class="hrm-approval-duration">@item.Duration day(s)</span>
                                    </div>
                                    <a href="/leave-request" class="hrm-approval-link">Review &rarr;</a>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="hrm-empty-state">
                            <span class="hrm-empty-text">No pending approval requests</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- W5: Approval Aging -->
        @if (Model.ShowW5ApprovalAging)
        {
            <div class="col-span-6">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge hrm-badge-alert">W5</span> APPROVAL AGING
                        </h2>
                        <a href="/leave-request" class="hrm-card-action">Check Overdue &rarr;</a>
                    </div>
                    @if (Model.ApprovalAging != null && Model.ApprovalAging.TotalPending > 0)
                    {
                        <div class="hrm-aging-buckets">
                            <div class="hrm-aging-bucket">
                                <span class="hrm-aging-count">@Model.ApprovalAging.TodayCount</span>
                                <span class="hrm-aging-label">Today</span>
                            </div>
                            <div class="hrm-aging-bucket">
                                <span class="hrm-aging-count">@Model.ApprovalAging.OneToTwoDaysCount</span>
                                <span class="hrm-aging-label">1-2 Days</span>
                            </div>
                            <div class="hrm-aging-bucket hrm-aging-overdue">
                                <span class="hrm-aging-count">@Model.ApprovalAging.OverdueCount</span>
                                <span class="hrm-aging-label">3+ Days</span>
                            </div>
                        </div>
                        @if (Model.ApprovalAging.TopOverdue.Any())
                        {
                            <div class="hrm-overdue-list">
                                <span class="hrm-overdue-header">OVERDUE REQUESTS</span>
                                @foreach (var item in Model.ApprovalAging.TopOverdue)
                                {
                                    <div class="hrm-overdue-item">
                                        <span class="hrm-overdue-name">@item.EmployeeName</span>
                                        <span class="hrm-overdue-type">@item.LeaveTypeName</span>
                                        <span class="hrm-overdue-age">@item.AgeDays days</span>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="hrm-empty-state">
                            <span class="hrm-empty-text">No overdue approval requests</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- W6: My Leave Balance -->
        @if (Model.ShowW6MyLeaveBalance)
        {
            <div class="col-span-4">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge">W6</span> MY LEAVE BALANCE
                        </h2>
                        <a href="/leave-request" class="hrm-card-action">Create New Request &rarr;</a>
                    </div>
                    @if (Model.MyLeaveBalance != null)
                    {
                        var availPct = Model.MyLeaveBalance.AllocatedDays > 0
                            ? (double)Model.MyLeaveBalance.AvailableDays / (double)Model.MyLeaveBalance.AllocatedDays * 100
                            : 0;

                        <div class="hrm-balance-summary">
                            <div class="hrm-balance-track">
                                <div class="hrm-balance-fill" style="width: @availPct.ToString("F1")%">
                                    <span class="hrm-balance-text-white">@Model.MyLeaveBalance.AvailableDays.ToString("F1") / @Model.MyLeaveBalance.AllocatedDays.ToString("F1")</span>
                                </div>
                            </div>
                            <div class="hrm-balance-metadata">
                                <span>Total: @Model.MyLeaveBalance.AllocatedDays.ToString("F1")</span>
                                <span>Used: @Model.MyLeaveBalance.UsedDays.ToString("F1")</span>
                                <span>Pending: @Model.MyLeaveBalance.PendingDays.ToString("F1")</span>
                                <span class="hrm-balance-bold">Avail: @Model.MyLeaveBalance.AvailableDays.ToString("F1")</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="hrm-empty-state">
                            <span class="hrm-empty-text">No Annual Leave balance found for current year</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- W7: Low Balance Watchlist -->
        @if (Model.ShowW7LowBalanceWatchlist)
        {
            <div class="col-span-4">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge hrm-badge-alert">W7</span> LOW BALANCE WATCHLIST
                        </h2>
                        <a href="/employee" class="hrm-card-action">Employee Directory &rarr;</a>
                    </div>
                    <div class="hrm-skeleton-box">
                        <span class="hrm-skeleton-text">LOW BALANCE WATCHLIST</span>
                        <span class="hrm-skeleton-subtext">No employees currently on low balance watchlist (&le; 2.0 days)</span>
                    </div>
                </div>
            </div>
        }

        <!-- W8: Upcoming Holidays & Work Calendar -->
        @if (Model.ShowW8UpcomingHolidays)
        {
            <div class="col-span-8">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge">W8</span> UPCOMING HOLIDAYS & WORK CALENDAR
                        </h2>
                        <a href="/work-calendar" class="hrm-card-action">View Work Calendar &rarr;</a>
                    </div>
                    @if (Model.UpcomingHolidays.Any())
                    {
                        <div class="hrm-timeline">
                            @foreach (var holiday in Model.UpcomingHolidays)
                            {
                                <div class="hrm-timeline-item">
                                    <div class="hrm-timeline-dot"></div>
                                    <div class="w-20 text-[13px] font-mono font-bold">@holiday.Date.ToString("dd/MM")</div>
                                    <div class="flex-1">
                                        <p class="text-[13px] font-medium">@(holiday.Description ?? "Non-Working Day")</p>
                                        <span class="bg-gray-100 text-[10px] px-2 py-0.5 border border-gray-200 uppercase font-bold text-gray-600">@holiday.DayType</span>
                                    </div>
                                    <div class="text-[11px] text-gray-500">@holiday.DayName</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="hrm-empty-state">
                            <span class="hrm-empty-text">No upcoming holidays scheduled</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- W9: Calendar Impact Alerts -->
        @if (Model.ShowW9CalendarImpactAlerts)
        {
            <div class="col-span-6">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge">W9</span> CALENDAR IMPACT ALERTS
                        </h2>
                        <a href="/work-calendar" class="hrm-card-action">Impact Details &rarr;</a>
                    </div>
                    @if (Model.CalendarImpactAlerts.Any())
                    {
                        <div class="space-y-3">
                            @foreach (var alert in Model.CalendarImpactAlerts)
                            {
                                <div class="p-3 border border-standard flex justify-between items-center">
                                    <div>
                                        <p class="text-[13px] font-semibold">@alert.EventName</p>
                                        <p class="text-[11px] text-gray-500 font-mono">@alert.Date.ToString("dd MMM yyyy") (@alert.DayType)</p>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-[10px] font-bold font-mono px-2 py-0.5 @(alert.AffectedLeaveRequestsCount > 0 ? "bg-black text-white" : "bg-gray-100 text-gray-600")">
                                            @alert.AffectedLeaveRequestsCount Overlaps
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="hrm-empty-state">
                            <span class="hrm-empty-text">No calendar impact alerts for upcoming period</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- W10: Department Leave Load -->
        @if (Model.ShowW10DepartmentLeaveLoad)
        {
            <div class="col-span-6">
                <div class="hrm-card">
                    <div class="hrm-card-header">
                        <h2 class="hrm-card-title">
                            <span class="hrm-badge">W10</span> DEPARTMENT LEAVE LOAD
                        </h2>
                        <a href="/department" class="hrm-card-action">Department Report &rarr;</a>
                    </div>
                    @if (Model.DepartmentLeaveLoad.Any())
                    {
                        <div class="hrm-dept-load-list">
                            @foreach (var dept in Model.DepartmentLeaveLoad)
                            {
                                <div class="hrm-dept-load-row">
                                    <div class="hrm-dept-load-header">
                                        <span>@dept.DepartmentName.ToUpper()</span>
                                        <span>@dept.ActiveLeaveCount active leave(s)</span>
                                    </div>
                                    <div class="hrm-dept-load-track">
                                        <div class="hrm-dept-load-bar" style="width: @dept.LoadPercentage.ToString("F1")%"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="hrm-empty-state">
                            <span class="hrm-empty-text">No department leave load data available</span>
                        </div>
                    }
                </div>
            </div>
        }

    </div>

    <!-- Fallback if no widget is allowed -->
    @if (!Model.ShowW1MyLeaveRequests && !Model.ShowW2StatusDistribution && !Model.ShowW3MonthlyTrend &&
         !Model.ShowW4ApprovalQueue && !Model.ShowW5ApprovalAging && !Model.ShowW6MyLeaveBalance &&
         !Model.ShowW7LowBalanceWatchlist && !Model.ShowW8UpcomingHolidays && !Model.ShowW9CalendarImpactAlerts &&
         !Model.ShowW10DepartmentLeaveLoad)
    {
        <div class="hrm-card" style="margin-top: 2rem;">
            <div class="hrm-skeleton-box">
                <span class="hrm-skeleton-text">NO REPORTING WIDGET PERMISSIONS GRANTED</span>
                <span class="hrm-skeleton-subtext">Please contact your system administrator to check account access permissions.</span>
            </div>
        </div>
    }
</div>
