@using Microsoft.AspNetCore.Mvc.TagHelpers
@model LoginViewModel
@{
    Layout = null;
    ViewBag.Title = "Sign-In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Web.Backend</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/sumoselect.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
</head>
<body class="bg-wnz-secondary">
<script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/1.8.1/flowbite.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/1.8.1/datepicker.min.js"></script>
<div id="toast-container"></div>
<div id="loadingOverlay" style="z-index: 1000 !important;" class="transition delay-150 ease-in-out fixed top-0 left-0 bg-gray-800 bg-opacity-60 h-full w-full h-full flex items-center justify-center">
  
</div>
<div class="w-full h-screen">
    <div class="bg-gray-50 dark:bg-gray-900">
        <div class="flex flex-col items-center justify-center px-6 py-8 mx-auto md:h-screen lg:py-0">
            <a href="#" class="flex items-center mb-6 text-2xl font-semibold text-gray-900 dark:text-white">
                    <h1 style="color:chocolate; font-size:xx-large;font-weight:bold"> LOGO HERE </h1>
            </a>
            <div class="w-full bg-white rounded-lg shadow dark:border md:mt-0 sm:max-w-md xl:p-0 dark:bg-gray-800 dark:border-gray-700">
                <div class="p-6 space-y-4 md:space-y-6 sm:p-8">
                    <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 md:text-2xl dark:text-white">
                        Sign In
                    </h1>
                    <form class="space-y-4 md:space-y-6" action="#">
                        <div>
                            <label for="username" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Username</label>
                            <input autocomplete="username" asp-for="Username" type="text" name="Username" id="username" class="bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Enter Username" required>
                            <p id="usernameError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                        </div>
                        <div>
                            <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Password</label>
                            <input autocomplete="current-password" asp-for="Password" type="password" name="Password" id="password" placeholder="Password" class="bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" required>
                            <p id="passwordError" class="mt-2 text-sm text-red-600 dark:text-red-500"></p>
                        </div>
                        <div class="flex items-center justify-content-end">
                            <a href="#" class="text-sm font-medium text-primary-600 hover:underline dark:text-primary-500">Forgot Password?</a>
                        </div>
                        <button id="loginButton" type="button" class="w-full text-white bg-wnz-yellow focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
                            <div class="flex gap-2 items-center justify-center">
                                <svg id="spinner" aria-hidden="true" role="status" class="inline w-4 h-4 me-3 text-white animate-spin" viewBox="0 0 100 101" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="#E5E7EB"/>
                                    <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentColor"/>
                                </svg>
                                <span id="loginLabel">
                                    Login
                                </span>
                            </div>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/jquery.sumoselect.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    const loginButton = $('#loginButton')
    const usernameError = $('#usernameError');
    const passwordError = $('#passwordError');
    const toastContainer = $('#toast-container')
    const loadingOverlay = $('#loadingOverlay');
    loadingOverlay.hide();
    const formData = new FormData();
    
    let isFormValid = false;
    
    function resetFormError(){
        usernameError.hide();
        passwordError.hide();
    }
    
    resetFormError();
    
    function validation(){
        resetFormError()
        
        const username = $('#username').val()
        const password = $('#password').val()
        const errors = []
        if(username === ''){
            const error = 'Please Input username'
            usernameError.show();
            usernameError.text(error)
            errors.push(error)
        }
        
        if(password === ''){
            const error = 'Please input password'
            passwordError.show();
            passwordError.text(error)
            errors.push(error)
        }
        
        isFormValid = errors.length === 0
    }
    
    const spinner = $('#spinner')
    $(document).on('load', function (){
        spinner.hide()
    })
    spinner.hide()
    function toggleLoginButton(state){
        const loginButton = $('#loginButton')
        const loginLabel = $('#loginLabel')
        if (state){
            loginButton.prop('disabled', true);
            spinner.show();
                loginLabel.text('Logging in...')
        }else{
            loginButton.prop('disabled', false);
            spinner.hide();
            loginLabel.text('Login')
        }
    }
    
    loginButton.on('click', function (){
        validation();
        if (!isFormValid){
            return;
        }
        const username = $('#username').val()
        const password = $('#password').val()
        
        formData.delete("Username") 
        formData.delete("Password") 
        formData.append("Username", username) 
        formData.append("Password", password) 
        toggleLoginButton(true)
        
        $.ajax({
                type: "POST",
                url: `/auth/login`,
                data: formData,
                processData: false,
                contentType: false,
                success: function () {
                        toastContainer.load('@Url.Action("SuccessToastPartial", "Main", new { message = "Login Successful" }, null)')
                    setTimeout(() => {
                        loadingOverlay.show();
                        location.href="/dashboard"
                        toggleLoginButton(false)
                    }, 1500)
                },
                error: function (error){
                    toggleLoginButton(false)
                    passwordError.show();
                        passwordError.text('Incorrect Username or Password')
                        toastContainer.load('@Url.Action("FailToastPartial", "Main", new { message = "Login Failed" }, null)')
                },
                done: function() {
                    toggleLoginButton(false)
                }
            })
    });
</script>
</body>