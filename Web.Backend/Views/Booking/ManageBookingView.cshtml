@section Scripts
{
    <script>
        flatpickr('#bookingTime', {
            enableTime: true,
            noCalendar: true,
            dateFormat: "H:i",
        });
        
        flatpickr('#date', {
            dateFormat: "d/m/Y",
            minDate: "today"
        });
        
        const loading = $("#loadingSpinner");
        const searchPlaceholder = $("#searchPlaceholder");
        const selectMemberDropdownItemContainer = $("#selectMemberDropdownItemContainer")
        const searchResult = $('#searchResult')
        const memberList = $('#memberList')
        let selectedMemberId;
        loading.hide();
        searchResult.hide();
        function setMemberSelected(member){
            $("#memberList").val(member)
        }
        
        $('#memberList').on('keyup', debounce(() => searchMember()))
        $('#memberList').on('keypress', function (){
            selectMemberDropdownItemContainer.find('.member-item').remove()
            searchPlaceholder.hide();
            searchResult.hide();
            loading.show()
            
        })
        
        const saveButton = $('#saveButton')
        let isFormValid = false;
        const nameError =  $('#nameError')
        const phoneError  =  $('#phoneError')
        const bookingDateError =  $('#bookingDateError')
        const bookingTimeError =  $('#bookingTimeError')
        const isUpdate = @(Model.BookingModel.Id.HasValue ? "true" : "false")
        
        function resetFormError(){
            nameError.hide();
            phoneError.hide();
            bookingDateError.hide();
            bookingTimeError.hide();
        }
        
        function inputChange(inputName){
            switch (inputName){
                case 'name':
                    nameError.hide();
                    break;
                case 'phone':
                    phoneError.hide();
                    break;
                case 'time':
                    bookingTimeError.hide();
                    break;
                case 'date':
                    bookingDateError.hide();
                    break;
            }
        }
        
        resetFormError()
        
        function formValidate(){
            
            resetFormError();
            
            const name = $('#fullName').val();
            const phone = $('#phoneNumber').val()
            const bookingDate = parseDate($('#date').val());
            const bookingTime = $('#bookingTime')
            
            const errors = [];
            
            if (name === '' || !name){
                const error = 'Please provide the reservation name'
                nameError.show();
                nameError.text(error);
                errors.push(error);
            }
            
            if (phone === '' || !phone){
                const error = 'Please enter phone number'
                phoneError.show();
                phoneError.text(error);
                errors.push(error);
            }
            
            
            if (bookingDate === null || !bookingDate){
                        const error = 'Please select a reservation date'
                bookingDateError.show();
                bookingDateError.text(error);
                errors.push(error);
            }
            /*else{
                if (bookingDate < new Date()){
                    const error = 'Ngày đặt bàn No hợp lệ'
                    bookingDateError.show();
                    bookingDateError.text(error);
                    errors.push(error);
                }
            }*/
            
            if (bookingTime === '' || !bookingTime){
                const error = 'Please chọn giờ đặt bàn'
                bookingTime.show();
                bookingTime.text(error);
                errors.push(error);
            }else{
                
            }
            isFormValid = errors.length === 0;
            
        }

        
        const submitButton = $('#submitButton')
        saveButton.on('click', (event) => {
            event.preventDefault();
            formValidate();
            if(!isFormValid){
                return;
            }
            
            const loadingOverlay = $('#loadingOverlay');
            loadingOverlay.show();
            
            const restaurantId = $("#restaurant").val();
            const numberOfPeople = $("#numberOfPeople").val();
            const date = $("#date").val().trim();
            const time = $("#bookingTime").val();
            const fullName = $('#fullName').val()
            const phoneNumber = $('#phoneNumber').val()
            const bookingNote = $('#note').val()
            
            const lineItems = []
            
            extendLineItemIds.forEach(id => {
                const productId = $(`#productList${id}`).val();
                const quantity = parseInt($(`#productQuantity${id}`).val());
                const note = $(`#productNote${id}`).val();
                lineItems.push({
                    productId,
                    quantity,
                    note
                })
            })
            
            let request = {
                fullName,
                phoneNumber,
                restaurantId,
                numberOfPeople,
                date,
                time,
                lineItems: [],
                note: bookingNote,
                id: isUpdate ? '@Model.BookingModel.Id' : null
            }
            
            const toastContainer = $('#toast-container')
            
            $.ajax({
                type: "POST",
                url: isUpdate ? '/Booking/Update' :`/booking/reserve`,
                data: {
                    ...request
                },
                dataType: 'multipart/form-data',
                success: function () {
                    loadingOverlay.hide();
                    showToast(isUpdate ? 'Save Success' : 'Added Success')
                    setTimeout(() => {
                        loadingOverlay.show();
                        location.href = "/booking"
                    }, 1500)
                },error: function (error){
                    if (error.status === 200){
                        loadingOverlay.hide();
                        showToast(isUpdate ? 'Save Success' : 'Added Success')
                        setTimeout(() => {
                            loadingOverlay.show();
                            location.href = "/booking"
                        }, 1500)
                    }else{
                        loadingOverlay.hide();
                        showToast('Add Failed')
                    }
                }
            })
        })
        
        $(document).ready(function() {
            if (isUpdate){
            lineItems = @(Json.Serialize(Model.BookingModel.LineItems))
            lineItems?.forEach(item => {
                addNewLineItem(item.productId, item.quantity, item.note ?? '' )
            })
        }
        });
        
        let extendLineItemIds = [];
        let lineItems = []
        
        const lineItemsContainer = $("#lineItemsList")
        function uuidv4() {
          return "10000000-1000-4000-8000-100000000000".replace(/[018]/g, c =>
            (c ^ crypto.getRandomValues(new Uint8Array(1))[0] & 15 >> c / 4).toString(16)
          );
        }
       
        const productList = @(Json.Serialize(Model.ProductList))
        
        function addNewLineItem(productId = null, quantity = 1, note = ''){
            const id = uuidv4();
            extendLineItemIds.push(id);
            lineItemsContainer.append(`<div class="grid grid-cols-12 gap-2 mt-3 relative" id="lineItem${id}">
                        <div id="lineItemRemoveIcon${id}" class="absolute right-0 top-0 cursor-pointer hover:scale-110">
                            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M10.1406 8.32812C10.1406 8.52344 10.0625 8.71875 9.92188 8.85937L8.85938 9.92187C8.71875 10.0625 8.52344 10.1406 8.32813 10.1406C8.13281 10.1406 7.9375 10.0625 7.79688 9.92187L5.5 7.625L3.20313 9.92187C3.0625 10.0625 2.86719 10.1406 2.67188 10.1406C2.47656 10.1406 2.28125 10.0625 2.14063 9.92187L1.07813 8.85937C0.9375 8.71875 0.859375 8.52344 0.859375 8.32812C0.859375 8.13281 0.9375 7.9375 1.07813 7.79687L3.375 5.5L1.07813 3.20312C0.9375 3.0625 0.859375 2.86719 0.859375 2.67188C0.859375 2.47656 0.9375 2.28125 1.07813 2.14062L2.14063 1.07812C2.28125 0.9375 2.47656 0.859374 2.67188 0.859374C2.86719 0.859374 3.0625 0.9375 3.20313 1.07812L5.5 3.375L7.79688 1.07812C7.9375 0.9375 8.13281 0.859374 8.32813 0.859374C8.52344 0.859374 8.71875 0.9375 8.85938 1.07812L9.92188 2.14062C10.0625 2.28125 10.1406 2.47656 10.1406 2.67188C10.1406 2.86719 10.0625 3.0625 9.92188 3.20312L7.625 5.5L9.92188 7.79687C10.0625 7.9375 10.1406 8.13281 10.1406 8.32812Z" fill="#FF0202"/>
                            </svg>
                        </div>
                        <div class="2xl:col-span-5 xl:col-span-4 lg:col-span-4 md:col-span-4 col-span-12">
                            <label for="productList${id}" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Dish</label>
                            <select placeholder="Chọn món ăn" name="productId${id}" id="productList${id}" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500">
                                ${productList.map(p => {
                                    if (productId === p.id){
                                        return `<option selected value="${p.id}">${p.productName}</option>`
                                    }else{
                                        return `<option value="${p.id}">${p.productName}</option>`
                                    }
                                })}
                            </select>
                        </div>
                        <div class="2xl:col-span-1 xl:col-span-2 lg:col-span-2 md:col-span-2 col-span-4">
                            <label for="productQuantity${id}" class="required-label block mb-2 text-sm font-medium text-gray-900 dark:text-white">Quantity</label>
                            <input value="${quantity}" required type="number" min="1" name="productQuantity${id}" id="productQuantity${id}" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Quantity">
                        </div>
                        <div class="2xl:col-span-5 xl:col-span-6 lg:col-span-6 md:col-span-6 col-span-8">
                            <label for="productNote${id}" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Notes</label>
                            <input type="text" value="${note}" name="productNote${id}" id="productNote${id}" class="border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" placeholder="Enter Notes">
                        </div>
                    </div>`)
                    $(`#lineItemRemoveIcon${id}`).one('click', () => removeLineItem(id))
        }
        
        function removeLineItem(lineItemId){
            extendLineItemIds = extendLineItemIds.filter(x => x !== lineItemId)
            $(`#lineItem${lineItemId}`).remove()
        }
        
        const lblCompanyTaxCode = $("#lblCompanyTaxCode")
        const lblCompanyEmail = $("#lblCompanyMail")
        const lblCompanyAddress = $("#lblCompanyAddress")
        const lblCompanyName = $("#lblCompanyName")
        const companyTaxCode = $("#companyTaxCode")
        const companyEmail = $("#companyMail")
        const companyAddress = $("#companyAddress")
        const companyName = $("#companyName")
        const companyField = $("#companyField")
        function toggleIssueAnInvoice(toggle){
            if (toggle){
                lblCompanyName.addClass("required-label")
                lblCompanyAddress.addClass("required-label")
                lblCompanyTaxCode.addClass("required-label")
                lblCompanyEmail.addClass("required-label")
                companyAddress.attr("required",true);
                companyName.attr("required",true);
                companyEmail.attr("required",true);
                companyTaxCode.attr("required",true);
                companyField.show();
            }else{
                lblCompanyName.removeClass("required-label")
                lblCompanyAddress.removeClass("required-label")
                lblCompanyTaxCode.removeClass("required-label")
                lblCompanyEmail.removeClass("required-label")
                companyAddress.removeAttr("required");
                companyName.removeAttr("required");
                companyEmail.removeAttr("required");
                companyTaxCode.removeAttr("required");   
                companyField.hide();
            }
        }
       
        /*$("#submitButton").on('click', function (){
            
            
        });*/
        
        function debounce(func, timeout = 500){
          let timer;
          return (...args) => {
            clearTimeout(timer);
            timer = setTimeout(() => { func.apply(this, args); }, timeout);
          };
        }
        
        function searchMember(){
            const searchValue = memberList.val()
            if(!searchValue){
                searchPlaceholder.show()
                searchResult.hide();
                loading.hide();
                selectMemberDropdownItemContainer.find('.member-item').remove()
                return;
            }
            
            $.ajax({
                type: "GET",
                url: `/Restaurant/Search?value=${searchValue}`,
                success: function (customers) {
                    selectMemberDropdownItemContainer.find('.member-item').remove()
                    if(!customers || customers.length === 0){
                        searchResult.show();
                    }
                    $.each(customers, function (i, member) {
                        const memberElement = $(`<p class="member-item text-wrap text-sm rounded-lg px-2 text-gray-900 p-1 font-semibold hover:bg-wnz-yellow hover:text-white transition ease-in-out cursor-pointer">${member.firstName + ' ' + member.lastName + ' - '+ member.phoneNumber}</p>`)
                        memberElement.on('click', function (){
                            selectedMemberId = member.id;
                            memberList.val(member.firstName + ' ' + member.lastName + ' - '+ member.phoneNumber)
                        })
                        selectMemberDropdownItemContainer.append(memberElement)
                    });
                },error: function (){
                    searchResult.show();
                }
            }).done(function (){
                setTimeout(() => {
                    loading.hide();
                }, 300)
            })
        }
        
        $(document).ready(function (){
            $('#selectMemberDropdown').append('')
        })
        
        $(document).ready(function (){
            $('#productSelect').SumoSelect({
                placeholder: 'Choose a dish',
            });
        })
    </script>
